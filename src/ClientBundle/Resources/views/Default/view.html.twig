{% set currency = client.currency %}

{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% block page_title %}
    {{ client.name }}
{% endblock page_title %}

{% block content %}
    {# ========================================================================
       HERO SECTION
       ======================================================================== #}
    <div class="client-hero">
        <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between gap-3">
            <div>
                <div class="d-flex align-items-center gap-3 mb-2">
                    <h1 class="client-hero-title">{{ client.name }}</h1>
                    {{ client_label(client.status) }}
                </div>
                <div class="client-hero-meta">
                    {% if client.website %}
                        {% set website_url = client.website starts with 'http://' or client.website starts with 'https://' ? client.website : 'https://' ~ client.website %}
                        <a href="{{ website_url }}" class="client-hero-meta-item" rel="external noreferrer noopener" target="_blank">
                            {{ ux_icon('tabler:world', {width: 16, height: 16}) }}
                            <span>{{ client.website }}</span>
                            {{ ux_icon('tabler:external-link', {width: 14, height: 14}) }}
                        </a>
                    {% endif %}
                    {% if client.currencyCode %}
                        <span class="client-hero-meta-item">
                            {{ ux_icon('tabler:currency-dollar', {width: 16, height: 16}) }}
                            <span>{{ client.currencyCode }}</span>
                        </span>
                    {% endif %}
                    {% for identifier in tax_identifiers(client) %}
                        <span class="client-hero-meta-item">
                            {{ ux_icon('tabler:receipt-tax', {width: 16, height: 16}) }}
                            <span>{{ identifier.label }}: {{ identifier.value }}</span>
                        </span>
                    {% endfor %}
                </div>
            </div>

            {# Quick Actions #}
            <div class="d-flex flex-wrap gap-2">
                <a href="{{ path('_quotes_create', {'client': client.id}) }}" class="btn btn-outline-primary">
                    {{ ux_icon('tabler:file-text', {width: 18, height: 18}) }}
                    {{ 'client.view.actions.create_quote'|trans }}
                </a>
                <a href="{{ path('_invoices_create', {'client': client.id}) }}" class="btn btn-primary">
                    {{ ux_icon('tabler:file-invoice', {width: 18, height: 18}) }}
                    {{ 'client.view.actions.create_invoice'|trans }}
                </a>
                <a href="{{ path('_purchase_new', {'client': client.id}) }}" class="btn btn-outline-secondary">
                    {{ ux_icon('tabler:shopping-cart', {width: 18, height: 18}) }}
                    {{ 'Create Purchase Order'|trans }}
                </a>
                <div class="dropdown">
                    <button class="btn btn-outline-secondary" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="{{ 'More actions'|trans }}">
                        {{ ux_icon('tabler:dots-vertical', {width: 18, height: 18}) }}
                    </button>
                    <div class="dropdown-menu dropdown-menu-end">
                        <a class="dropdown-item d-flex align-items-center gap-2" href="{{ path('_clients_edit', {'id': client.id}) }}">
                            {{ ux_icon('tabler:pencil', {width: 16, height: 16}) }}
                            {{ 'client.view.actions.edit'|trans }}
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ========================================================================
       METRICS ROW
       ======================================================================== #}
    <div class="row row-cards mb-4">
        {# Total Income #}
        <div class="col-sm-6 col-lg-3">
            <twig:Ui:Card>
                <div class="client-stat-label">{{ 'client.stats.income'|trans }}</div>
                <div class="client-stat-value client-stat-value--success">
                    {{ total_income(client)|formatCurrency(client.currency) }}
                </div>
            </twig:Ui:Card>
        </div>

        {# Outstanding #}
        <div class="col-sm-6 col-lg-3">
            <twig:Ui:Card>
                <div class="client-stat-label">{{ 'client.stats.outstanding'|trans }}</div>
                <div class="client-stat-value client-stat-value--warning">
                    {{ total_outstanding(client)|formatCurrency(client.currency) }}
                </div>
            </twig:Ui:Card>
        </div>

        {# Invoices Count #}
        <div class="col-sm-6 col-lg-3">
            <twig:Ui:Card>
                <div class="client-stat-label">{{ 'client.stats.invoices'|trans }}</div>
                <div class="client-stat-value">{{ client.invoices|length }}</div>
                <div class="client-stat-badges">
                    <span class="badge bg-success-lt" title="{{ 'client.stats.tooltip.total_paid'|trans }}">
                        {{ total_invoices_paid }} {{ 'paid'|trans }}
                    </span>
                    <span class="badge bg-warning-lt" title="{{ 'client.stats.tooltip.total_outstanding'|trans }}">
                        {{ total_invoices_pending }} {{ 'pending'|trans }}
                    </span>
                </div>
            </twig:Ui:Card>
        </div>

        {# Quotes Count #}
        <div class="col-sm-6 col-lg-3">
            <twig:Ui:Card>
                <div class="client-stat-label">{{ 'client.stats.quotes'|trans }}</div>
                <div class="client-stat-value">{{ client.quotes|length }}</div>
            </twig:Ui:Card>
        </div>
    </div>

    {# ========================================================================
       CLIENT CREDIT SECTION
       ======================================================================== #}
    <div class="client-credit-card">
        <twig:Ui:Card>
            <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center gap-3">
                    <div class="client-credit-icon">
                        {{ ux_icon('tabler:wallet', {width: 24, height: 24}) }}
                    </div>
                    <div>
                        <div class="client-credit-label">{{ 'client.stats.credit'|trans }}</div>
                        <twig:ClientCredit :client="client" />
                    </div>
                </div>
            </div>
        </twig:Ui:Card>
    </div>

    {# ========================================================================
       TABS SECTION
       ======================================================================== #}
    <div class="client-tabs-card card">
        <div class="card-header">
            <ul class="nav nav-tabs card-header-tabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="info-tab" data-bs-toggle="tab" data-bs-target="#client-info" type="button" role="tab" aria-controls="client-info" aria-selected="true">
                        {{ ux_icon('tabler:info-circle', {width: 16, height: 16}) }}
                        <span>{{ 'client.view.tabs.info'|trans }}</span>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="quotes-tab" data-bs-toggle="tab" data-bs-target="#quotes" type="button" role="tab" aria-controls="quotes" aria-selected="false">
                        {{ ux_icon('tabler:file-text', {width: 16, height: 16}) }}
                        <span>{{ 'client.view.tabs.quotes'|trans }}</span>
                        <span class="badge bg-secondary-lt">{{ client.quotes|length }}</span>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="invoices-tab" data-bs-toggle="tab" data-bs-target="#invoices" type="button" role="tab" aria-controls="invoices" aria-selected="false">
                        {{ ux_icon('tabler:file-invoice', {width: 16, height: 16}) }}
                        <span>{{ 'client.view.tabs.invoices'|trans }}</span>
                        <span class="badge bg-secondary-lt">{{ client.invoices|length }}</span>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="purchases-tab" data-bs-toggle="tab" data-bs-target="#purchases" type="button" role="tab" aria-controls="purchases" aria-selected="false">
                        {{ ux_icon('tabler:shopping-cart', {width: 16, height: 16}) }}
                        <span>{{ 'Purchase Orders'|trans }}</span>
                        <span class="badge bg-secondary-lt">{{ purchases|length }}</span>
                    </button>
                </li>
                {% if payments|length > 0 %}
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="payments-tab" data-bs-toggle="tab" data-bs-target="#payments" type="button" role="tab" aria-controls="payments" aria-selected="false">
                            {{ ux_icon('tabler:credit-card', {width: 16, height: 16}) }}
                            <span>{{ 'client.view.tabs.payments'|trans }}</span>
                            <span class="badge bg-secondary-lt">{{ payments|length }}</span>
                        </button>
                    </li>
                {% endif %}
            </ul>
        </div>

        <div class="card-body">
            <div class="tab-content">
                {# Info Tab #}
                <div class="tab-pane fade show active" id="client-info" role="tabpanel" aria-labelledby="info-tab">
                    <twig:CustomFieldsList :target="enum('SolidInvoice\\CoreBundle\\Enum\\CustomFieldTarget').CLIENT" :recordId="client.id" />
                    <twig:ContactCollection :client="client" count="{{ client.contacts|length }}" />
                    <twig:AddressCollection :client="client" count="{{ client.addresses|length }}" />
                </div>

                {# Quotes Tab #}
                <div class="tab-pane fade" id="quotes" role="tabpanel" aria-labelledby="quotes-tab">
                    {% include "@SolidInvoiceClient/quote_list.html.twig" %}
                </div>

                {# Invoices Tab #}
                <div class="tab-pane fade" id="invoices" role="tabpanel" aria-labelledby="invoices-tab">
                    {% include "@SolidInvoiceClient/invoice_list.html.twig" %}
                </div>

                {# Purchase Orders Tab #}
                <div class="tab-pane fade" id="purchases" role="tabpanel" aria-labelledby="purchases-tab">
                    <div class="d-flex justify-content-end mb-3">
                        <a href="{{ path('_purchase_new', {'client': client.id}) }}" class="btn btn-sm btn-primary">
                            {{ ux_icon('tabler:plus', {width: 16, height: 16}) }}
                            {{ 'New Purchase Order'|trans }}
                        </a>
                    </div>
                    {% if purchases is empty %}
                        <div class="text-center py-5 text-muted">
                            {{ ux_icon('tabler:shopping-cart-off', {width: 40, height: 40}) }}
                            <p class="mt-3 mb-0">{{ 'No purchase orders for this client yet.'|trans }}</p>
                        </div>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-vcenter">
                                <thead>
                                    <tr>
                                        <th>{{ 'Date'|trans }}</th>
                                        <th>{{ 'Reference'|trans }}</th>
                                        <th class="text-end">{{ 'Total'|trans }}</th>
                                        <th class="text-end">{{ 'Paid'|trans }}</th>
                                        <th class="text-end">{{ 'Balance'|trans }}</th>
                                        <th>{{ 'Status'|trans }}</th>
                                        <th class="text-end">{{ 'Actions'|trans }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for purchase in purchases %}
                                        {% set badge = {'paid': 'bg-success-lt', 'partial': 'bg-warning-lt', 'unpaid': 'bg-secondary-lt'}[purchase.status] %}
                                        <tr>
                                            <td class="text-nowrap">{{ purchase.purchaseDate ? purchase.purchaseDate|date('d M Y') : '—' }}</td>
                                            <td>{{ purchase.reference ?: '—' }}</td>
                                            <td class="text-end">AED {{ purchase.totalAmount|number_format(2) }}</td>
                                            <td class="text-end text-success">AED {{ purchase.amountPaid|number_format(2) }}</td>
                                            <td class="text-end fw-semibold">AED {{ purchase.balance|number_format(2) }}</td>
                                            <td><span class="badge {{ badge }}">{{ purchase.status|capitalize|trans }}</span></td>
                                            <td class="text-end text-nowrap">
                                                <a href="{{ path('_purchase_view', {id: purchase.id}) }}" class="btn btn-sm btn-outline-secondary" title="{{ 'View / Print'|trans }}">
                                                    {{ ux_icon('tabler:eye', {width: 16, height: 16}) }}
                                                </a>
                                                <a href="{{ path('_purchase_edit', {id: purchase.id}) }}" class="btn btn-sm btn-outline-primary" title="{{ 'Edit'|trans }}">
                                                    {{ ux_icon('tabler:pencil', {width: 16, height: 16}) }}
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>

                {# Payments Tab #}
                {% if payments|length > 0 %}
                    <div class="tab-pane fade" id="payments" role="tabpanel" aria-labelledby="payments-tab">
                        {% include "@SolidInvoicePayment/Payment/list.html.twig" with {"data": {'client': client.id}} only %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    {# ========================================================================
       DELETE CLIENT MODAL
       ======================================================================== #}
    <twig:Ui:Modal id="delete-client-modal" title="{{ 'Confirm'|trans }}" status="danger" :centered="true">
        <div class="text-center py-3">
            <div class="mb-3">
                {{ ux_icon('tabler:alert-triangle', {width: 48, height: 48, class: 'text-danger'}) }}
            </div>
            <h3>{{ 'client.delete.confirm.title'|trans({'%name%': client.name}) }}</h3>
            <p class="text-muted">{{ 'client.delete.confirm.message'|trans }}</p>
        </div>

        <twig:block name="footer">
            <button type="button" class="btn btn-ghost" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
            <form method="post" action="{{ path('_clients_delete', {'id': client.id}) }}" class="d-inline">
                <input type="hidden" name="_method" value="DELETE">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ client.id) }}">
                <button type="submit" class="btn btn-danger">
                    {{ ux_icon('tabler:trash', {width: 16, height: 16}) }}
                    {{ 'client.view.actions.delete'|trans }}
                </button>
            </form>
        </twig:block>
    </twig:Ui:Modal>
{% endblock content %}
