{% set rows = this.rows %}
{% set populated = rows|filter(row => row.raw is not null) %}
{% if populated|length > 0 %}
    {% set typeIcons = {
        text: 'tabler:cursor-text',
        textarea: 'tabler:align-left',
        number: 'tabler:number',
        date: 'tabler:calendar',
        email: 'tabler:mail',
        url: 'tabler:link',
        checkbox: 'tabler:checkbox',
        select: 'tabler:list',
        multi_select: 'tabler:list-check',
    } %}

    <div class="card my-3 custom-fields-card">
        <div class="card-header">
            <span class="d-flex align-items-center gap-2">
                {{ ux_icon('tabler:forms', {width: 16, height: 16, class: 'text-muted'}) }}
                <span class="fw-medium">{{ 'Custom fields'|trans }}</span>
            </span>
        </div>
        <div class="card-body py-2">
            <dl class="custom-fields-list mb-0">
                {% for row in populated %}
                    {% set t = row.field.type.value %}
                    <div class="custom-fields-item">
                        <dt class="custom-fields-label">
                            {{ ux_icon(typeIcons[t]|default('tabler:tag'), {width: 14, height: 14, class: 'text-muted'}) }}
                            <span>{{ row.field.label }}</span>
                        </dt>
                        <dd class="custom-fields-value mb-0">
                            {% if t == 'url' %}
                                {% set safeUrl = row.raw matches '#^(https?:)?//#i' ? row.raw : null %}
                                {% if safeUrl %}
                                    <a href="{{ safeUrl }}" target="_blank" rel="noopener noreferrer">{{ row.raw }}</a>
                                {% else %}
                                    {{ row.raw }}
                                {% endif %}
                            {% elseif t == 'email' %}
                                <a href="mailto:{{ row.raw }}">{{ row.raw }}</a>
                            {% elseif t == 'date' %}
                                {{ row.raw|date('M d, Y') }}
                            {% elseif t == 'textarea' %}
                                <span class="text-pre-wrap">{{ row.formatted|nl2br }}</span>
                            {% elseif t == 'checkbox' %}
                                {% if row.raw == '1' %}
                                    {{ ux_icon('tabler:check', {width: 16, height: 16, class: 'text-success'}) }}
                                {% else %}
                                    {{ ux_icon('tabler:x', {width: 16, height: 16, class: 'text-muted'}) }}
                                {% endif %}
                            {% elseif t == 'multi_select' %}
                                {% for label in row.formatted|split(', ') %}
                                    <span class="badge bg-secondary-lt">{{ label }}</span>
                                {% endfor %}
                            {% elseif t == 'select' %}
                                <span class="badge bg-secondary-lt">{{ row.formatted }}</span>
                            {% else %}
                                {{ row.formatted }}
                            {% endif %}
                        </dd>
                    </div>
                {% endfor %}
            </dl>
        </div>
    </div>
{% endif %}
