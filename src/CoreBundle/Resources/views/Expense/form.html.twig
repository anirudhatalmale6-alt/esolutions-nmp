{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% set isEdit = expense is not null %}

{% block title %}{{ ux_icon('tabler:wallet', {width: 24, height: 24, class: 'me-2'}) }}{{ (isEdit ? 'Edit Expense' : 'New Expense')|trans }}{% endblock title %}

{% block heading %}
    <a href="{{ path('_expenses_list') }}" class="btn btn-outline-secondary">
        {{ ux_icon('tabler:arrow-left', {width: 18, height: 18}) }}
        {{ 'Back'|trans }}
    </a>
{% endblock %}

{% block content %}
    <twig:Ui:Card>
        <form method="post" action="{{ isEdit ? path('_expense_edit', {id: expense.id}) : path('_expense_new') }}">
            <div class="row g-3">
                <div class="col-md-4">
                    <label for="e-date" class="form-label">{{ 'Date'|trans }} <span class="text-danger">*</span></label>
                    <input type="date" name="expense_date" id="e-date" class="form-control" value="{{ data.expense_date }}" required>
                </div>
                <div class="col-md-4">
                    <label for="e-category" class="form-label">{{ 'Category'|trans }} <span class="text-danger">*</span></label>
                    <input type="text" name="category" id="e-category" class="form-control" list="expense-categories"
                           value="{{ data.category }}" placeholder="{{ 'e.g. Rent'|trans }}" maxlength="128" required autocomplete="off">
                    <datalist id="expense-categories">
                        {% for category in categories %}
                            <option value="{{ category }}"></option>
                        {% endfor %}
                    </datalist>
                    <div class="form-text">{{ 'Pick from the list or type your own.'|trans }}</div>
                </div>
                <div class="col-md-4">
                    <label for="e-amount" class="form-label">{{ 'Amount (AED)'|trans }} <span class="text-danger">*</span></label>
                    <input type="number" step="0.01" min="0" name="amount" id="e-amount" class="form-control" value="{{ data.amount }}" required>
                </div>
                <div class="col-md-6">
                    <label for="e-payee" class="form-label">{{ 'Paid to (optional)'|trans }}</label>
                    <input type="text" name="payee" id="e-payee" class="form-control" value="{{ data.payee }}" maxlength="191" placeholder="{{ 'e.g. landlord, staff name, DEWA'|trans }}">
                </div>
                <div class="col-md-6">
                    <label for="e-desc" class="form-label">{{ 'Note (optional)'|trans }}</label>
                    <input type="text" name="description" id="e-desc" class="form-control" value="{{ data.description }}">
                </div>
            </div>

            <input type="hidden" name="_token" value="{{ csrf_token('expense.save') }}">

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    {{ ux_icon('tabler:device-floppy', {width: 18, height: 18}) }}
                    {{ 'Save expense'|trans }}
                </button>
                <a href="{{ path('_expenses_list') }}" class="btn btn-link">{{ 'Cancel'|trans }}</a>
            </div>
        </form>
    </twig:Ui:Card>
{% endblock content %}
