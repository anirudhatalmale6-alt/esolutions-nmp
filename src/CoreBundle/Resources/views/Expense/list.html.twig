{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% block title %}{{ ux_icon('tabler:wallet', {width: 24, height: 24, class: 'me-2'}) }}{{ 'Payouts (Expenses)'|trans }}{% endblock title %}

{% block heading %}
    <a href="{{ path('_expense_new') }}" class="btn btn-primary">
        {{ ux_icon('tabler:plus', {width: 18, height: 18}) }}
        {{ 'New Expense'|trans }}
    </a>
{% endblock %}

{% block content %}
    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <div class="card"><div class="card-body">
                <div class="text-muted small text-uppercase">{{ 'Total paid out'|trans }}</div>
                <div class="h3 mb-0 text-danger">AED {{ totalExpenses|number_format(2) }}</div>
            </div></div>
        </div>
    </div>

    <twig:Ui:Card>
        {% if expenses is empty %}
            <div class="text-center py-5 text-muted">
                {{ ux_icon('tabler:wallet-off', {width: 40, height: 40}) }}
                <p class="mt-3 mb-1">{{ 'No expenses recorded yet.'|trans }}</p>
                <a href="{{ path('_expense_new') }}" class="btn btn-sm btn-primary mt-2">{{ 'Record your first expense'|trans }}</a>
            </div>
        {% else %}
            <div class="mb-3">
                <input type="text" id="expense-search" class="form-control" placeholder="{{ 'Search category, payee or note...'|trans }}" autocomplete="off">
            </div>
            <div class="table-responsive">
                <table class="table table-vcenter" id="expense-table">
                    <thead>
                        <tr>
                            <th>{{ 'Date'|trans }}</th>
                            <th>{{ 'Category'|trans }}</th>
                            <th>{{ 'Paid to'|trans }}</th>
                            <th>{{ 'Note'|trans }}</th>
                            <th class="text-end">{{ 'Amount'|trans }}</th>
                            <th class="text-end">{{ 'Actions'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody id="expense-body">
                        {% for expense in expenses %}
                            <tr data-search="{{ (expense.category ~ ' ' ~ (expense.payee ?: '') ~ ' ' ~ (expense.description ?: ''))|lower }}">
                                <td class="text-nowrap">{{ expense.expenseDate ? expense.expenseDate|date('d M Y') : '—' }}</td>
                                <td class="fw-semibold">{{ expense.category }}</td>
                                <td>{{ expense.payee ?: '—' }}</td>
                                <td class="text-muted">{{ expense.description ?: '—' }}</td>
                                <td class="text-end text-danger fw-semibold">AED {{ expense.amount|number_format(2) }}</td>
                                <td class="text-end text-nowrap">
                                    <a href="{{ path('_expense_edit', {id: expense.id}) }}" class="btn btn-sm btn-outline-primary" title="{{ 'Edit'|trans }}">
                                        {{ ux_icon('tabler:edit', {width: 15, height: 15}) }}
                                    </a>
                                    <form method="post" action="{{ path('_expense_delete', {id: expense.id}) }}" class="d-inline" onsubmit="return confirm('{{ 'Delete this expense?'|trans }}');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('expense.delete') }}">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            {{ ux_icon('tabler:trash', {width: 15, height: 15}) }}
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div id="expense-no-results" class="text-center text-muted py-4" style="display: none;">{{ 'No matching expenses found.'|trans }}</div>
            <script>
                (function () {
                    var input = document.getElementById('expense-search');
                    var rows = document.querySelectorAll('#expense-body tr');
                    var noResults = document.getElementById('expense-no-results');
                    if (!input) { return; }
                    input.addEventListener('input', function () {
                        var q = input.value.trim().toLowerCase();
                        var shown = 0;
                        rows.forEach(function (row) {
                            var match = q === '' || row.getAttribute('data-search').indexOf(q) !== -1;
                            row.style.display = match ? '' : 'none';
                            if (match) { shown++; }
                        });
                        noResults.style.display = shown === 0 ? 'block' : 'none';
                    });
                })();
            </script>
        {% endif %}
    </twig:Ui:Card>
{% endblock content %}
