{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% block title %}{{ ux_icon('tabler:package', {width: 24, height: 24, class: 'me-2'}) }}{{ 'Orders'|trans }}{% endblock title %}

{% block heading %}
    <a href="{{ path('_order_new') }}" class="btn btn-primary">
        {{ ux_icon('tabler:plus', {width: 18, height: 18}) }}
        {{ 'New order'|trans }}
    </a>
{% endblock %}

{% block content %}
    <div class="mb-3 d-flex flex-wrap gap-2">
        <a href="{{ path('_orders_list') }}" class="btn btn-sm {{ activeStatus is null ? 'btn-primary' : 'btn-outline-secondary' }}">
            {{ 'All'|trans }} <span class="badge bg-secondary-lt ms-1">{{ total }}</span>
        </a>
        {% for s in statuses %}
            <a href="{{ path('_orders_list', {status: s.value}) }}" class="btn btn-sm {{ activeStatus is same as(s) ? 'btn-primary' : 'btn-outline-secondary' }}">
                {{ s.label|trans }} <span class="badge bg-{{ s.color }}-lt ms-1">{{ counts[s.value]|default(0) }}</span>
            </a>
        {% endfor %}
    </div>

    <twig:Ui:Card>
        {% if orders is empty %}
            <div class="text-center py-5 text-muted">
                {{ ux_icon('tabler:package', {width: 40, height: 40}) }}
                <p class="mt-3 mb-1">{{ 'No orders here yet.'|trans }}</p>
                <a href="{{ path('_order_new') }}" class="btn btn-sm btn-primary mt-2">{{ 'Add your first order'|trans }}</a>
            </div>
        {% else %}
            <div class="table-responsive">
            <table class="table table-vcenter">
                <thead>
                    <tr>
                        <th>{{ 'Order'|trans }}</th>
                        <th>{{ 'Customer'|trans }}</th>
                        <th>{{ 'Item'|trans }}</th>
                        <th class="text-center">{{ 'Qty'|trans }}</th>
                        <th class="text-end">{{ 'Amount'|trans }}</th>
                        <th style="min-width: 160px;">{{ 'Status'|trans }}</th>
                        <th class="text-end" style="width: 190px;">{{ 'Actions'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for order in orders %}
                        <tr>
                            <td>
                                <div class="fw-bold">{{ order.orderNumber }}</div>
                                <div class="text-muted small">{{ order.created ? order.created|date('d M Y') : '' }}</div>
                            </td>
                            <td>
                                <div class="fw-semibold">{{ order.customerName }}</div>
                                <div class="text-muted small">{{ order.customerPhone }}</div>
                                <div class="text-muted small">{{ [order.area, order.city, order.emirate]|filter(v => v)|join(', ') }}</div>
                            </td>
                            <td>
                                <div>{{ order.model }}</div>
                                <div class="text-muted small">
                                    {{ [order.storage, order.condition, order.color]|filter(v => v)|join(' · ') }}
                                </div>
                            </td>
                            <td class="text-center">{{ order.quantity }}</td>
                            <td class="text-end text-nowrap">
                                <div class="fw-bold">AED {{ order.price|number_format(2) }}</div>
                                {% if order.cod %}
                                    <span class="badge bg-orange text-orange-fg">{{ 'COD'|trans }}{{ order.codAmount ? ' ' ~ order.codAmount|number_format(2) : '' }}</span>
                                {% else %}
                                    <span class="badge bg-green text-green-fg">{{ 'Paid'|trans }}</span>
                                {% endif %}
                            </td>
                            <td>
                                <span class="badge bg-{{ order.status.color }} text-{{ order.status.color }}-fg mb-1">{{ order.status.label|trans }}</span>
                                <form method="post" action="{{ path('_order_status', {id: order.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token(csrfIntent) }}">
                                    <select name="status" class="form-select form-select-sm" onchange="this.form.submit()" aria-label="{{ 'Change status'|trans }}">
                                        {% for s in statuses %}
                                            <option value="{{ s.value }}" {{ s is same as(order.status) ? 'selected' : '' }}>{{ s.label|trans }}</option>
                                        {% endfor %}
                                    </select>
                                </form>
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end align-items-center gap-1">
                                    <a href="{{ path('_order_label', {id: order.id}) }}" target="_blank" rel="noopener" class="btn btn-sm btn-outline-primary" title="{{ 'Print label'|trans }}">
                                        {{ ux_icon('tabler:printer', {width: 16, height: 16}) }}
                                    </a>
                                    <a href="{{ path('_order_edit', {id: order.id}) }}" class="btn btn-sm btn-outline-secondary" title="{{ 'Edit'|trans }}">
                                        {{ ux_icon('tabler:edit', {width: 16, height: 16}) }}
                                    </a>
                                    <form method="post" action="{{ path('_order_delete', {id: order.id}) }}" onsubmit="return confirm({{ 'Delete this order?'|trans|json_encode|raw }});">
                                        <input type="hidden" name="_token" value="{{ csrf_token(csrfIntent) }}">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="{{ 'Delete'|trans }}">{{ ux_icon('tabler:trash', {width: 16, height: 16}) }}</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            </div>
        {% endif %}
    </twig:Ui:Card>
{% endblock content %}
