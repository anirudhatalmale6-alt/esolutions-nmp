{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% set isEdit = purchase is not null %}
{% set rows = data.items|default([]) %}

{% block title %}{{ ux_icon('tabler:shopping-cart', {width: 24, height: 24, class: 'me-2'}) }}{{ (isEdit ? 'Edit Purchase Order' : 'New Purchase Order')|trans }}{% endblock title %}

{% block heading %}
    <a href="{{ path('_purchases_list') }}" class="btn btn-outline-secondary">
        {{ ux_icon('tabler:arrow-left', {width: 18, height: 18}) }}
        {{ 'Back'|trans }}
    </a>
{% endblock %}

{% block content %}
    {% if clients is empty %}
        <twig:Ui:Alert type="info">
            {{ 'You need at least one client before recording a purchase.'|trans }}
            <a href="{{ path('_clients_add') }}">{{ 'Add a client'|trans }}</a>.
        </twig:Ui:Alert>
    {% else %}
        <twig:Ui:Card>
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h2 class="h4 mb-0 text-uppercase">{{ 'Purchase Order'|trans }}</h2>
                {% if isEdit and data.reference %}
                    <span class="text-muted">{{ data.reference }}</span>
                {% endif %}
            </div>

            <form method="post" id="purchase-form" action="{{ isEdit ? path('_purchase_edit', {id: purchase.id}) : path('_purchase_new') }}">
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label for="p-supplier" class="form-label">{{ 'Supplier'|trans }} <span class="text-danger">*</span></label>
                        <select name="client_id" id="p-supplier" class="form-select client-select"
                                data-controller="symfony--ux-autocomplete--autocomplete" required>
                            <option value="">{{ '— Select supplier —'|trans }}</option>
                            {% for client in clients %}
                                <option value="{{ client.id }}" {{ data.client_id == (client.id ~ '') ? 'selected' : '' }}>{{ client.name }}</option>
                            {% endfor %}
                        </select>
                        <div class="form-text">{{ 'Start typing to search your clients list.'|trans }}</div>
                    </div>
                    <div class="col-md-3">
                        <label for="p-date" class="form-label">{{ 'Purchase date'|trans }} <span class="text-danger">*</span></label>
                        <input type="date" name="purchase_date" id="p-date" class="form-control" value="{{ data.purchase_date }}" required>
                    </div>
                    <div class="col-md-3">
                        <label for="p-ref" class="form-label">{{ 'Reference / Bill no'|trans }}</label>
                        <input type="text" name="reference" id="p-ref" class="form-control" value="{{ data.reference }}" maxlength="128">
                    </div>
                </div>

                {# ---------------- Line items ---------------- #}
                <div class="table-responsive">
                    <table class="table align-middle" id="purchase-items">
                        <thead>
                            <tr>
                                <th style="width: 50%;">{{ 'Item / Product'|trans }}</th>
                                <th style="width: 12%;" class="text-end">{{ 'Qty'|trans }}</th>
                                <th style="width: 18%;" class="text-end">{{ 'Unit price (AED)'|trans }}</th>
                                <th style="width: 18%;" class="text-end">{{ 'Line total'|trans }}</th>
                                <th style="width: 2%;"></th>
                            </tr>
                        </thead>
                        <tbody id="items-body">
                            {% if rows is empty %}
                                {% set rows = [{description: '', qty: '1', price: ''}] %}
                            {% endif %}
                            {% for row in rows %}
                                <tr class="purchase-item-row">
                                    <td>
                                        <input type="text" name="item_description[]" class="form-control item-desc" value="{{ row.description }}" placeholder="{{ 'e.g. iPhone 15 128GB'|trans }}">
                                    </td>
                                    <td>
                                        <input type="number" step="0.01" min="0" name="item_qty[]" class="form-control text-end item-qty" value="{{ row.qty }}">
                                    </td>
                                    <td>
                                        <input type="number" step="0.01" min="0" name="item_price[]" class="form-control text-end item-price" value="{{ row.price }}">
                                    </td>
                                    <td class="text-end item-line-total">0.00</td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-sm btn-link text-danger p-0 remove-row" title="{{ 'Remove'|trans }}">
                                            {{ ux_icon('tabler:trash', {width: 16, height: 16}) }}
                                        </button>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="5">
                                    <button type="button" class="btn btn-sm btn-outline-primary" id="add-row">
                                        {{ ux_icon('tabler:plus', {width: 16, height: 16}) }}
                                        {{ 'Add item'|trans }}
                                    </button>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="3" class="text-end fw-bold">{{ 'Total'|trans }}</td>
                                <td class="text-end fw-bold"><span id="grand-total">0.00</span> AED</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                {# ---------------- Payments to supplier (dated) ---------------- #}
                <div class="mt-4">
                    <label class="form-label fw-semibold">{{ 'Payments to supplier'|trans }}</label>
                    <div class="form-text mb-2">{{ 'Add each payment with the date you actually paid it. Leave empty if nothing paid yet. Each payment shows on that day in your Daily Ledger, so paying in parts over several days stays accurate.'|trans }}</div>
                    <div class="table-responsive">
                        <table class="table align-middle" id="purchase-payments">
                            <thead>
                                <tr>
                                    <th style="width: 45%;">{{ 'Payment date'|trans }}</th>
                                    <th style="width: 45%;" class="text-end">{{ 'Amount paid (AED)'|trans }}</th>
                                    <th style="width: 10%;"></th>
                                </tr>
                            </thead>
                            <tbody id="payments-body">
                                {% set prows = data.payments|default([]) %}
                                {% if prows is empty %}
                                    {% set prows = [{date: data.purchase_date, amount: ''}] %}
                                {% endif %}
                                {% for prow in prows %}
                                    <tr class="purchase-payment-row">
                                        <td>
                                            <input type="date" name="payment_date[]" class="form-control payment-date" value="{{ prow.date }}">
                                        </td>
                                        <td>
                                            <input type="number" step="0.01" min="0" name="payment_amount[]" class="form-control text-end payment-amount" value="{{ prow.amount }}">
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-link text-danger p-0 remove-payment" title="{{ 'Remove'|trans }}">
                                                {{ ux_icon('tabler:trash', {width: 16, height: 16}) }}
                                            </button>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="3">
                                        <button type="button" class="btn btn-sm btn-outline-primary" id="add-payment">
                                            {{ ux_icon('tabler:plus', {width: 16, height: 16}) }}
                                            {{ 'Add payment'|trans }}
                                        </button>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-end fw-bold">{{ 'Total paid'|trans }}</td>
                                    <td class="text-end fw-bold"><span id="paid-total">0.00</span> AED</td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td class="text-end fw-bold">{{ 'Balance owed'|trans }}</td>
                                    <td class="text-end fw-bold"><span id="balance-owed">0.00</span> AED</td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>

                <div class="row g-3 mt-2">
                    <div class="col-md-12">
                        <label for="p-desc" class="form-label">{{ 'Notes (optional)'|trans }}</label>
                        <textarea name="description" id="p-desc" class="form-control" rows="2">{{ data.description }}</textarea>
                    </div>
                </div>

                <input type="hidden" name="_token" value="{{ csrf_token('purchase.save') }}">

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        {{ ux_icon('tabler:device-floppy', {width: 18, height: 18}) }}
                        {{ 'Save purchase order'|trans }}
                    </button>
                    <a href="{{ path('_purchases_list') }}" class="btn btn-link">{{ 'Cancel'|trans }}</a>
                </div>
            </form>
        </twig:Ui:Card>

        {# Blank row template used when adding new lines #}
        <template id="row-template">
            <tr class="purchase-item-row">
                <td>
                    <input type="text" name="item_description[]" class="form-control item-desc" placeholder="{{ 'e.g. iPhone 15 128GB'|trans }}">
                </td>
                <td>
                    <input type="number" step="0.01" min="0" name="item_qty[]" class="form-control text-end item-qty" value="1">
                </td>
                <td>
                    <input type="number" step="0.01" min="0" name="item_price[]" class="form-control text-end item-price">
                </td>
                <td class="text-end item-line-total">0.00</td>
                <td class="text-center">
                    <button type="button" class="btn btn-sm btn-link text-danger p-0 remove-row" title="{{ 'Remove'|trans }}">
                        {{ ux_icon('tabler:trash', {width: 16, height: 16}) }}
                    </button>
                </td>
            </tr>
        </template>

        {# Blank row template used when adding new payments #}
        <template id="payment-row-template">
            <tr class="purchase-payment-row">
                <td>
                    <input type="date" name="payment_date[]" class="form-control payment-date" value="{{ data.purchase_date }}">
                </td>
                <td>
                    <input type="number" step="0.01" min="0" name="payment_amount[]" class="form-control text-end payment-amount">
                </td>
                <td class="text-center">
                    <button type="button" class="btn btn-sm btn-link text-danger p-0 remove-payment" title="{{ 'Remove'|trans }}">
                        {{ ux_icon('tabler:trash', {width: 16, height: 16}) }}
                    </button>
                </td>
            </tr>
        </template>

        <script>
            (function () {
                var form = document.getElementById('purchase-form');
                if (!form) { return; }

                var body = document.getElementById('items-body');
                var addBtn = document.getElementById('add-row');
                var template = document.getElementById('row-template');
                var grandTotalEl = document.getElementById('grand-total');

                function money(n) {
                    if (isNaN(n) || !isFinite(n)) { n = 0; }
                    return n.toFixed(2);
                }

                function recalc() {
                    var rows = body.querySelectorAll('.purchase-item-row');
                    var grand = 0;
                    rows.forEach(function (row) {
                        var qty = parseFloat(row.querySelector('.item-qty').value) || 0;
                        var price = parseFloat(row.querySelector('.item-price').value) || 0;
                        var line = qty * price;
                        grand += line;
                        row.querySelector('.item-line-total').textContent = money(line);
                    });
                    grandTotalEl.textContent = money(grand);
                }

                function wireRow(row) {
                    row.querySelectorAll('.item-qty, .item-price').forEach(function (input) {
                        input.addEventListener('input', recalc);
                    });
                    var removeBtn = row.querySelector('.remove-row');
                    if (removeBtn) {
                        removeBtn.addEventListener('click', function () {
                            // Keep at least one row on screen.
                            if (body.querySelectorAll('.purchase-item-row').length > 1) {
                                row.remove();
                            } else {
                                row.querySelector('.item-desc').value = '';
                                row.querySelector('.item-qty').value = '1';
                                row.querySelector('.item-price').value = '';
                            }
                            recalc();
                        });
                    }
                }

                body.querySelectorAll('.purchase-item-row').forEach(wireRow);

                if (addBtn) {
                    addBtn.addEventListener('click', function () {
                        var clone = template.content.firstElementChild.cloneNode(true);
                        body.appendChild(clone);
                        wireRow(clone);
                        clone.querySelector('.item-desc').focus();
                        recalc();
                    });
                }

                recalc();
            })();
        </script>

        <script>
            (function () {
                var body = document.getElementById('payments-body');
                var addBtn = document.getElementById('add-payment');
                var template = document.getElementById('payment-row-template');
                var paidTotalEl = document.getElementById('paid-total');
                var balanceEl = document.getElementById('balance-owed');
                var itemsTable = document.getElementById('purchase-items');
                if (!body) { return; }

                function money(n) {
                    if (isNaN(n) || !isFinite(n)) { n = 0; }
                    return n.toFixed(2);
                }

                function grandTotal() {
                    var el = document.getElementById('grand-total');
                    return el ? (parseFloat(el.textContent) || 0) : 0;
                }

                function recalc() {
                    var paid = 0;
                    body.querySelectorAll('.payment-amount').forEach(function (input) {
                        paid += parseFloat(input.value) || 0;
                    });
                    paidTotalEl.textContent = money(paid);
                    var balance = grandTotal() - paid;
                    if (balance < 0) { balance = 0; }
                    balanceEl.textContent = money(balance);
                }

                function wireRow(row) {
                    var amt = row.querySelector('.payment-amount');
                    if (amt) { amt.addEventListener('input', recalc); }
                    var removeBtn = row.querySelector('.remove-payment');
                    if (removeBtn) {
                        removeBtn.addEventListener('click', function () {
                            if (body.querySelectorAll('.purchase-payment-row').length > 1) {
                                row.remove();
                            } else {
                                row.querySelector('.payment-amount').value = '';
                            }
                            recalc();
                        });
                    }
                }

                body.querySelectorAll('.purchase-payment-row').forEach(wireRow);

                if (addBtn) {
                    addBtn.addEventListener('click', function () {
                        var clone = template.content.firstElementChild.cloneNode(true);
                        body.appendChild(clone);
                        wireRow(clone);
                        recalc();
                    });
                }

                // Keep the balance in step when the line items (grand total) change.
                if (itemsTable) {
                    itemsTable.addEventListener('input', recalc);
                }

                recalc();
            })();
        </script>
    {% endif %}
{% endblock content %}
