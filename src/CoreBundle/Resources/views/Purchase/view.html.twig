{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% set badge = {'paid': 'bg-success-lt', 'partial': 'bg-warning-lt', 'unpaid': 'bg-secondary-lt'}[purchase.status] %}

{% block title %}{{ ux_icon('tabler:file-invoice', {width: 24, height: 24, class: 'me-2'}) }}{{ 'Purchase Order'|trans }}{% endblock title %}

{% block heading %}
    <div class="d-flex gap-2 no-print">
        <a href="{{ path('_purchases_list') }}" class="btn btn-outline-secondary">
            {{ ux_icon('tabler:arrow-left', {width: 18, height: 18}) }}
            {{ 'Back'|trans }}
        </a>
        <a href="{{ path('_purchase_edit', {id: purchase.id}) }}" class="btn btn-outline-primary">
            {{ ux_icon('tabler:edit', {width: 18, height: 18}) }}
            {{ 'Edit'|trans }}
        </a>
        {% if purchase.balance > 0 %}
            <a href="{{ path('_purchase_pay', {id: purchase.id}) }}" class="btn btn-success">
                {{ ux_icon('tabler:cash', {width: 18, height: 18}) }}
                {{ 'Pay'|trans }}
            </a>
        {% endif %}
        <button type="button" class="btn btn-primary" onclick="window.print();">
            {{ ux_icon('tabler:printer', {width: 18, height: 18}) }}
            {{ 'Print / Save as PDF'|trans }}
        </button>
    </div>
{% endblock %}

{% block content %}
    <style>
        @media print {
            .no-print, .navbar, .app-header, .app-sidebar, header, nav, footer.footer { display: none !important; }
            .po-document { border: none !important; box-shadow: none !important; }
            body { background: #fff !important; }
        }
        .po-document { max-width: 900px; margin: 0 auto; }
        .po-title { letter-spacing: 2px; }
    </style>

    <twig:Ui:Card class="po-document">
        <div class="d-flex justify-content-between align-items-start mb-4">
            <div>
                <h1 class="h2 mb-1 text-uppercase po-title">{{ 'Purchase Order'|trans }}</h1>
                {% if purchase.reference %}
                    <div class="text-muted">{{ 'Ref'|trans }}: {{ purchase.reference }}</div>
                {% endif %}
            </div>
            <span class="badge {{ badge }} fs-4">{{ purchase.status|capitalize|trans }}</span>
        </div>

        <div class="row mb-4">
            <div class="col-sm-6">
                <div class="text-muted small text-uppercase mb-1">{{ 'Buyer'|trans }}</div>
                <div class="fw-bold">{{ company_name() }}</div>
                {% for identifier in tax_identifiers() %}
                    <div><strong>{{ identifier.label }}</strong> {{ identifier.value }}</div>
                {% endfor %}
                {% set phoneNumber = setting('system/company/contact_details/phone_number') %}
                {% if phoneNumber is not empty %}<div>{{ phoneNumber }}</div>{% endif %}
                {% set address = setting('system/company/contact_details/address', null, true) %}
                {% if address is not null and address|filter(v => v) is not empty %}
                    <div>{{ address(address)|replace({"\n": ", "}) }}</div>
                {% endif %}
            </div>
            <div class="col-sm-6 text-sm-end">
                <div class="text-muted small text-uppercase mb-1">{{ 'Supplier'|trans }}</div>
                <div class="fw-bold">{{ purchase.client ? purchase.client.name : '—' }}</div>
                {% if purchase.client %}
                    {% for identifier in tax_identifiers(purchase.client) %}
                        <div><strong>{{ identifier.label }}</strong> {{ identifier.value }}</div>
                    {% endfor %}
                    {% for addr in purchase.client.addresses %}
                        <div>{{ addr|replace({"\n": ", "}) }}</div>
                    {% endfor %}
                {% endif %}
                <div class="mt-2"><strong>{{ 'Date'|trans }}:</strong> {{ purchase.purchaseDate ? purchase.purchaseDate|date('d F Y') : '—' }}</div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th style="width: 50%;">{{ 'Item / Product'|trans }}</th>
                        <th class="text-end" style="width: 15%;">{{ 'Qty'|trans }}</th>
                        <th class="text-end" style="width: 17%;">{{ 'Unit price'|trans }}</th>
                        <th class="text-end" style="width: 18%;">{{ 'Line total'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in purchase.items %}
                        <tr>
                            <td>{{ item.description }}</td>
                            <td class="text-end">{{ item.qty|number_format(2) }}</td>
                            <td class="text-end">AED {{ item.price|number_format(2) }}</td>
                            <td class="text-end">AED {{ item.total|number_format(2) }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="4" class="text-center text-muted">{{ 'No line items.'|trans }}</td></tr>
                    {% endfor %}
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" class="text-end fw-bold">{{ 'Total'|trans }}</td>
                        <td class="text-end fw-bold">AED {{ purchase.totalAmount|number_format(2) }}</td>
                    </tr>
                    <tr>
                        <td colspan="3" class="text-end text-success">{{ 'Paid'|trans }}</td>
                        <td class="text-end text-success">AED {{ purchase.amountPaid|number_format(2) }}</td>
                    </tr>
                    <tr>
                        <td colspan="3" class="text-end fw-bold">{{ 'Balance'|trans }}</td>
                        <td class="text-end fw-bold">AED {{ purchase.balance|number_format(2) }}</td>
                    </tr>
                </tfoot>
            </table>
        </div>

        {% if purchase.description %}
            <div class="mt-3">
                <div class="text-muted small text-uppercase mb-1">{{ 'Notes'|trans }}</div>
                <div>{{ purchase.description|nl2br }}</div>
            </div>
        {% endif %}
    </twig:Ui:Card>
{% endblock content %}
