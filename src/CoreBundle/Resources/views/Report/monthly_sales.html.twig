{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% block title %}{{ ux_icon('tabler:calendar-stats', {width: 24, height: 24, class: 'me-2'}) }}{{ 'Monthly Sales Report'|trans }}{% endblock title %}

{% block heading %}
    <button type="button" class="btn btn-primary no-print" onclick="printReport();">
        {{ ux_icon('tabler:printer', {width: 18, height: 18}) }}
        {{ 'Print / Save as PDF'|trans }}
    </button>
    <script>
        // Browsers use document.title as the default "Save as PDF" filename.
        // Swap in a dated report name for the print, then restore it afterwards.
        (function () {
            var reportFileName = {{ ('nmp-sales-' ~ month|date('M-Y'))|json_encode|raw }};
            var originalTitle = document.title;

            window.printReport = function () {
                document.title = reportFileName;
                window.print();
            };

            window.addEventListener('afterprint', function () {
                document.title = originalTitle;
            });
        })();
    </script>
{% endblock %}

{% block content %}
    <style>
        .sales-banner { background: linear-gradient(135deg, #206bc4 0%, #4299e1 100%); color: #fff; border: 0; }
        .sales-banner .text-muted { color: rgba(255,255,255,.85) !important; }
        .sales-day-head { background: #f1f5f9; }
        .sales-invoice-row td { background: #f8fafc; font-weight: 600; border-top: 2px solid #e2e8f0; }
        .sales-line-desc { padding-left: 1.5rem !important; }
        .sales-status-badge { font-size: .8rem; padding: .3em .55em; letter-spacing: .02em; }
        /* The theme tints plain .badge text orange, which is unreadable on the
           green/red fills on screen. Force proper contrast, like the invoice list. */
        .sales-status-badge.bg-success, .sales-status-badge.bg-danger { color: #fff !important; }
        .sales-status-badge.bg-warning { color: #212529 !important; }

        @media print {
            @page { size: A4 portrait; margin: 8mm; }
            .no-print, .navbar, .sidebar, aside, footer, .page-header .btn, .app-header, .navbar-vertical { display: none !important; }
            body { background: #fff !important; font-size: 10px !important; }
            /* Don't rely on background colours printing (browsers skip them by
               default / office printers are often B&W). Use dark text + borders
               so everything stays readable, and outline the status badges with
               coloured text instead of coloured fills. */
            .sales-banner { background: #fff !important; color: #000 !important; border: 0 !important; border-bottom: 2px solid #000 !important; border-radius: 0 !important; }
            .sales-banner .text-muted { color: #000 !important; }
            .sales-day-head { background: #fff !important; border-bottom: 1px solid #000 !important; }
            .sales-invoice-row td { background: #fff !important; border-top: 1px solid #000 !important; }
            .badge { background: transparent !important; border: 1px solid #333; color: #000 !important; font-weight: 700 !important; }
            .badge.bg-success { color: #1a7f37 !important; border-color: #1a7f37 !important; }
            .badge.bg-warning { color: #9a6700 !important; border-color: #9a6700 !important; }
            .badge.bg-danger { color: #b02a37 !important; border-color: #b02a37 !important; }
            .card { border: 1px solid #ccc !important; box-shadow: none !important; margin-bottom: .5rem !important; }
            .card-body { padding: .4rem .6rem !important; }
            h2, .h2, .h3 { font-size: 1rem !important; margin-bottom: .3rem !important; }
            .h4, .h5, h3 { font-size: .9rem !important; margin-bottom: .3rem !important; }
            table { font-size: 9px !important; }
            .table td, .table th { padding: .1rem .3rem !important; }
            thead { display: table-header-group; }
            tr { break-inside: avoid; }
            .row.g-3 { --bs-gutter-y: .4rem !important; --bs-gutter-x: .4rem !important; }
            .col-md-3 { width: 25% !important; float: left; }
        }
    </style>

    {# ---------------- Pro banner header ---------------- #}
    <div class="card mb-3 sales-banner">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <div class="h2 mb-1">{{ company_name() }}</div>
                <div class="text-muted text-uppercase" style="letter-spacing: .08em;">{{ 'Monthly Sales Report'|trans }}</div>
            </div>
            <div class="text-end">
                <div class="h3 mb-0">{{ month|date('F Y') }}</div>
                <div class="text-muted">{{ invoiceCount }} {{ 'invoice(s)'|trans }}</div>
            </div>
        </div>
    </div>

    {# ---------------- Month picker ---------------- #}
    <div class="card mb-3 no-print">
        <div class="card-body">
            <form method="get" action="{{ path('_monthly_sales') }}" class="row g-2 align-items-end">
                <div class="col-auto">
                    <label for="report-month" class="form-label">{{ 'Show the month'|trans }}</label>
                    <input type="month" name="month" id="report-month" class="form-control" value="{{ month|date('Y-m') }}" onchange="this.form.submit()">
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-outline-primary">{{ 'Show'|trans }}</button>
                </div>
                {% if month|date('Y-m') != thisMonth %}
                    <div class="col-auto">
                        <a href="{{ path('_monthly_sales') }}" class="btn btn-link">{{ 'Back to this month'|trans }}</a>
                    </div>
                {% endif %}
            </form>
        </div>
    </div>

    {# ---------------- Summary cards ---------------- #}
    <div class="row g-3 mb-3">
        <div class="col-md-3 col-6">
            <div class="card"><div class="card-body">
                <div class="text-muted small text-uppercase">{{ 'Total billed'|trans }}</div>
                <div class="h3 mb-0">AED {{ totalBilled|number_format(2) }}</div>
            </div></div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card"><div class="card-body">
                <div class="text-muted small text-uppercase">{{ 'Total received'|trans }}</div>
                <div class="h3 mb-0 text-success">AED {{ totalReceived|number_format(2) }}</div>
            </div></div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card"><div class="card-body">
                <div class="text-muted small text-uppercase">{{ 'Outstanding'|trans }}</div>
                <div class="h3 mb-0 text-danger">AED {{ totalOutstanding|number_format(2) }}</div>
            </div></div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card"><div class="card-body">
                <div class="text-muted small text-uppercase">{{ 'Invoices'|trans }}</div>
                <div class="h3 mb-0">{{ invoiceCount }}</div>
            </div></div>
        </div>
    </div>

    {# ---------------- Day-by-day detailed sales ---------------- #}
    {% if days is empty %}
        <twig:Ui:Card>
            <p class="text-muted mb-0">{{ 'No invoices were raised in this month.'|trans }}</p>
        </twig:Ui:Card>
    {% else %}
        {% for day in days %}
            <div class="card mb-3">
                <div class="card-header sales-day-head d-flex justify-content-between align-items-center">
                    <h3 class="h5 mb-0">
                        {{ ux_icon('tabler:calendar-event', {width: 18, height: 18, class: 'me-1'}) }}
                        {{ day.date ? day.date|date('l, d M Y') : '—' }}
                    </h3>
                    <div class="fw-bold">AED {{ day.dayTotal|number_format(2) }}</div>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-vcenter mb-0">
                            <thead>
                                <tr>
                                    <th>{{ 'Item sold'|trans }}</th>
                                    <th class="text-end">{{ 'Qty'|trans }}</th>
                                    <th class="text-end">{{ 'Unit price'|trans }}</th>
                                    <th class="text-end">{{ 'Amount'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for sale in day.sales %}
                                    <tr class="sales-invoice-row">
                                        <td colspan="2">
                                            <span class="badge {{ sale.statusColor }} sales-status-badge me-1">{{ sale.statusLabel|trans }}</span>
                                            {{ sale.invoiceId ?: '—' }} &nbsp;&mdash;&nbsp; {{ sale.client }}
                                        </td>
                                        <td colspan="2" class="text-end text-nowrap">
                                            {{ 'Total'|trans }} AED {{ sale.total|number_format(2) }}
                                            &nbsp;|&nbsp; {{ 'Paid'|trans }} <span class="text-success">AED {{ sale.paid|number_format(2) }}</span>
                                            &nbsp;|&nbsp; {{ 'Balance'|trans }} <span class="{{ sale.balance == '0.00' ? 'text-success' : 'text-danger' }}">AED {{ sale.balance|number_format(2) }}</span>
                                        </td>
                                    </tr>
                                    {% if sale.lines is empty %}
                                        <tr><td colspan="4" class="sales-line-desc text-muted">{{ 'No item detail on this invoice.'|trans }}</td></tr>
                                    {% else %}
                                        {% for line in sale.lines %}
                                            <tr>
                                                <td class="sales-line-desc">{{ line.description }}</td>
                                                <td class="text-end">{{ line.qty }}</td>
                                                <td class="text-end">AED {{ line.unitPrice|number_format(2) }}</td>
                                                <td class="text-end">AED {{ line.amount|number_format(2) }}</td>
                                            </tr>
                                        {% endfor %}
                                    {% endif %}
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        {% endfor %}

        {# ---------------- Month grand total ---------------- #}
        <div class="card mb-3">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div class="h4 mb-0">{{ 'Month total'|trans }} &mdash; {{ month|date('F Y') }}</div>
                <div class="text-end">
                    <div class="h4 mb-0">AED {{ totalBilled|number_format(2) }}</div>
                    <div class="small text-muted">
                        {{ 'Received'|trans }} AED {{ totalReceived|number_format(2) }} &middot;
                        {{ 'Outstanding'|trans }} AED {{ totalOutstanding|number_format(2) }}
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
{% endblock content %}
