{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% block title %}{{ ux_icon('tabler:chart-histogram', {width: 24, height: 24, class: 'me-2'}) }}{{ 'Sales by Model'|trans }}{% endblock title %}

{% block heading %}
    {% if detail %}
        <a href="{{ path('_sales_analysis') }}" class="btn btn-outline-secondary">
            {{ ux_icon('tabler:arrow-left', {width: 18, height: 18}) }}
            {{ 'Back to all models'|trans }}
        </a>
    {% endif %}
{% endblock %}

{% block content %}
    {# Hidden icon holders reused by the client-side sorter so the icons match the site exactly #}
    <template id="ico-default">{{ ux_icon('tabler:selector', {width: 14, height: 14}) }}</template>
    <template id="ico-asc">{{ ux_icon('tabler:chevron-up', {width: 14, height: 14}) }}</template>
    <template id="ico-desc">{{ ux_icon('tabler:chevron-down', {width: 14, height: 14}) }}</template>

    {% if not detail %}
        {# ---------------- Summary: one row per model ---------------- #}
        <twig:Ui:Card>
            {% if products is empty %}
                <div class="datagrid-empty">
                    <div class="datagrid-empty-icon">{{ ux_icon('tabler:chart-histogram', {width: 40, height: 40}) }}</div>
                    <h3 class="datagrid-empty-title">{{ 'No sales yet'|trans }}</h3>
                    <p class="datagrid-empty-message">{{ 'Once you raise invoices, this page shows what each model has sold for and who is buying.'|trans }}</p>
                </div>
            {% else %}
                <p class="text-secondary">{{ 'What each model has sold for, across all your invoices. Click any column heading to sort, or a model to see the full price history and who buys it most.'|trans }}</p>
                <div class="mb-3">
                    <div class="input-icon">
                        <span class="input-icon-addon">{{ ux_icon('tabler:search', {width: 16, height: 16}) }}</span>
                        <input type="text" id="sales-search" class="form-control" placeholder="{{ 'Search model, e.g. Sense 8...'|trans }}" autocomplete="off">
                    </div>
                </div>
                <div class="datagrid-table-wrapper">
                    <table class="datagrid-table js-sortable" id="sales-table">
                        <thead>
                            <tr>
                                <th data-sort-type="text"><a href="#" class="datagrid-sort-link">{{ 'Model'|trans }}<span class="datagrid-sort-icon"></span></a></th>
                                <th class="text-end" data-sort-type="number"><a href="#" class="datagrid-sort-link">{{ 'Units sold'|trans }}<span class="datagrid-sort-icon"></span></a></th>
                                <th class="text-end" data-sort-type="number"><a href="#" class="datagrid-sort-link">{{ 'Avg price'|trans }}<span class="datagrid-sort-icon"></span></a></th>
                                <th class="text-end" data-sort-type="number"><a href="#" class="datagrid-sort-link">{{ 'Lowest'|trans }}<span class="datagrid-sort-icon"></span></a></th>
                                <th class="text-end" data-sort-type="number"><a href="#" class="datagrid-sort-link">{{ 'Highest'|trans }}<span class="datagrid-sort-icon"></span></a></th>
                                <th class="text-end" data-sort-type="number" data-default-dir="desc"><a href="#" class="datagrid-sort-link">{{ 'Total sold'|trans }}<span class="datagrid-sort-icon"></span></a></th>
                                <th class="text-end" data-sort-type="number"><a href="#" class="datagrid-sort-link">{{ 'Invoices'|trans }}<span class="datagrid-sort-icon"></span></a></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="sales-body">
                            {% for product in products %}
                                <tr data-row data-search="{{ product.model|lower }}">
                                    <td class="fw-semibold">{{ product.model }}</td>
                                    <td class="text-end" data-sort="{{ product.units }}">{{ product.units }}</td>
                                    <td class="text-end fw-semibold" data-sort="{{ product.avgPrice }}">AED {{ product.avgPrice|number_format(2) }}</td>
                                    <td class="text-end text-secondary" data-sort="{{ product.minPrice }}">AED {{ product.minPrice|number_format(2) }}</td>
                                    <td class="text-end text-secondary" data-sort="{{ product.maxPrice }}">AED {{ product.maxPrice|number_format(2) }}</td>
                                    <td class="text-end text-success" data-sort="{{ product.revenue }}">AED {{ product.revenue|number_format(2) }}</td>
                                    <td class="text-end" data-sort="{{ product.invoices }}">{{ product.invoices }}</td>
                                    <td class="text-end">
                                        <a href="{{ path('_sales_analysis', {model: product.model}) }}" class="btn btn-sm btn-outline-primary" title="{{ 'Details'|trans }}">
                                            {{ ux_icon('tabler:chart-line', {width: 15, height: 15}) }}
                                            {{ 'Details'|trans }}
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div id="sales-no-results" class="datagrid-empty" style="display: none;">
                    <p class="datagrid-empty-message">{{ 'No matching model found.'|trans }}</p>
                </div>
            {% endif %}
        </twig:Ui:Card>
    {% else %}
        {# ---------------- Detail: one selected model ---------------- #}
        <h2 class="h4 mb-3">{{ model }}</h2>

        <div class="row g-3">
            <div class="col-lg-5">
                <twig:Ui:Card>
                    <h3 class="h5 mb-3">{{ ux_icon('tabler:users', {width: 18, height: 18, class: 'me-1'}) }}{{ 'Top buyers'|trans }}</h3>
                    {% if buyers is empty %}
                        <p class="text-secondary mb-0">{{ 'No sales recorded for this model yet.'|trans }}</p>
                    {% else %}
                        <div class="datagrid-table-wrapper">
                            <table class="datagrid-table js-sortable">
                                <thead>
                                    <tr>
                                        <th data-sort-type="text"><a href="#" class="datagrid-sort-link">{{ 'Customer'|trans }}<span class="datagrid-sort-icon"></span></a></th>
                                        <th class="text-end" data-sort-type="number" data-default-dir="desc"><a href="#" class="datagrid-sort-link">{{ 'Units'|trans }}<span class="datagrid-sort-icon"></span></a></th>
                                        <th class="text-end" data-sort-type="number"><a href="#" class="datagrid-sort-link">{{ 'Price range'|trans }}<span class="datagrid-sort-icon"></span></a></th>
                                        <th class="text-end" data-sort-type="number"><a href="#" class="datagrid-sort-link">{{ 'Total'|trans }}<span class="datagrid-sort-icon"></span></a></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for buyer in buyers %}
                                        <tr data-row>
                                            <td class="fw-semibold">{{ buyer.client }}</td>
                                            <td class="text-end" data-sort="{{ buyer.units }}">{{ buyer.units }}</td>
                                            <td class="text-end text-secondary" data-sort="{{ buyer.minPrice }}">
                                                {% if buyer.minPrice == buyer.maxPrice %}
                                                    AED {{ buyer.minPrice|number_format(2) }}
                                                {% else %}
                                                    AED {{ buyer.minPrice|number_format(2) }} – {{ buyer.maxPrice|number_format(2) }}
                                                {% endif %}
                                            </td>
                                            <td class="text-end text-success" data-sort="{{ buyer.revenue }}">AED {{ buyer.revenue|number_format(2) }}</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </twig:Ui:Card>
            </div>

            <div class="col-lg-7">
                <twig:Ui:Card>
                    <h3 class="h5 mb-3">{{ ux_icon('tabler:list-details', {width: 18, height: 18, class: 'me-1'}) }}{{ 'Every sale'|trans }}</h3>
                    {% if history is empty %}
                        <p class="text-secondary mb-0">{{ 'No sales recorded for this model yet.'|trans }}</p>
                    {% else %}
                        <div class="datagrid-table-wrapper">
                            <table class="datagrid-table js-sortable">
                                <thead>
                                    <tr>
                                        <th data-sort-type="date" data-default-dir="desc"><a href="#" class="datagrid-sort-link">{{ 'Date'|trans }}<span class="datagrid-sort-icon"></span></a></th>
                                        <th data-sort-type="text"><a href="#" class="datagrid-sort-link">{{ 'Invoice'|trans }}<span class="datagrid-sort-icon"></span></a></th>
                                        <th data-sort-type="text"><a href="#" class="datagrid-sort-link">{{ 'Customer'|trans }}<span class="datagrid-sort-icon"></span></a></th>
                                        <th class="text-end" data-sort-type="number"><a href="#" class="datagrid-sort-link">{{ 'Qty'|trans }}<span class="datagrid-sort-icon"></span></a></th>
                                        <th class="text-end" data-sort-type="number"><a href="#" class="datagrid-sort-link">{{ 'Unit price'|trans }}<span class="datagrid-sort-icon"></span></a></th>
                                        <th class="text-end" data-sort-type="number"><a href="#" class="datagrid-sort-link">{{ 'Line total'|trans }}<span class="datagrid-sort-icon"></span></a></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for sale in history %}
                                        <tr data-row>
                                            <td class="text-nowrap" data-sort="{{ sale.date ? sale.date|date('Y-m-d') : '' }}">{{ sale.date ? sale.date|date('d M Y') : '—' }}</td>
                                            <td>{{ sale.invoiceId ?: '—' }}</td>
                                            <td>{{ sale.client }}</td>
                                            <td class="text-end" data-sort="{{ sale.qty }}">{{ sale.qty }}</td>
                                            <td class="text-end fw-semibold" data-sort="{{ sale.price }}">AED {{ sale.price|number_format(2) }}</td>
                                            <td class="text-end text-success" data-sort="{{ sale.total }}">AED {{ sale.total|number_format(2) }}</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </twig:Ui:Card>
            </div>
        </div>
    {% endif %}

    <script>
        (function () {
            function ico(name) {
                var el = document.getElementById('ico-' + name);
                return el ? el.innerHTML : '';
            }

            function cellValue(cell, type) {
                if (!cell) { return type === 'number' ? -Infinity : ''; }
                var v = cell.getAttribute('data-sort');
                if (v === null) { v = cell.textContent.trim(); }
                if (type === 'number') {
                    var n = parseFloat(v);
                    return isNaN(n) ? -Infinity : n;
                }
                return v.toLowerCase();
            }

            function sortBy(table, th) {
                var tbody = table.tBodies[0];
                var type = th.getAttribute('data-sort-type') || 'text';
                var colIndex = th.cellIndex;
                var asc = th.getAttribute('data-sort-dir') !== 'asc';

                Array.prototype.forEach.call(table.querySelectorAll('th[data-sort-type]'), function (h) {
                    h.removeAttribute('data-sort-dir');
                    var icn = h.querySelector('.datagrid-sort-icon');
                    var lnk = h.querySelector('.datagrid-sort-link');
                    if (icn) { icn.innerHTML = ico('default'); }
                    if (lnk) { lnk.classList.remove('sorted'); }
                });

                th.setAttribute('data-sort-dir', asc ? 'asc' : 'desc');
                var icon = th.querySelector('.datagrid-sort-icon');
                var link = th.querySelector('.datagrid-sort-link');
                if (icon) { icon.innerHTML = ico(asc ? 'asc' : 'desc'); }
                if (link) { link.classList.add('sorted'); }

                var rows = Array.prototype.slice.call(tbody.querySelectorAll('tr[data-row]'));
                rows.sort(function (a, b) {
                    var av = cellValue(a.cells[colIndex], type);
                    var bv = cellValue(b.cells[colIndex], type);
                    if (av < bv) { return asc ? -1 : 1; }
                    if (av > bv) { return asc ? 1 : -1; }
                    return 0;
                });
                rows.forEach(function (r) { tbody.appendChild(r); });
            }

            Array.prototype.forEach.call(document.querySelectorAll('table.js-sortable'), function (table) {
                Array.prototype.forEach.call(table.querySelectorAll('th[data-sort-type]'), function (th) {
                    var icn = th.querySelector('.datagrid-sort-icon');
                    var def = th.getAttribute('data-default-dir');
                    if (icn) { icn.innerHTML = ico(def ? def : 'default'); }
                    if (def) {
                        th.setAttribute('data-sort-dir', def);
                        var lnk = th.querySelector('.datagrid-sort-link');
                        if (lnk) { lnk.classList.add('sorted'); }
                    }
                    var link = th.querySelector('.datagrid-sort-link');
                    if (link) {
                        link.addEventListener('click', function (e) {
                            e.preventDefault();
                            sortBy(table, th);
                        });
                    }
                });
            });

            var input = document.getElementById('sales-search');
            if (input) {
                var body = document.getElementById('sales-body');
                var noResults = document.getElementById('sales-no-results');
                input.addEventListener('input', function () {
                    var q = input.value.trim().toLowerCase();
                    var shown = 0;
                    Array.prototype.forEach.call(body.querySelectorAll('tr[data-row]'), function (row) {
                        var match = q === '' || row.getAttribute('data-search').indexOf(q) !== -1;
                        row.style.display = match ? '' : 'none';
                        if (match) { shown++; }
                    });
                    if (noResults) { noResults.style.display = shown === 0 ? '' : 'none'; }
                });
            }
        })();
    </script>
{% endblock content %}
