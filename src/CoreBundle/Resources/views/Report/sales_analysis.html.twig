{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% block title %}{{ ux_icon('tabler:chart-histogram', {width: 24, height: 24, class: 'me-2'}) }}{{ 'Sales by Model'|trans }}{% endblock title %}

{% block heading %}
    {% if detail %}
        <a href="{{ path('_sales_analysis') }}" class="btn btn-outline-secondary">
            {{ ux_icon('tabler:arrow-left', {width: 18, height: 18}) }}
            {{ 'Back to all models'|trans }}
        </a>
    {% endif %}
{% endblock %}

{% block content %}
    {% if not detail %}
        {# ---------------- Summary: one row per model ---------------- #}
        <twig:Ui:Card>
            {% if products is empty %}
                <div class="text-center py-5 text-muted">
                    {{ ux_icon('tabler:chart-histogram', {width: 40, height: 40}) }}
                    <p class="mt-3 mb-0">{{ 'No sales yet. Once you raise invoices, this page shows what each model has sold for and who is buying.'|trans }}</p>
                </div>
            {% else %}
                <p class="text-muted">{{ 'What each model has sold for, across all your invoices. Click a model to see the full price history and who buys it most.'|trans }}</p>
                <div class="mb-3">
                    <input type="text" id="sales-search" class="form-control" placeholder="{{ 'Search model, e.g. Sense 8...'|trans }}" autocomplete="off">
                </div>
                <div class="table-responsive">
                    <table class="table table-vcenter" id="sales-table">
                        <thead>
                            <tr>
                                <th>{{ 'Model'|trans }}</th>
                                <th class="text-end">{{ 'Units sold'|trans }}</th>
                                <th class="text-end">{{ 'Avg price'|trans }}</th>
                                <th class="text-end">{{ 'Lowest'|trans }}</th>
                                <th class="text-end">{{ 'Highest'|trans }}</th>
                                <th class="text-end">{{ 'Total sold'|trans }}</th>
                                <th class="text-end">{{ 'Invoices'|trans }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="sales-body">
                            {% for product in products %}
                                <tr data-search="{{ product.model|lower }}">
                                    <td class="fw-semibold">{{ product.model }}</td>
                                    <td class="text-end">{{ product.units }}</td>
                                    <td class="text-end fw-semibold">AED {{ product.avgPrice|number_format(2) }}</td>
                                    <td class="text-end text-muted">AED {{ product.minPrice|number_format(2) }}</td>
                                    <td class="text-end text-muted">AED {{ product.maxPrice|number_format(2) }}</td>
                                    <td class="text-end text-success">AED {{ product.revenue|number_format(2) }}</td>
                                    <td class="text-end">{{ product.invoices }}</td>
                                    <td class="text-end">
                                        <a href="{{ path('_sales_analysis', {model: product.model}) }}" class="btn btn-sm btn-outline-primary" title="{{ 'Details'|trans }}">
                                            {{ ux_icon('tabler:chart-line', {width: 15, height: 15}) }}
                                            {{ 'Details'|trans }}
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div id="sales-no-results" class="text-center text-muted py-4" style="display: none;">{{ 'No matching model found.'|trans }}</div>
                <script>
                    (function () {
                        var input = document.getElementById('sales-search');
                        var rows = document.querySelectorAll('#sales-body tr');
                        var noResults = document.getElementById('sales-no-results');
                        if (!input) { return; }
                        input.addEventListener('input', function () {
                            var q = input.value.trim().toLowerCase();
                            var shown = 0;
                            rows.forEach(function (row) {
                                var match = q === '' || row.getAttribute('data-search').indexOf(q) !== -1;
                                row.style.display = match ? '' : 'none';
                                if (match) { shown++; }
                            });
                            noResults.style.display = shown === 0 ? 'block' : 'none';
                        });
                    })();
                </script>
            {% endif %}
        </twig:Ui:Card>
    {% else %}
        {# ---------------- Detail: one selected model ---------------- #}
        <h2 class="h4 mb-3">{{ model }}</h2>

        <div class="row g-3">
            <div class="col-lg-5">
                <twig:Ui:Card>
                    <h3 class="h5 mb-3">{{ ux_icon('tabler:users', {width: 18, height: 18, class: 'me-1'}) }}{{ 'Top buyers'|trans }}</h3>
                    {% if buyers is empty %}
                        <p class="text-muted mb-0">{{ 'No sales recorded for this model yet.'|trans }}</p>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-vcenter">
                                <thead>
                                    <tr>
                                        <th>{{ 'Customer'|trans }}</th>
                                        <th class="text-end">{{ 'Units'|trans }}</th>
                                        <th class="text-end">{{ 'Price range'|trans }}</th>
                                        <th class="text-end">{{ 'Total'|trans }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for buyer in buyers %}
                                        <tr>
                                            <td class="fw-semibold">{{ buyer.client }}</td>
                                            <td class="text-end">{{ buyer.units }}</td>
                                            <td class="text-end text-muted">
                                                {% if buyer.minPrice == buyer.maxPrice %}
                                                    AED {{ buyer.minPrice|number_format(2) }}
                                                {% else %}
                                                    AED {{ buyer.minPrice|number_format(2) }} – {{ buyer.maxPrice|number_format(2) }}
                                                {% endif %}
                                            </td>
                                            <td class="text-end text-success">AED {{ buyer.revenue|number_format(2) }}</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </twig:Ui:Card>
            </div>

            <div class="col-lg-7">
                <twig:Ui:Card>
                    <h3 class="h5 mb-3">{{ ux_icon('tabler:list-details', {width: 18, height: 18, class: 'me-1'}) }}{{ 'Every sale'|trans }}</h3>
                    {% if history is empty %}
                        <p class="text-muted mb-0">{{ 'No sales recorded for this model yet.'|trans }}</p>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-vcenter">
                                <thead>
                                    <tr>
                                        <th>{{ 'Date'|trans }}</th>
                                        <th>{{ 'Invoice'|trans }}</th>
                                        <th>{{ 'Customer'|trans }}</th>
                                        <th class="text-end">{{ 'Qty'|trans }}</th>
                                        <th class="text-end">{{ 'Unit price'|trans }}</th>
                                        <th class="text-end">{{ 'Line total'|trans }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for sale in history %}
                                        <tr>
                                            <td class="text-nowrap">{{ sale.date ? sale.date|date('d M Y') : '—' }}</td>
                                            <td>{{ sale.invoiceId ?: '—' }}</td>
                                            <td>{{ sale.client }}</td>
                                            <td class="text-end">{{ sale.qty }}</td>
                                            <td class="text-end fw-semibold">AED {{ sale.price|number_format(2) }}</td>
                                            <td class="text-end text-success">AED {{ sale.total|number_format(2) }}</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </twig:Ui:Card>
            </div>
        </div>
    {% endif %}
{% endblock content %}
