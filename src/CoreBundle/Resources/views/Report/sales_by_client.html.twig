{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% block title %}{{ ux_icon('tabler:users-group', {width: 24, height: 24, class: 'me-2'}) }}{{ 'Sales by Client'|trans }}{% endblock title %}

{% block heading %}
    {% if detail %}
        <a href="{{ path('_sales_by_client') }}" class="btn btn-outline-secondary">
            {{ ux_icon('tabler:arrow-left', {width: 18, height: 18}) }}
            {{ 'Back to all clients'|trans }}
        </a>
    {% endif %}
{% endblock %}

{% block content %}
    {% if not detail %}
        {# ---------------- Summary: one row per client ---------------- #}
        <twig:Ui:Card>
            {% if clients is empty %}
                <div class="text-center py-5 text-muted">
                    {{ ux_icon('tabler:users-group', {width: 40, height: 40}) }}
                    <p class="mt-3 mb-0">{{ 'No sales yet. Once you raise invoices, this page shows how much each client has bought and who your best buyers are.'|trans }}</p>
                </div>
            {% else %}
                <p class="text-muted">{{ 'How much each client has bought, across all your invoices. Click a client to see the models they buy and their full purchase history.'|trans }}</p>
                <div class="mb-3">
                    <input type="text" id="client-search" class="form-control" placeholder="{{ 'Search client name...'|trans }}" autocomplete="off">
                </div>
                <div class="table-responsive">
                    <table class="table table-vcenter" id="client-table">
                        <thead>
                            <tr>
                                <th>{{ 'Client'|trans }}</th>
                                <th class="text-end">{{ 'Units bought'|trans }}</th>
                                <th class="text-end">{{ 'Invoices'|trans }}</th>
                                <th class="text-end">{{ 'Avg invoice'|trans }}</th>
                                <th class="text-end">{{ 'Total spent'|trans }}</th>
                                <th>{{ 'Last purchase'|trans }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="client-body">
                            {% for c in clients %}
                                <tr data-search="{{ c.client|lower }}">
                                    <td class="fw-semibold">{{ c.client }}</td>
                                    <td class="text-end">{{ c.units }}</td>
                                    <td class="text-end">{{ c.invoices }}</td>
                                    <td class="text-end text-muted">AED {{ c.avgInvoice|number_format(2) }}</td>
                                    <td class="text-end text-success fw-semibold">AED {{ c.revenue|number_format(2) }}</td>
                                    <td class="text-nowrap text-muted">{{ c.lastPurchase ? c.lastPurchase|date('d M Y') : '—' }}</td>
                                    <td class="text-end">
                                        <a href="{{ path('_sales_by_client', {client: c.clientId}) }}" class="btn btn-sm btn-outline-primary" title="{{ 'Details'|trans }}">
                                            {{ ux_icon('tabler:chart-line', {width: 15, height: 15}) }}
                                            {{ 'Details'|trans }}
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div id="client-no-results" class="text-center text-muted py-4" style="display: none;">{{ 'No matching client found.'|trans }}</div>
                <script>
                    (function () {
                        var input = document.getElementById('client-search');
                        var rows = document.querySelectorAll('#client-body tr');
                        var noResults = document.getElementById('client-no-results');
                        if (!input) { return; }
                        input.addEventListener('input', function () {
                            var q = input.value.trim().toLowerCase();
                            var shown = 0;
                            rows.forEach(function (row) {
                                var match = q === '' || row.getAttribute('data-search').indexOf(q) !== -1;
                                row.style.display = match ? '' : 'none';
                                if (match) { shown++; }
                            });
                            noResults.style.display = shown === 0 ? 'block' : 'none';
                        });
                    })();
                </script>
            {% endif %}
        </twig:Ui:Card>
    {% else %}
        {# ---------------- Detail: one selected client ---------------- #}
        <h2 class="h4 mb-3">{{ ux_icon('tabler:user', {width: 20, height: 20, class: 'me-1'}) }}{{ client }}</h2>

        <div class="row g-3">
            <div class="col-lg-5">
                <twig:Ui:Card>
                    <h3 class="h5 mb-3">{{ ux_icon('tabler:device-mobile', {width: 18, height: 18, class: 'me-1'}) }}{{ 'Models bought'|trans }}</h3>
                    {% if models is empty %}
                        <p class="text-muted mb-0">{{ 'No purchases recorded for this client yet.'|trans }}</p>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-vcenter">
                                <thead>
                                    <tr>
                                        <th>{{ 'Model'|trans }}</th>
                                        <th class="text-end">{{ 'Units'|trans }}</th>
                                        <th class="text-end">{{ 'Avg price'|trans }}</th>
                                        <th class="text-end">{{ 'Total'|trans }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for m in models %}
                                        <tr>
                                            <td class="fw-semibold">{{ m.model }}</td>
                                            <td class="text-end">{{ m.units }}</td>
                                            <td class="text-end text-muted">AED {{ m.avgPrice|number_format(2) }}</td>
                                            <td class="text-end text-success">AED {{ m.revenue|number_format(2) }}</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </twig:Ui:Card>
            </div>

            <div class="col-lg-7">
                <twig:Ui:Card>
                    <h3 class="h5 mb-3">{{ ux_icon('tabler:list-details', {width: 18, height: 18, class: 'me-1'}) }}{{ 'Every purchase'|trans }}</h3>
                    {% if history is empty %}
                        <p class="text-muted mb-0">{{ 'No purchases recorded for this client yet.'|trans }}</p>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-vcenter">
                                <thead>
                                    <tr>
                                        <th>{{ 'Date'|trans }}</th>
                                        <th>{{ 'Invoice'|trans }}</th>
                                        <th>{{ 'Model'|trans }}</th>
                                        <th class="text-end">{{ 'Qty'|trans }}</th>
                                        <th class="text-end">{{ 'Unit price'|trans }}</th>
                                        <th class="text-end">{{ 'Line total'|trans }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for sale in history %}
                                        <tr>
                                            <td class="text-nowrap">{{ sale.date ? sale.date|date('d M Y') : '—' }}</td>
                                            <td>{{ sale.invoiceId ?: '—' }}</td>
                                            <td>{{ sale.model }}</td>
                                            <td class="text-end">{{ sale.qty }}</td>
                                            <td class="text-end fw-semibold">AED {{ sale.price|number_format(2) }}</td>
                                            <td class="text-end text-success">AED {{ sale.total|number_format(2) }}</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </twig:Ui:Card>
            </div>
        </div>
    {% endif %}
{% endblock content %}
