{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% block title %}{{ ux_icon('tabler:upload', {width: 24, height: 24, class: 'me-2'}) }}{{ 'Import stock'|trans }}{% endblock title %}

{% block heading %}
    <a href="{{ path('_stock_list') }}" class="btn btn-outline-secondary">
        {{ ux_icon('tabler:arrow-left', {width: 18, height: 18}) }}
        {{ 'Back to stock'|trans }}
    </a>
{% endblock %}

{% block content %}
    <twig:Ui:Card>
        <twig:block name="header">
            <h3 class="card-title mb-0">{{ 'Upload Tally stock summary'|trans }}</h3>
        </twig:block>

        <p class="text-muted">
            {{ 'Upload the Excel stock summary exported from Tally. Each upload fully replaces the current stock list. The file is read exactly as Tally lays it out - every model with its grade breakdown, quantities, rates and values.'|trans }}
        </p>

        <form method="post" action="{{ path('_stock_import') }}" enctype="multipart/form-data" class="d-flex align-items-end gap-3 flex-wrap">
            <div>
                <label for="stock-file" class="form-label">{{ 'Stock file (.xlsx / .xls)'|trans }}</label>
                <input type="file" name="stock_file" id="stock-file" class="form-control" accept=".xlsx,.xls" required>
            </div>
            <input type="hidden" name="_token" value="{{ csrf_token('stock.import') }}">
            <button type="submit" class="btn btn-primary">
                {{ ux_icon('tabler:upload', {width: 18, height: 18}) }}
                {{ 'Import'|trans }}
            </button>
        </form>
    </twig:Ui:Card>

    <div class="mt-3">
        <a href="{{ path('_stock_list') }}" class="btn btn-link">{{ ux_icon('tabler:arrow-left', {width: 16, height: 16}) }} {{ 'Back to stock'|trans }}</a>
    </div>
{% endblock content %}
