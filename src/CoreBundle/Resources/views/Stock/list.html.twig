{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% block title %}{{ ux_icon('tabler:box', {width: 24, height: 24, class: 'me-2'}) }}{{ 'Stock'|trans }}{% endblock title %}

{% block heading %}
    {% if is_granted('ROLE_MANAGER') %}
    <a href="{{ path('_stock_import') }}" class="btn btn-primary">
        {{ ux_icon('tabler:upload', {width: 18, height: 18}) }}
        {{ 'Import stock'|trans }}
    </a>
    {% endif %}
{% endblock %}

{% block content %}
    <div class="text-muted mb-3">
        {{ 'Total'|trans }}:
        <strong>{{ totalQuantity|number_format }}</strong> {{ 'units'|trans }}
        &middot;
        <strong>AED {{ totalValue|number_format(2) }}</strong>
        {% if lastImported %}
            &middot;
            {{ ux_icon('tabler:clock', {width: 16, height: 16}) }}
            {{ 'Stock last updated'|trans }}: <strong>{{ lastImported|date('d M Y, g:i A') }}</strong>
        {% endif %}
    </div>

    {% if shareUrl %}
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <span class="fw-semibold text-nowrap">
                        {{ ux_icon('tabler:share', {width: 18, height: 18}) }} {{ 'Public share link'|trans }}
                    </span>
                    <input type="text" id="stock-share-url" class="form-control" style="max-width: 520px;" value="{{ shareUrl }}" readonly onclick="this.select()">
                    <button type="button" id="stock-share-copy" class="btn btn-outline-primary">{{ 'Copy'|trans }}</button>
                    <a href="{{ shareUrl }}" target="_blank" rel="noopener" class="btn btn-link">{{ 'Open'|trans }}</a>
                </div>
                <div class="text-muted small mt-2">
                    {{ 'Share this link with customers - it shows model, grade and quantity only, with no prices, and needs no login.'|trans }}
                </div>
            </div>
        </div>
        <script>
            (function () {
                var btn = document.getElementById('stock-share-copy');
                var field = document.getElementById('stock-share-url');
                if (!btn || !field) { return; }
                btn.addEventListener('click', function () {
                    field.select();
                    var done = function () {
                        var original = btn.innerHTML;
                        btn.innerHTML = {{ 'Copied!'|trans|json_encode|raw }};
                        setTimeout(function () { btn.innerHTML = original; }, 1500);
                    };
                    if (navigator.clipboard && navigator.clipboard.writeText) {
                        navigator.clipboard.writeText(field.value).then(done, function () { document.execCommand('copy'); done(); });
                    } else {
                        document.execCommand('copy');
                        done();
                    }
                });
            })();
        </script>
    {% endif %}

    <twig:Ui:Card>
        {% if models is empty %}
            <div class="text-center py-5 text-muted">
                {{ ux_icon('tabler:box-off', {width: 40, height: 40}) }}
                <p class="mt-3 mb-1">{{ 'No stock has been imported yet.'|trans }}</p>
                {% if is_granted('ROLE_MANAGER') %}
                <a href="{{ path('_stock_import') }}" class="btn btn-sm btn-primary mt-2">{{ 'Import your Tally stock file'|trans }}</a>
                {% endif %}
            </div>
        {% else %}
            <div class="mb-3">
                <input type="text" id="stock-search" class="form-control" placeholder="{{ 'Search model or grade...'|trans }}" autocomplete="off">
            </div>
            <table class="table table-vcenter" id="stock-table">
                <thead>
                    <tr>
                        <th>{{ 'Model'|trans }}</th>
                        <th class="text-end">{{ 'Quantity'|trans }}</th>
                        <th class="text-end">{{ 'Rate'|trans }}</th>
                        <th class="text-end">{{ 'Value'|trans }}</th>
                    </tr>
                </thead>
                <tbody id="stock-body">
                    {% for model in models %}
                        <tr class="fw-bold stock-model-row" data-search="{{ (model.name ~ ' ' ~ model.grades|map(g => g.grade)|join(' '))|lower }}">
                            <td>{{ model.name }}</td>
                            <td class="text-end">{{ model.quantity|number_format }}</td>
                            <td class="text-end">AED {{ model.rate|number_format(2) }}</td>
                            <td class="text-end">AED {{ model.value|number_format(2) }}</td>
                        </tr>
                        {% for grade in model.grades %}
                            <tr class="text-muted stock-grade-row">
                                <td class="ps-4">
                                    {{ ux_icon('tabler:corner-down-right', {width: 14, height: 14, class: 'me-1'}) }}
                                    {{ grade.grade }}
                                </td>
                                <td class="text-end">{{ grade.quantity|number_format }}</td>
                                <td class="text-end">AED {{ grade.rate|number_format(2) }}</td>
                                <td class="text-end">AED {{ grade.value|number_format(2) }}</td>
                            </tr>
                        {% endfor %}
                    {% endfor %}
                </tbody>
            </table>
            <div id="stock-no-results" class="text-center text-muted py-4" style="display: none;">{{ 'No matching stock found.'|trans }}</div>
            <script>
                (function () {
                    var input = document.getElementById('stock-search');
                    var rows = document.querySelectorAll('#stock-body tr');
                    var noResults = document.getElementById('stock-no-results');
                    if (!input) { return; }
                    input.addEventListener('input', function () {
                        var q = input.value.trim().toLowerCase();
                        var currentMatch = true;
                        var shown = 0;
                        rows.forEach(function (row) {
                            if (row.classList.contains('stock-model-row')) {
                                currentMatch = q === '' || row.getAttribute('data-search').indexOf(q) !== -1;
                                row.style.display = currentMatch ? '' : 'none';
                                if (currentMatch) { shown++; }
                            } else {
                                row.style.display = currentMatch ? '' : 'none';
                            }
                        });
                        noResults.style.display = shown === 0 ? 'block' : 'none';
                    });
                })();
            </script>
        {% endif %}
    </twig:Ui:Card>
{% endblock content %}
