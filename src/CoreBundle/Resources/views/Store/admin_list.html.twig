{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% block title %}{{ ux_icon('tabler:building-store', {width: 24, height: 24, class: 'me-2'}) }}{{ 'Online store'|trans }}{% endblock title %}

{% block heading %}
    {% if is_granted('ROLE_MANAGER') %}
    <a href="{{ path('_store_import') }}" class="btn btn-primary">
        {{ ux_icon('tabler:upload', {width: 18, height: 18}) }}
        {{ 'Upload products'|trans }}
    </a>
    {% endif %}
{% endblock %}

{% block content %}
    <style>
        .store-thumb { width: 46px; height: 58px; object-fit: cover; border-radius: 8px; border: 1px solid #e2e8f0; background: #f1f5f9; }
        .store-thumb-empty { display: grid; place-items: center; color: #94a3b8; }
        .store-photo-form input[type=file] { max-width: 190px; }
    </style>

    {% if storeUrl %}
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <span class="fw-semibold text-nowrap">
                        {{ ux_icon('tabler:external-link', {width: 18, height: 18}) }} {{ 'Store link'|trans }}
                    </span>
                    <input type="text" id="store-url" class="form-control" style="max-width: 520px;" value="{{ storeUrl }}" readonly onclick="this.select()">
                    <button type="button" id="store-url-copy" class="btn btn-outline-primary">{{ 'Copy'|trans }}</button>
                    <a href="{{ storeUrl }}" target="_blank" rel="noopener" class="btn btn-link">{{ 'Open store'|trans }}</a>
                </div>
                <div class="text-muted small mt-2">
                    {{ 'This is your public storefront. Once your domain is pointed here it becomes your shop front for customers.'|trans }}
                </div>
            </div>
        </div>
        <script>
            (function () {
                var btn = document.getElementById('store-url-copy');
                var field = document.getElementById('store-url');
                if (!btn || !field) { return; }
                btn.addEventListener('click', function () {
                    field.select();
                    var done = function () {
                        var original = btn.innerHTML;
                        btn.innerHTML = {{ 'Copied!'|trans|json_encode|raw }};
                        setTimeout(function () { btn.innerHTML = original; }, 1500);
                    };
                    if (navigator.clipboard && navigator.clipboard.writeText) {
                        navigator.clipboard.writeText(field.value).then(done, function () { document.execCommand('copy'); done(); });
                    } else {
                        document.execCommand('copy');
                        done();
                    }
                });
            })();
        </script>
    {% endif %}

    <twig:Ui:Card>
        {% if products is empty %}
            <div class="text-center py-5 text-muted">
                {{ ux_icon('tabler:building-store', {width: 40, height: 40}) }}
                <p class="mt-3 mb-1">{{ 'No products in the store yet.'|trans }}</p>
                {% if is_granted('ROLE_MANAGER') %}
                <a href="{{ path('_store_import') }}" class="btn btn-sm btn-primary mt-2">{{ 'Upload your product sheet'|trans }}</a>
                {% endif %}
            </div>
        {% else %}
            <div class="text-muted mb-3">
                <strong>{{ products|length }}</strong> {{ 'product(s)'|trans }}
            </div>
            <div class="table-responsive">
            <table class="table table-vcenter">
                <thead>
                    <tr>
                        <th style="width: 60px;">{{ 'Photo'|trans }}</th>
                        <th>{{ 'Product'|trans }}</th>
                        <th>{{ 'SKU'|trans }}</th>
                        <th class="text-end">{{ 'Price'|trans }}</th>
                        <th class="text-center">{{ 'Status'|trans }}</th>
                        <th style="width: 300px;">{{ 'Actions'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for product in products %}
                        <tr>
                            <td>
                                {% if product.imagePath %}
                                    <img src="{{ asset(product.imagePath) }}" alt="{{ product }}" class="store-thumb">
                                {% else %}
                                    <div class="store-thumb store-thumb-empty">{{ ux_icon('tabler:photo', {width: 20, height: 20}) }}</div>
                                {% endif %}
                            </td>
                            <td>
                                <div class="fw-bold">{{ product }}</div>
                                <div class="text-muted small">
                                    {{ product.storage ? product.storage ~ ' · ' : '' }}{{ product.condition ?: '' }}{{ product.color ? ' · ' ~ product.color : '' }}
                                </div>
                            </td>
                            <td class="text-muted">{{ product.sku }}</td>
                            <td class="text-end text-nowrap">
                                {% if product.onSale %}
                                    <span class="fw-bold">AED {{ product.salePrice|number_format(2) }}</span><br>
                                    <span class="text-muted small text-decoration-line-through">AED {{ product.regularPrice|number_format(2) }}</span>
                                {% else %}
                                    <span class="fw-bold">AED {{ product.regularPrice|number_format(2) }}</span>
                                {% endif %}
                            </td>
                            <td class="text-center text-nowrap">
                                {% if product.featured %}<span class="badge bg-yellow text-yellow-fg me-1">{{ 'Featured'|trans }}</span>{% endif %}
                                {% if product.inStock %}
                                    <span class="badge bg-green text-green-fg">{{ 'In stock'|trans }}</span>
                                {% else %}
                                    <span class="badge bg-secondary text-secondary-fg">{{ 'Sold out'|trans }}</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2 flex-wrap">
                                    <form method="post" action="{{ path('_store_image', {id: product.id}) }}" enctype="multipart/form-data" class="store-photo-form d-flex align-items-center gap-1">
                                        <input type="file" name="image" class="form-control form-control-sm" accept=".jpg,.jpeg,.png,.webp" required>
                                        <input type="hidden" name="_token" value="{{ csrf_token('store.product') }}">
                                        <button type="submit" class="btn btn-sm btn-outline-primary" title="{{ 'Upload photo'|trans }}">{{ ux_icon('tabler:photo-up', {width: 16, height: 16}) }}</button>
                                    </form>
                                    <form method="post" action="{{ path('_store_delete', {id: product.id}) }}" onsubmit="return confirm({{ 'Remove this product from the store?'|trans|json_encode|raw }});">
                                        <input type="hidden" name="_token" value="{{ csrf_token('store.product') }}">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="{{ 'Remove'|trans }}">{{ ux_icon('tabler:trash', {width: 16, height: 16}) }}</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            </div>
        {% endif %}
    </twig:Ui:Card>

    <script>
        // Shrink product photos in the browser before they are sent to the
        // server. Phone pictures are often 4-8 MB, which is bigger than the
        // host's upload limit, so the upload used to fail "most of the time".
        // Here we scale the image down to a sensible size and re-encode it as a
        // light JPEG, so the file that leaves the browser is small enough to
        // always go through - and the store also loads faster.
        (function () {
            var MAX_SIDE = 1400;   // longest edge, in pixels
            var QUALITY = 0.82;    // JPEG quality

            if (typeof DataTransfer === 'undefined' || !document.createElement('canvas').toBlob) {
                return; // very old browser - fall back to a normal upload
            }

            document.querySelectorAll('.store-photo-form').forEach(function (form) {
                form.addEventListener('submit', function (ev) {
                    if (form.dataset.compressed === '1') {
                        return; // already processed, let it submit for real
                    }
                    var input = form.querySelector('input[type=file]');
                    if (!input || !input.files || !input.files[0]) {
                        return; // nothing chosen - server will ask for a photo
                    }
                    var file = input.files[0];
                    if (!/^image\//.test(file.type)) {
                        return; // not an image - let the server reject it
                    }

                    ev.preventDefault();
                    var btn = form.querySelector('button[type=submit]');
                    if (btn) { btn.disabled = true; }

                    var finish = function () {
                        form.dataset.compressed = '1';
                        form.submit();
                    };

                    var img = new Image();
                    var url = URL.createObjectURL(file);
                    img.onload = function () {
                        URL.revokeObjectURL(url);
                        var w = img.naturalWidth, h = img.naturalHeight;
                        if (!w || !h) { finish(); return; }
                        var scale = Math.min(1, MAX_SIDE / Math.max(w, h));
                        var cw = Math.max(1, Math.round(w * scale));
                        var ch = Math.max(1, Math.round(h * scale));
                        var canvas = document.createElement('canvas');
                        canvas.width = cw;
                        canvas.height = ch;
                        var ctx = canvas.getContext('2d');
                        ctx.fillStyle = '#ffffff';           // flatten transparency to white
                        ctx.fillRect(0, 0, cw, ch);
                        ctx.drawImage(img, 0, 0, cw, ch);
                        canvas.toBlob(function (blob) {
                            if (!blob) { finish(); return; }   // fall back to original
                            var name = (file.name || 'photo').replace(/\.[^.]+$/, '') + '.jpg';
                            try {
                                var newFile = new File([blob], name, { type: 'image/jpeg' });
                                var dt = new DataTransfer();
                                dt.items.add(newFile);
                                input.files = dt.files;
                            } catch (e) {
                                // Assigning input.files failed - just send the original.
                            }
                            finish();
                        }, 'image/jpeg', QUALITY);
                    };
                    img.onerror = function () {
                        URL.revokeObjectURL(url);
                        finish(); // couldn't read it here - let the server try
                    };
                    img.src = url;
                });
            });
        })();
    </script>
{% endblock content %}
