{#
 # This file is part of SolidInvoice package.
 #
 # (c) Pierre du Plessis <open-source@solidworx.co>
 #
 # Public, no-login MobilesOnline storefront. Self-contained (inline CSS/JS) so
 # it renders anywhere and is independent of the admin theme. Cart is handled
 # client-side; the finished order is handed to WhatsApp for despatch.
 #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ brand }} — {{ 'Buy phones online'|trans }}</title>
    {% set metaDescription = 'Mobiles Online — buy genuine new and graded pre-owned smartphones in Dubai, UAE. Verified handsets, honest grading and fast delivery. Order easily on WhatsApp.'|trans %}
    <meta name="description" content="{{ metaDescription }}">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="{{ store.canonicalUrl }}">
    <meta name="theme-color" content="#912e8a">
    <link rel="icon" type="image/png" sizes="32x32" href="/store-icon-32.png">
    <link rel="apple-touch-icon" href="/store-icon-180.png">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="{{ brand }}">
    <meta property="og:title" content="{{ brand }} — {{ 'Buy phones online'|trans }}">
    <meta property="og:description" content="{{ metaDescription }}">
    <meta property="og:url" content="{{ store.canonicalUrl }}">
    <meta property="og:image" content="{{ store.ogImage }}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:locale" content="en_US">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ brand }} — {{ 'Buy phones online'|trans }}">
    <meta name="twitter:description" content="{{ metaDescription }}">
    <meta name="twitter:image" content="{{ store.ogImage }}">
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Store",
        "name": {{ brand|json_encode|raw }},
        "legalName": {{ store.legalName|json_encode|raw }},
        "url": {{ store.canonicalUrl|json_encode|raw }},
        "image": {{ store.ogImage|json_encode|raw }},
        "telephone": "+{{ store.supportPhone }}",
        "email": {{ store.supportEmail|json_encode|raw }},
        "address": {
            "@type": "PostalAddress",
            "addressLocality": {{ (store.area ~ ', ' ~ store.city)|json_encode|raw }},
            "addressCountry": "AE"
        },
        "areaServed": "AE",
        "priceRange": "AED",
        "identifier": {
            "@type": "PropertyValue",
            "propertyID": "Trade Licence",
            "value": {{ store.licenceNumber|json_encode|raw }}
        }
    }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,700;12..96,800&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --ink:#0d1220; --ink-2:#1b2436; --muted:#6b7688; --line:#e7eaf0; --paper:#f6f7fb;
            --card:#fff; --cobalt:#2f5bff; --cobalt-d:#1e40e0; --sand:#e8b667;
            --green:#17a06a; --amber:#d98a1a; --slate:#64748b; --brand:#912e8a; --radius:16px;
            --shadow:0 1px 2px rgba(13,18,32,.04),0 12px 30px -18px rgba(13,18,32,.28);
        }
        *{box-sizing:border-box;margin:0;padding:0}
        body{font-family:"Manrope",-apple-system,BlinkMacSystemFont,sans-serif;background:var(--paper);color:var(--ink);-webkit-font-smoothing:antialiased}
        a{color:inherit;text-decoration:none}
        .display{font-family:"Bricolage Grotesque",sans-serif;letter-spacing:-.02em}
        header{position:sticky;top:0;z-index:40;background:rgba(255,255,255,.86);backdrop-filter:saturate(160%) blur(12px);border-bottom:1px solid var(--line)}
        .bar{max-width:1180px;margin:0 auto;padding:14px 22px;display:flex;align-items:center;gap:20px}
        .brand{display:flex;align-items:center;gap:11px}
        .brand-logo{height:30px;width:auto;display:block}
        .logo{width:38px;height:38px;border-radius:11px;flex:none;background:linear-gradient(145deg,var(--ink),var(--ink-2));display:grid;place-items:center;color:#fff;font-family:"Bricolage Grotesque";font-weight:800;font-size:17px}
        .brand .name{font-family:"Bricolage Grotesque";font-weight:800;font-size:18px;line-height:1}
        .brand .name span{display:block;font-family:"Manrope";font-weight:600;font-size:10.5px;letter-spacing:.16em;color:var(--muted);text-transform:uppercase;margin-top:3px}
        .search-wrap{flex:1;max-width:460px;margin:0 auto;position:relative}
        .search-wrap svg{position:absolute;left:14px;top:50%;transform:translateY(-50%);color:var(--muted)}
        .search{width:100%;padding:11px 14px 11px 40px;font-size:14px;font-family:inherit;border:1px solid var(--line);border-radius:12px;background:var(--paper);color:var(--ink)}
        .search:focus{outline:none;border-color:var(--cobalt);background:#fff;box-shadow:0 0 0 4px rgba(47,91,255,.1)}
        .cart-btn{position:relative;display:inline-flex;align-items:center;gap:8px;padding:10px 16px;border-radius:11px;background:var(--ink);color:#fff;font-weight:700;font-size:13px;cursor:pointer;border:0}
        .cart-btn .count{position:absolute;top:-7px;right:-7px;background:var(--sand);color:var(--ink);font-size:11px;font-weight:800;min-width:20px;height:20px;padding:0 5px;border-radius:10px;display:grid;place-items:center;box-shadow:0 0 0 2px #fff}
        .hero{max-width:1180px;margin:26px auto 8px;padding:0 22px}
        .hero-card{position:relative;overflow:hidden;border-radius:22px;padding:34px 36px;background:radial-gradient(120% 140% at 88% 8%,rgba(47,91,255,.20),rgba(47,91,255,0) 55%),radial-gradient(95% 120% at 30% 118%,rgba(145,46,138,.34),rgba(145,46,138,0) 60%),radial-gradient(100% 120% at 0% 100%,rgba(232,182,103,.20),rgba(232,182,103,0) 50%),linear-gradient(160deg,#0d1220,#161f36);color:#fff}
        .hero-card:before{content:"";position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,.05) 1px,transparent 1px);background-size:22px 22px;opacity:.5}
        .hero-card .tag{position:relative;display:inline-flex;align-items:center;gap:7px;font-size:12px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:var(--sand);margin-bottom:14px}
        .hero-card h1{position:relative;font-size:38px;line-height:1.03;font-weight:800;max-width:16ch}
        .hero-card p{position:relative;margin-top:14px;color:#c3ccdd;font-size:15px;max-width:48ch}
        .rail{max-width:1180px;margin:22px auto 6px;padding:0 22px;display:flex;gap:10px;flex-wrap:wrap}
        .chip{padding:9px 16px;border-radius:999px;font-size:13px;font-weight:600;cursor:pointer;background:#fff;border:1px solid var(--line);color:var(--ink-2);transition:.15s}
        .chip:hover{border-color:#c9d2e4}
        .chip.active{background:var(--brand);color:#fff;border-color:var(--brand)}
        .sec-head{max-width:1180px;margin:20px auto 0;padding:0 22px;display:flex;align-items:baseline;justify-content:space-between}
        .sec-head h2{font-family:"Bricolage Grotesque";font-size:21px;font-weight:800}
        .sec-head .meta{font-size:13px;color:var(--muted)}
        .grid{max-width:1180px;margin:16px auto 40px;padding:0 22px;display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
        .prod{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;display:flex;flex-direction:column;box-shadow:var(--shadow);transition:.18s}
        .prod:hover{transform:translateY(-3px);border-color:#d6deee;box-shadow:0 1px 2px rgba(13,18,32,.05),0 22px 40px -22px rgba(13,18,32,.4)}
        .shot{position:relative;aspect-ratio:4/3.2;display:grid;place-items:center;background:linear-gradient(170deg,#f2f4fa,#e9edf6);overflow:hidden}
        .shot img{width:100%;height:100%;object-fit:cover}
        .badge-grade{position:absolute;top:10px;left:10px;font-size:10px;font-weight:800;letter-spacing:.02em;padding:4px 8px;border-radius:7px;text-transform:uppercase;z-index:2;white-space:nowrap;box-shadow:0 1px 3px rgba(13,18,32,.12)}
        .g-a{background:#0f9d63;color:#fff} .g-b{background:#e08a12;color:#fff} .g-c{background:#5b6675;color:#fff} .g-new{background:var(--cobalt);color:#fff}
        .stock-dot{position:absolute;top:10px;right:10px;font-size:10px;font-weight:700;color:var(--green);display:inline-flex;align-items:center;gap:5px;background:#fff;padding:4px 8px;border-radius:7px;border:1px solid var(--line);z-index:2;white-space:nowrap;box-shadow:0 1px 3px rgba(13,18,32,.08)}
        .stock-dot i{width:7px;height:7px;border-radius:50%;background:var(--green);display:inline-block}
        .stock-dot.out{color:var(--slate)} .stock-dot.out i{background:var(--slate)}
        .sale-flag{position:absolute;bottom:12px;left:12px;background:var(--cobalt);color:#fff;font-size:11px;font-weight:800;padding:4px 9px;border-radius:7px;z-index:2}
        .phone{width:78px;height:150px;border-radius:16px;position:relative;background:linear-gradient(160deg,#2b3a55,#0d1220);box-shadow:0 10px 22px -8px rgba(13,18,32,.45),inset 0 0 0 2px rgba(255,255,255,.12)}
        .phone:before{content:"";position:absolute;top:9px;left:50%;transform:translateX(-50%);width:26px;height:5px;border-radius:3px;background:rgba(0,0,0,.28)}
        .phone:after{content:"";position:absolute;right:9px;top:15px;width:20px;height:20px;border-radius:6px;background:rgba(255,255,255,.16);box-shadow:0 22px 0 rgba(255,255,255,.10)}
        .info{padding:14px 15px 16px;display:flex;flex-direction:column;gap:9px;flex:1}
        .info .title{font-weight:700;font-size:15px;line-height:1.25}
        .chips{display:flex;gap:6px;flex-wrap:wrap}
        .spec{font-size:11.5px;font-weight:600;color:var(--ink-2);background:var(--paper);border:1px solid var(--line);padding:3px 8px;border-radius:6px}
        .buy{display:flex;align-items:center;justify-content:space-between;margin-top:auto;padding-top:6px;gap:8px}
        .price b{font-family:"Bricolage Grotesque";font-size:20px;font-weight:800;display:block}
        .price .was{font-size:12px;color:var(--muted);text-decoration:line-through;font-weight:600}
        .add{border:0;cursor:pointer;width:40px;height:40px;border-radius:11px;background:var(--cobalt);color:#fff;display:grid;place-items:center;transition:.15s;flex:none}
        .add:hover{background:var(--cobalt-d)}
        .add:disabled{background:#cbd5e1;cursor:not-allowed}
        #no-results{max-width:1180px;margin:0 auto 40px;padding:0 22px;text-align:center;color:#94a3b8;display:none}
        .empty-store{max-width:1180px;margin:30px auto;padding:40px 22px;text-align:center;color:#94a3b8}
        .scrim{position:fixed;inset:0;background:rgba(13,18,32,.42);z-index:60;display:none}
        .drawer{position:fixed;top:0;right:0;height:100%;width:380px;max-width:92vw;z-index:61;background:#fff;box-shadow:-20px 0 50px -20px rgba(13,18,32,.4);display:flex;flex-direction:column;transform:translateX(100%);transition:transform .25s}
        .drawer.open{transform:none}
        .drawer h3{font-family:"Bricolage Grotesque";font-size:19px;font-weight:800;padding:20px 22px 4px;display:flex;justify-content:space-between;align-items:center}
        .drawer h3 .x{cursor:pointer;color:var(--muted);font-size:26px;line-height:1;font-weight:400}
        .drawer .sub{padding:0 22px 16px;color:var(--muted);font-size:13px;border-bottom:1px solid var(--line)}
        .items{flex:1;overflow:auto;padding:8px 14px}
        .cart-empty{text-align:center;color:var(--muted);padding:50px 16px;font-size:14px}
        .line{display:flex;gap:12px;padding:12px 8px;border-bottom:1px solid var(--paper);align-items:center}
        .line .mini{width:42px;height:54px;border-radius:9px;flex:none;background:linear-gradient(160deg,#2b3a55,#0d1220);background-size:cover;background-position:center}
        .line .l-body{flex:1}
        .line .l-body .t{font-weight:700;font-size:14px}
        .line .l-body .s{font-size:12px;color:var(--muted);margin-top:2px}
        .line .l-price{font-weight:800;font-family:"Bricolage Grotesque";font-size:15px;white-space:nowrap}
        .qty{display:inline-flex;align-items:center;gap:10px;margin-top:6px;font-size:13px}
        .qty button{width:22px;height:22px;border-radius:6px;border:1px solid var(--line);background:#fff;cursor:pointer;font-weight:700}
        .foot{border-top:1px solid var(--line);padding:18px 22px 22px}
        .foot .row{display:flex;justify-content:space-between;font-size:14px;margin-bottom:6px;color:var(--ink-2)}
        .foot .row.total{font-size:17px;font-weight:800;color:var(--ink);font-family:"Bricolage Grotesque";margin:10px 0 16px}
        .wa-checkout{display:flex;align-items:center;justify-content:center;gap:10px;width:100%;padding:15px;border-radius:13px;border:0;cursor:pointer;background:#1faa5a;color:#fff;font-family:inherit;font-weight:800;font-size:15px}
        .wa-checkout:disabled{background:#c7d0dc;cursor:not-allowed}
        .wa-note{text-align:center;font-size:11.5px;color:var(--muted);margin-top:10px}
        footer{border-top:1px solid var(--line);background:#fff;margin-top:28px}
        .foot-in{max-width:1180px;margin:0 auto;padding:34px 22px 20px;display:flex;justify-content:space-between;gap:30px;color:var(--muted);font-size:13px;flex-wrap:wrap}
        .foot-col{display:flex;flex-direction:column;gap:7px;min-width:180px}
        .foot-about{max-width:340px}
        .foot-name{font-family:"Bricolage Grotesque",sans-serif;font-weight:800;font-size:16px;color:var(--ink)}
        .foot-licence{font-size:12.5px;line-height:1.5;color:var(--muted)}
        .foot-col h4{font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.04em;color:var(--ink-2)}
        .foot-col p{font-size:13px;line-height:1.5}
        .foot-col a{color:var(--muted);transition:color .15s}
        .foot-col a:hover{color:var(--brand)}
        .foot-bottom{border-top:1px solid var(--line);max-width:1180px;margin:0 auto;padding:14px 22px;display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;font-size:12px;color:var(--muted)}
        @media (max-width:900px){.grid{grid-template-columns:repeat(2,1fr)}.search-wrap{display:none}.hero-card h1{font-size:28px}}
        /* Phones: drop to a single full-width column so every card gets the whole
           screen width - the title, spec chips and key-specs line read clearly
           (same roomy feel as desktop) and the corner badges never crowd each
           other. Two narrow columns squeezed the detail and clipped the badges. */
        @media (max-width:560px){
            .brand-logo{height:26px}
            .grid{grid-template-columns:1fr;gap:14px;padding:0 16px;margin-top:14px}
            .shot{aspect-ratio:auto;height:200px}
            .shot img{height:100%}
            .info{padding:16px 17px 18px;gap:10px}
            .info .title{font-size:17px}
            .spec{font-size:12.5px;padding:4px 9px}
            .info .text-muted{font-size:13px !important}
            .price b{font-size:22px}
            .price .was{font-size:13px}
            .add{width:46px;height:46px}
            .hero-card h1{font-size:24px}
            .sec-head h2{font-size:19px}
            .foot-in{flex-direction:column;gap:22px;padding:26px 18px 16px}
            .foot-bottom{flex-direction:column;gap:6px;padding:14px 18px}
        }
    </style>
</head>
<body>

<header>
    <div class="bar">
        <a class="brand" href="{{ path('_store_front') }}">
            <img class="brand-logo" src="data:image/png;base64," alt="{{ brand }}">
        </a>
        <div class="search-wrap">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
            <input class="search" id="store-search" placeholder="{{ 'Search iPhone, Samsung, model, storage…'|trans }}" autocomplete="off">
        </div>
        <button class="cart-btn" id="cart-open">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 6h15l-1.5 9h-12z"/><circle cx="9" cy="20" r="1.4"/><circle cx="18" cy="20" r="1.4"/><path d="M6 6 5 3H2"/></svg>
            {{ 'Cart'|trans }}
            <span class="count" id="cart-count" style="display:none;">0</span>
        </button>
    </div>
</header>

<section class="hero">
    <div class="hero-card">
        <div class="tag">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 3 7v6c0 5 3.8 8.5 9 9 5.2-.5 9-4 9-9V7Z"/></svg>
            {{ 'Verified phones · Order on WhatsApp · Dispatch across UAE'|trans }}
        </div>
        <h1 class="display">{{ 'Genuine phones, graded and priced to move.'|trans }}</h1>
        <p>{{ 'Browse our hand-picked handsets, add to cart, and your order lands straight on our despatch WhatsApp — no accounts, no waiting.'|trans }}</p>
    </div>
</section>

{% if products is empty %}
    <div class="empty-store">
        {{ 'Our store is being updated. Please check back shortly.'|trans }}
    </div>
{% else %}
    <div class="rail" id="filter-rail">
        <div class="chip active" data-filter="all">{{ 'All phones'|trans }}</div>
        {% for make in makes %}
            <div class="chip" data-filter="make:{{ make|lower }}">{{ make }}</div>
        {% endfor %}
        <div class="chip" data-filter="sale">{{ 'On sale'|trans }}</div>
    </div>

    <div class="sec-head">
        <h2>{{ 'In stock now'|trans }}</h2>
        <div class="meta">{{ products|length }} {{ 'models'|trans }}</div>
    </div>

    <div class="grid" id="grid">
        {% for product in products %}
            {% set cond = (product.condition ?: '')|lower %}
            {% set gradeClass = 'g-new' %}
            {% set gradeLabel = 'New' %}
            {% if 'c' in cond %}{% set gradeClass = 'g-c' %}{% set gradeLabel = 'Grade C' %}
            {% elseif 'b' in cond %}{% set gradeClass = 'g-b' %}{% set gradeLabel = 'Grade B' %}
            {% elseif 'a' in cond %}{% set gradeClass = 'g-a' %}{% set gradeLabel = 'Grade A' %}{% endif %}
            {% set eff = product.effectivePrice %}
            <article class="prod"
                     data-search="{{ (product.make ~ ' ' ~ product.model ~ ' ' ~ (product.storage ?: '') ~ ' ' ~ (product.condition ?: ''))|lower }}"
                     data-make="{{ product.make|lower }}"
                     data-sale="{{ product.onSale ? '1' : '0' }}">
                <div class="shot">
                    {% if product.condition %}<span class="badge-grade {{ gradeClass }}">{{ gradeLabel }}</span>{% endif %}
                    {% if product.inStock %}
                        <span class="stock-dot"><i></i>{{ 'In stock'|trans }}</span>
                    {% else %}
                        <span class="stock-dot out"><i></i>{{ 'Sold out'|trans }}</span>
                    {% endif %}
                    {% if product.onSale %}<span class="sale-flag">{{ 'SALE'|trans }}</span>{% endif %}
                    {% if product.imagePath %}
                        <img src="{{ asset(product.imagePath) }}" alt="{{ product }}">
                    {% else %}
                        <div class="phone"></div>
                    {% endif %}
                </div>
                <div class="info">
                    <div class="title">{{ product }}</div>
                    <div class="chips">
                        {% if product.storage %}<span class="spec">{{ product.storage }}</span>{% endif %}
                        {% if product.condition %}<span class="spec">{{ product.condition }}</span>{% endif %}
                        {% if product.color %}<span class="spec">{{ product.color }}</span>{% endif %}
                    </div>
                    {% if product.keySpecs %}<div class="text-muted" style="font-size:12px;color:var(--muted)">{{ product.keySpecs }}</div>{% endif %}
                    <div class="buy">
                        <div class="price">
                            {% if product.onSale %}<span class="was">AED {{ product.regularPrice|number_format(0) }}</span>{% endif %}
                            <b>AED {{ eff|number_format(0) }}</b>
                        </div>
                        <button class="add"
                                {{ product.inStock ? '' : 'disabled' }}
                                data-sku="{{ product.sku }}"
                                data-name="{{ product }}"
                                data-detail="{{ ((product.storage ?: '') ~ (product.condition ? ' · ' ~ product.condition : '') ~ (product.color ? ' · ' ~ product.color : ''))|trim(' ·') }}"
                                data-price="{{ eff }}"
                                data-img="{{ product.imagePath ? asset(product.imagePath) : '' }}"
                                title="{{ 'Add to order'|trans }}">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 5v14M5 12h14"/></svg>
                        </button>
                    </div>
                </div>
            </article>
        {% endfor %}
    </div>
    <div id="no-results">{{ 'No matching phones found.'|trans }}</div>
{% endif %}

<footer>
    <div class="foot-in">
        <div class="foot-col foot-about">
            <div class="foot-name">{{ store.legalName }}</div>
            <p class="foot-licence">{{ 'Trade Licence'|trans }} No. {{ store.licenceNumber }}<br>{{ 'Issued by'|trans }} {{ store.licenceAuthority }}</p>
        </div>
        <div class="foot-col">
            <h4>{{ 'Customer Service'|trans }}</h4>
            <p><a href="https://wa.me/{{ store.supportPhone }}">{{ 'WhatsApp'|trans }} {{ store.supportPhoneDisplay }}</a></p>
            <p><a href="mailto:{{ store.supportEmail }}">{{ store.supportEmail }}</a></p>
        </div>
        <div class="foot-col">
            <h4>{{ 'Location'|trans }}</h4>
            <p>{{ store.area }}, {{ store.city }}</p>
            <p>{{ store.country }}</p>
        </div>
    </div>
    <div class="foot-bottom">
        <span>© {{ 'now'|date('Y') }} {{ brand }}</span>
        <span>{{ 'Prices in AED · Order on WhatsApp'|trans }}</span>
    </div>
</footer>

<div class="scrim" id="scrim"></div>
<aside class="drawer" id="drawer">
    <h3>{{ 'Your order'|trans }} <span class="x" id="cart-close">&times;</span></h3>
    <div class="sub">{{ 'Review, then send to despatch on WhatsApp to confirm.'|trans }}</div>
    <div class="items" id="cart-items">
        <div class="cart-empty" id="cart-empty">{{ 'Your cart is empty. Add a phone to get started.'|trans }}</div>
    </div>
    <div class="foot">
        <div class="row total"><span>{{ 'Total'|trans }}</span><span id="cart-total">AED 0</span></div>
        <button class="wa-checkout" id="wa-send" disabled>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.5 15.2L2 22l4.9-1.4A10 10 0 1 0 12 2Zm5.3 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .1-1.7-.1-.4-.1-.9-.3-1.6-.6a9.6 9.6 0 0 1-3.6-3.2c-.3-.4-.7-1-.7-1.9 0-.9.5-1.3.6-1.5.2-.2.4-.2.6-.2h.4c.1 0 .3 0 .5.4l.7 1.6c0 .1.1.3 0 .4l-.3.5-.3.3c-.1.1-.2.2-.1.4.1.2.6 1 1.3 1.6.9.8 1.6 1 1.8 1.1.2.1.3.1.4-.1l.6-.7c.2-.2.3-.2.5-.1l1.5.7c.2.1.4.2.4.3.1.1.1.5 0 .7Z"/></svg>
            {{ 'Send order to despatch'|trans }}
        </button>
        <div class="wa-note">{{ "You'll be handed to WhatsApp with your full order pre-filled."|trans }}</div>
    </div>
</aside>

<script>
(function () {
    var WHATSAPP = {{ whatsapp|json_encode|raw }};
    var COMPANY = {{ brand|json_encode|raw }};
    var cart = {}; // sku -> {name, detail, price, img, qty}

    var drawer = document.getElementById('drawer');
    var scrim = document.getElementById('scrim');
    var itemsEl = document.getElementById('cart-items');
    var emptyEl = document.getElementById('cart-empty');
    var totalEl = document.getElementById('cart-total');
    var countEl = document.getElementById('cart-count');
    var sendBtn = document.getElementById('wa-send');

    function money(n) { return 'AED ' + Math.round(n).toLocaleString('en-US'); }

    function openCart() { drawer.classList.add('open'); scrim.style.display = 'block'; }
    function closeCart() { drawer.classList.remove('open'); scrim.style.display = 'none'; }

    document.getElementById('cart-open').addEventListener('click', openCart);
    document.getElementById('cart-close').addEventListener('click', closeCart);
    scrim.addEventListener('click', closeCart);

    function render() {
        var skus = Object.keys(cart);
        var total = 0, count = 0;
        if (skus.length === 0) {
            itemsEl.innerHTML = '';
            itemsEl.appendChild(emptyEl);
            emptyEl.style.display = 'block';
            sendBtn.disabled = true;
        } else {
            emptyEl.style.display = 'none';
            var html = '';
            skus.forEach(function (sku) {
                var it = cart[sku];
                total += it.price * it.qty;
                count += it.qty;
                var bg = it.img ? "background-image:url('" + it.img + "')" : '';
                html += '<div class="line">' +
                    '<div class="mini" style="' + bg + '"></div>' +
                    '<div class="l-body"><div class="t">' + it.name + '</div>' +
                    '<div class="s">' + (it.detail || '') + '</div>' +
                    '<div class="qty"><button data-dec="' + sku + '">−</button> ' + it.qty + ' <button data-inc="' + sku + '">+</button></div></div>' +
                    '<div class="l-price">' + money(it.price * it.qty) + '</div></div>';
            });
            itemsEl.innerHTML = html;
            sendBtn.disabled = false;
        }
        totalEl.textContent = money(total);
        if (count > 0) { countEl.style.display = 'grid'; countEl.textContent = count; }
        else { countEl.style.display = 'none'; }
    }

    document.querySelectorAll('.add').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var sku = btn.getAttribute('data-sku');
            if (!cart[sku]) {
                cart[sku] = {
                    name: btn.getAttribute('data-name'),
                    detail: btn.getAttribute('data-detail'),
                    price: parseFloat(btn.getAttribute('data-price')) || 0,
                    img: btn.getAttribute('data-img'),
                    qty: 0
                };
            }
            cart[sku].qty++;
            render();
            openCart();
        });
    });

    itemsEl.addEventListener('click', function (e) {
        var inc = e.target.getAttribute('data-inc');
        var dec = e.target.getAttribute('data-dec');
        if (inc && cart[inc]) { cart[inc].qty++; render(); }
        if (dec && cart[dec]) { cart[dec].qty--; if (cart[dec].qty <= 0) { delete cart[dec]; } render(); }
    });

    sendBtn.addEventListener('click', function () {
        var skus = Object.keys(cart);
        if (skus.length === 0) { return; }
        var lines = ['*New order — ' + COMPANY + '*', ''];
        var total = 0;
        skus.forEach(function (sku) {
            var it = cart[sku];
            total += it.price * it.qty;
            lines.push('• ' + it.qty + 'x ' + it.name + (it.detail ? ' (' + it.detail + ')' : '') + ' — ' + money(it.price * it.qty));
        });
        lines.push('', '*Total: ' + money(total) + '*', '', 'Please confirm availability and delivery. Thank you!');
        var text = encodeURIComponent(lines.join('\n'));
        var url = WHATSAPP ? ('https://wa.me/' + WHATSAPP + '?text=' + text) : ('https://wa.me/?text=' + text);
        window.open(url, '_blank');
    });

    // ---- search + category filter ----
    var searchInput = document.getElementById('store-search');
    var cards = Array.prototype.slice.call(document.querySelectorAll('#grid .prod'));
    var noResults = document.getElementById('no-results');
    var rail = document.getElementById('filter-rail');
    var activeFilter = 'all';

    function applyFilters() {
        var q = (searchInput && searchInput.value.trim().toLowerCase()) || '';
        var shown = 0;
        cards.forEach(function (card) {
            var matchQ = q === '' || card.getAttribute('data-search').indexOf(q) !== -1;
            var matchF = true;
            if (activeFilter === 'sale') { matchF = card.getAttribute('data-sale') === '1'; }
            else if (activeFilter.indexOf('make:') === 0) { matchF = card.getAttribute('data-make') === activeFilter.slice(5); }
            var show = matchQ && matchF;
            card.style.display = show ? '' : 'none';
            if (show) { shown++; }
        });
        if (noResults) { noResults.style.display = shown === 0 ? 'block' : 'none'; }
    }

    if (searchInput) { searchInput.addEventListener('input', applyFilters); }
    if (rail) {
        rail.addEventListener('click', function (e) {
            var chip = e.target.closest('.chip');
            if (!chip) { return; }
            rail.querySelectorAll('.chip').forEach(function (c) { c.classList.remove('active'); });
            chip.classList.add('active');
            activeFilter = chip.getAttribute('data-filter');
            applyFilters();
        });
    }
})();
</script>
</body>
</html>
