{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% set isEdit = supplier is not null %}

{% block title %}{{ ux_icon('tabler:truck', {width: 24, height: 24, class: 'me-2'}) }}{{ (isEdit ? 'Edit supplier' : 'Add supplier')|trans }}{% endblock title %}

{% block heading %}
    <a href="{{ path('_suppliers_list') }}" class="btn btn-outline-secondary">
        {{ ux_icon('tabler:arrow-left', {width: 18, height: 18}) }}
        {{ 'Back'|trans }}
    </a>
{% endblock %}

{% block content %}
    <twig:Ui:Card>
        <form method="post" action="{{ isEdit ? path('_supplier_edit', {id: supplier.id}) : path('_supplier_new') }}">
            <div class="row g-3">
                <div class="col-md-6">
                    <label for="s-name" class="form-label">{{ 'Supplier name'|trans }} <span class="text-danger">*</span></label>
                    <input type="text" name="name" id="s-name" class="form-control" value="{{ data.name }}" required maxlength="255">
                </div>
                <div class="col-md-6">
                    <label for="s-contact" class="form-label">{{ 'Contact person'|trans }}</label>
                    <input type="text" name="contact_person" id="s-contact" class="form-control" value="{{ data.contact_person }}" maxlength="255">
                </div>
                <div class="col-md-6">
                    <label for="s-phone" class="form-label">{{ 'Phone'|trans }}</label>
                    <input type="text" name="phone" id="s-phone" class="form-control" value="{{ data.phone }}" maxlength="64">
                </div>
                <div class="col-md-6">
                    <label for="s-email" class="form-label">{{ 'Email'|trans }}</label>
                    <input type="email" name="email" id="s-email" class="form-control" value="{{ data.email }}" maxlength="255">
                </div>
                <div class="col-md-6">
                    <label for="s-tax" class="form-label">{{ 'VAT / TRN'|trans }}</label>
                    <input type="text" name="tax_id" id="s-tax" class="form-control" value="{{ data.tax_id }}" maxlength="64">
                </div>
                <div class="col-12">
                    <label for="s-address" class="form-label">{{ 'Address'|trans }}</label>
                    <textarea name="address" id="s-address" class="form-control" rows="2">{{ data.address }}</textarea>
                </div>
                <div class="col-12">
                    <label for="s-notes" class="form-label">{{ 'Notes'|trans }}</label>
                    <textarea name="notes" id="s-notes" class="form-control" rows="2">{{ data.notes }}</textarea>
                </div>
            </div>

            <input type="hidden" name="_token" value="{{ csrf_token('supplier.save') }}">

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    {{ ux_icon('tabler:device-floppy', {width: 18, height: 18}) }}
                    {{ 'Save supplier'|trans }}
                </button>
                <a href="{{ path('_suppliers_list') }}" class="btn btn-link">{{ 'Cancel'|trans }}</a>
            </div>
        </form>
    </twig:Ui:Card>
{% endblock content %}
