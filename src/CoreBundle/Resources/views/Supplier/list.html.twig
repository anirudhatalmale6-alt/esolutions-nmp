{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% block title %}{{ ux_icon('tabler:truck', {width: 24, height: 24, class: 'me-2'}) }}{{ 'Suppliers'|trans }}{% endblock title %}

{% block heading %}
    <a href="{{ path('_supplier_new') }}" class="btn btn-primary">
        {{ ux_icon('tabler:plus', {width: 18, height: 18}) }}
        {{ 'Add supplier'|trans }}
    </a>
{% endblock %}

{% block content %}
    <twig:Ui:Card>
        {% if suppliers is empty %}
            <div class="text-center py-5 text-muted">
                {{ ux_icon('tabler:truck-off', {width: 40, height: 40}) }}
                <p class="mt-3 mb-1">{{ 'No suppliers added yet.'|trans }}</p>
                <a href="{{ path('_supplier_new') }}" class="btn btn-sm btn-primary mt-2">{{ 'Add your first supplier'|trans }}</a>
            </div>
        {% else %}
            <div class="mb-3">
                <input type="text" id="supplier-search" class="form-control" placeholder="{{ 'Search supplier...'|trans }}" autocomplete="off">
            </div>
            <div class="table-responsive">
                <table class="table table-vcenter" id="supplier-table">
                    <thead>
                        <tr>
                            <th>{{ 'Name'|trans }}</th>
                            <th>{{ 'Contact'|trans }}</th>
                            <th>{{ 'Phone'|trans }}</th>
                            <th>{{ 'Email'|trans }}</th>
                            <th>{{ 'VAT / TRN'|trans }}</th>
                            <th class="text-end">{{ 'Actions'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody id="supplier-body">
                        {% for supplier in suppliers %}
                            <tr data-search="{{ (supplier.name ~ ' ' ~ supplier.contactPerson ~ ' ' ~ supplier.phone ~ ' ' ~ supplier.email ~ ' ' ~ supplier.taxId)|lower }}">
                                <td class="fw-semibold">{{ supplier.name }}</td>
                                <td>{{ supplier.contactPerson ?: '—' }}</td>
                                <td>{{ supplier.phone ?: '—' }}</td>
                                <td>{{ supplier.email ?: '—' }}</td>
                                <td>{{ supplier.taxId ?: '—' }}</td>
                                <td class="text-end text-nowrap">
                                    <a href="{{ path('_supplier_edit', {id: supplier.id}) }}" class="btn btn-sm btn-outline-primary">
                                        {{ ux_icon('tabler:edit', {width: 15, height: 15}) }} {{ 'Edit'|trans }}
                                    </a>
                                    <form method="post" action="{{ path('_supplier_delete', {id: supplier.id}) }}" class="d-inline" onsubmit="return confirm('{{ 'Delete this supplier?'|trans }}');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('supplier.delete') }}">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            {{ ux_icon('tabler:trash', {width: 15, height: 15}) }}
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div id="supplier-no-results" class="text-center text-muted py-4" style="display: none;">{{ 'No matching suppliers found.'|trans }}</div>
            <script>
                (function () {
                    var input = document.getElementById('supplier-search');
                    var rows = document.querySelectorAll('#supplier-body tr');
                    var noResults = document.getElementById('supplier-no-results');
                    if (!input) { return; }
                    input.addEventListener('input', function () {
                        var q = input.value.trim().toLowerCase();
                        var shown = 0;
                        rows.forEach(function (row) {
                            var match = q === '' || row.getAttribute('data-search').indexOf(q) !== -1;
                            row.style.display = match ? '' : 'none';
                            if (match) { shown++; }
                        });
                        noResults.style.display = shown === 0 ? 'block' : 'none';
                    });
                })();
            </script>
        {% endif %}
    </twig:Ui:Card>
{% endblock content %}
