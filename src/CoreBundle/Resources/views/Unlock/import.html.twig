{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% block title %}{{ ux_icon('tabler:upload', {width: 24, height: 24, class: 'me-2'}) }}{{ 'Upload unlock codes'|trans }}{% endblock title %}

{% block heading %}
    <a href="{{ path('_unlock_list') }}" class="btn btn-outline-secondary">
        {{ ux_icon('tabler:arrow-left', {width: 18, height: 18}) }}
        {{ 'Back to unlock codes'|trans }}
    </a>
{% endblock %}

{% block content %}
    <twig:Ui:Card>
        <twig:block name="header">
            <h3 class="card-title mb-0">{{ 'Upload supplier unlock-codes file'|trans }}</h3>
        </twig:block>

        <p class="text-muted">
            {{ 'Upload the Excel file your supplier sends with the unlocking codes. It reads any of their layouts - it finds the IMEI column automatically and takes the code from right next to it. Only the IMEI and its code are stored (no model, colour or carrier).'|trans }}
        </p>
        <p class="text-muted">
            {{ 'Each upload ADDS to your codes and updates any IMEI already on file, so you can keep uploading each new invoice file as it arrives. Use "Clear all" on the previous page for a full reset.'|trans }}
        </p>

        <form method="post" action="{{ path('_unlock_import') }}" enctype="multipart/form-data" class="d-flex align-items-end gap-3 flex-wrap">
            <div>
                <label for="unlock-file" class="form-label">{{ 'Unlock codes file (.xlsx / .xls)'|trans }}</label>
                <input type="file" name="unlock_file" id="unlock-file" class="form-control" accept=".xlsx,.xls" required>
            </div>
            <input type="hidden" name="_token" value="{{ csrf_token('unlock.import') }}">
            <button type="submit" class="btn btn-primary">
                {{ ux_icon('tabler:upload', {width: 18, height: 18}) }}
                {{ 'Import'|trans }}
            </button>
        </form>
    </twig:Ui:Card>

    <div class="mt-3">
        <a href="{{ path('_unlock_list') }}" class="btn btn-link">{{ ux_icon('tabler:arrow-left', {width: 16, height: 16}) }} {{ 'Back to unlock codes'|trans }}</a>
    </div>
{% endblock content %}
