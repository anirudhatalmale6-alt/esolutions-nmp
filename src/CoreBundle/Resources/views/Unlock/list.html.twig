{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% block title %}{{ ux_icon('tabler:key', {width: 24, height: 24, class: 'me-2'}) }}{{ 'IMEI unlock codes'|trans }}{% endblock title %}

{% block heading %}
    {% if is_granted('ROLE_MANAGER') %}
    <a href="{{ path('_unlock_import') }}" class="btn btn-primary">
        {{ ux_icon('tabler:upload', {width: 18, height: 18}) }}
        {{ 'Upload codes'|trans }}
    </a>
    {% endif %}
{% endblock %}

{% block content %}
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <span class="fw-semibold text-nowrap">
                    {{ ux_icon('tabler:external-link', {width: 18, height: 18}) }} {{ 'Customer lookup link'|trans }}
                </span>
                <input type="text" id="unlock-url" class="form-control" style="max-width: 520px;" value="{{ publicUrl }}" readonly onclick="this.select()">
                <button type="button" id="unlock-url-copy" class="btn btn-outline-primary">{{ 'Copy'|trans }}</button>
                <a href="{{ publicUrl }}" target="_blank" rel="noopener" class="btn btn-link">{{ 'Open'|trans }}</a>
            </div>
            <div class="text-muted small mt-2">
                {{ 'Share this link with customers. They enter their IMEI and instantly get their unlock code - no login, nothing else shown.'|trans }}
            </div>
        </div>
    </div>
    <script>
        (function () {
            var btn = document.getElementById('unlock-url-copy');
            var field = document.getElementById('unlock-url');
            if (!btn || !field) { return; }
            btn.addEventListener('click', function () {
                field.select();
                var done = function () {
                    var original = btn.innerHTML;
                    btn.innerHTML = {{ 'Copied!'|trans|json_encode|raw }};
                    setTimeout(function () { btn.innerHTML = original; }, 1500);
                };
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(field.value).then(done, function () { document.execCommand('copy'); done(); });
                } else {
                    document.execCommand('copy');
                    done();
                }
            });
        })();
    </script>

    {# Bulk lookup: paste a batch of IMEIs and get every code back at once. #}
    <div class="card mb-3">
        <div class="card-body">
            <h3 class="card-title">{{ ux_icon('tabler:list-search', {width: 18, height: 18}) }} {{ 'Bulk lookup'|trans }}</h3>
            <p class="text-muted small mb-2">{{ 'Paste any number of IMEIs (from an order, one per line or separated by spaces/commas) and get all their codes together, ready to copy and forward.'|trans }}</p>
            <form method="post" action="{{ path('_unlock_lookup') }}">
                <textarea name="imeis" rows="4" class="form-control mb-2" placeholder="{{ 'Paste IMEIs here - one per line, or separated by spaces or commas'|trans }}"></textarea>
                <input type="hidden" name="_token" value="{{ csrf_token('unlock.lookup') }}">
                <button type="submit" class="btn btn-primary">
                    {{ ux_icon('tabler:search', {width: 18, height: 18}) }} {{ 'Look up codes'|trans }}
                </button>
            </form>
        </div>
    </div>

    <twig:Ui:Card>
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
            <div class="text-muted">
                {{ ux_icon('tabler:database', {width: 18, height: 18}) }}
                <strong>{{ total|number_format }}</strong> {{ 'unlock code(s) on file'|trans }}
            </div>
            {% if is_granted('ROLE_MANAGER') and total > 0 %}
                <form method="post" action="{{ path('_unlock_clear') }}" onsubmit="return confirm({{ 'Remove ALL unlock codes? This cannot be undone.'|trans|json_encode|raw }});">
                    <input type="hidden" name="_token" value="{{ csrf_token('unlock.clear') }}">
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                        {{ ux_icon('tabler:trash', {width: 16, height: 16}) }} {{ 'Clear all'|trans }}
                    </button>
                </form>
            {% endif %}
        </div>

        {% if codes is empty %}
            <div class="text-center py-5 text-muted">
                {{ ux_icon('tabler:key-off', {width: 40, height: 40}) }}
                <p class="mt-3 mb-1">{{ 'No unlock codes have been uploaded yet.'|trans }}</p>
                {% if is_granted('ROLE_MANAGER') %}
                <a href="{{ path('_unlock_import') }}" class="btn btn-sm btn-primary mt-2">{{ 'Upload your first codes file'|trans }}</a>
                {% endif %}
            </div>
        {% else %}
            <div class="mb-3">
                <input type="text" id="code-search" class="form-control" placeholder="{{ 'Search by IMEI or code...'|trans }}" autocomplete="off">
            </div>
            <div class="table-responsive">
            <table class="table table-vcenter" id="code-table">
                <thead>
                    <tr>
                        <th>{{ 'IMEI'|trans }}</th>
                        <th>{{ 'Code'|trans }}</th>
                        <th class="text-nowrap">{{ 'Updated'|trans }}</th>
                    </tr>
                </thead>
                <tbody id="code-body">
                    {% for code in codes %}
                        <tr data-search="{{ (code.imei ~ ' ' ~ code.code)|lower }}">
                            <td class="text-nowrap"><code>{{ code.imei }}</code></td>
                            <td class="fw-bold">{{ code.code ?: '—' }}</td>
                            <td class="text-muted small text-nowrap">
                                {% if code.updated %}{{ code.updated|date('d M Y, g:i A') }}{% else %}—{% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            </div>
            <div id="code-no-results" class="text-center text-muted py-4" style="display: none;">{{ 'No matching codes found.'|trans }}</div>
            <script>
                (function () {
                    var input = document.getElementById('code-search');
                    if (!input) { return; }
                    var rows = Array.prototype.slice.call(document.querySelectorAll('#code-body tr'));
                    var noResults = document.getElementById('code-no-results');
                    input.addEventListener('input', function () {
                        var q = input.value.trim().toLowerCase();
                        var shown = 0;
                        rows.forEach(function (row) {
                            var match = q === '' || row.getAttribute('data-search').indexOf(q) !== -1;
                            row.style.display = match ? '' : 'none';
                            if (match) { shown++; }
                        });
                        noResults.style.display = shown === 0 ? 'block' : 'none';
                    });
                })();
            </script>
        {% endif %}
    </twig:Ui:Card>
{% endblock content %}
