{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% block title %}{{ ux_icon('tabler:list-search', {width: 24, height: 24, class: 'me-2'}) }}{{ 'Bulk lookup results'|trans }}{% endblock title %}

{% block heading %}
    <a href="{{ path('_unlock_list') }}" class="btn btn-outline-secondary">
        {{ ux_icon('tabler:arrow-left', {width: 18, height: 18}) }}
        {{ 'Back to unlock codes'|trans }}
    </a>
{% endblock %}

{% block content %}
    <twig:Ui:Card>
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
            <div class="text-muted">
                {{ ux_icon('tabler:list-check', {width: 18, height: 18}) }}
                <strong>{{ found }}</strong> {{ 'of'|trans }} <strong>{{ total }}</strong> {{ 'IMEIs found'|trans }}
            </div>
            {% if found > 0 %}
                <button type="button" id="copy-all" class="btn btn-sm btn-outline-primary">
                    {{ ux_icon('tabler:copy', {width: 16, height: 16}) }} {{ 'Copy all'|trans }}
                </button>
            {% endif %}
        </div>

        {% if results is empty %}
            <div class="text-center py-4 text-muted">{{ 'No valid IMEIs were found in what you pasted. Please paste 15-digit IMEI numbers.'|trans }}</div>
        {% else %}
            <div class="table-responsive">
            <table class="table table-vcenter">
                <thead>
                    <tr>
                        <th>{{ 'IMEI'|trans }}</th>
                        <th>{{ 'Code'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in results %}
                        <tr>
                            <td class="text-nowrap"><code>{{ row.imei }}</code></td>
                            {% if row.code is null %}
                                <td class="text-danger">{{ 'Not found'|trans }}</td>
                            {% elseif row.code|trim == '' %}
                                <td class="text-muted">{{ 'No code on file'|trans }}</td>
                            {% else %}
                                <td class="fw-bold">{{ row.code }}</td>
                            {% endif %}
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            </div>

            <textarea id="copy-source" style="position:absolute; left:-9999px; top:-9999px;" readonly>{% for row in results %}{% if row.code is not null and row.code|trim != '' %}IMEI: {{ row.imei }} - Unlock Code: {{ row.code }}
{% endif %}{% endfor %}</textarea>
            <script>
                (function () {
                    var btn = document.getElementById('copy-all');
                    var src = document.getElementById('copy-source');
                    if (!btn || !src) { return; }
                    btn.addEventListener('click', function () {
                        var text = src.value.replace(/\n+$/, '');
                        var done = function () {
                            var original = btn.innerHTML;
                            btn.innerHTML = {{ 'Copied!'|trans|json_encode|raw }};
                            setTimeout(function () { btn.innerHTML = original; }, 1500);
                        };
                        if (navigator.clipboard && navigator.clipboard.writeText) {
                            navigator.clipboard.writeText(text).then(done, function () { src.select(); document.execCommand('copy'); done(); });
                        } else {
                            src.select();
                            document.execCommand('copy');
                            done();
                        }
                    });
                })();
            </script>
        {% endif %}
    </twig:Ui:Card>

    <div class="mt-3">
        <a href="{{ path('_unlock_list') }}" class="btn btn-link">{{ ux_icon('tabler:arrow-left', {width: 16, height: 16}) }} {{ 'Back to unlock codes'|trans }}</a>
    </div>
{% endblock content %}
