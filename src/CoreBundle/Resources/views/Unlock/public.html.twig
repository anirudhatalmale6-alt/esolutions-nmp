 # Public, no-login IMEI unlock-code lookup. Customer types an IMEI and gets the
 # code back - nothing else. Doubles as a minimal, mobile-first promo page for
 # NMP Mobiles (brand + sourcing note + carrier logos anchored at the bottom).
 # Self-contained (inline CSS/JS) so it renders anywhere the link is shared.
 #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex, nofollow">
    <title>{{ 'IMEI Unlock Code'|trans }} - {{ company.name }}</title>
    <style>
        :root { color-scheme: light; }
        * { box-sizing: border-box; }
        html, body { height: 100%; }
        body {
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: #f1f5f9;
            color: #1e293b;
            -webkit-font-smoothing: antialiased;
        }
        .wrap {
            max-width: 480px; margin: 0 auto; min-height: 100%;
            display: flex; flex-direction: column; padding: 24px 18px 28px;
        }

        /* Top: Powered by Unlocking Experts (UK) lockup */
        .powered-head { display: flex; align-items: center; justify-content: center; gap: 12px; padding: 6px 0 26px; }
        .powered-head img { height: 46px; width: auto; flex: none; }
        .powered-head .txt { text-align: left; line-height: 1.25; }
        .powered-head .txt .a { color: #94a3b8; font-size: 13px; }
        .powered-head .txt .b { color: #475569; font-size: 15px; font-weight: 700; }

        .card { background: #fff; border: 1px solid #e2e8f0; border-radius: 16px; padding: 22px; box-shadow: 0 1px 3px rgba(15,23,42,.06); }
        label { display: block; font-size: 13px; color: #475569; margin-bottom: 8px; font-weight: 600; }
        .row { display: flex; gap: 8px; }
        .search {
            flex: 1 1 auto; min-width: 0; padding: 13px 14px; font-size: 16px; border: 1px solid #cbd5e1;
            border-radius: 10px; background: #fff; color: #0f172a;
        }
        .search::placeholder { color: #cbd5e1; font-weight: 400; }
        .search:focus { outline: none; border-color: #4f46e5; box-shadow: 0 0 0 3px rgba(79,70,229,.15); }
        .btn {
            flex: none; padding: 13px 22px; font-size: 15px; font-weight: 600; border: none; border-radius: 10px;
            background: #4f46e5; color: #fff; cursor: pointer; white-space: nowrap;
        }
        .btn:hover { background: #4338ca; }

        .result { margin-top: 20px; }
        .result-imei { font-size: 12px; color: #64748b; text-transform: uppercase; letter-spacing: .5px; }
        .code-box {
            margin-top: 8px; background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 12px;
            padding: 20px; text-align: center;
        }
        .code-box .code {
            font-size: 26px; font-weight: 800; letter-spacing: 1px; color: #166534; word-break: break-all;
            font-variant-numeric: tabular-nums;
        }
        .code-box .copy {
            margin-top: 12px; padding: 8px 18px; font-size: 13px; font-weight: 600; border: 1px solid #16a34a;
            background: #fff; color: #16a34a; border-radius: 8px; cursor: pointer;
        }
        .status-box {
            margin-top: 8px; background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 12px;
            padding: 18px; text-align: center; color: #1e40af; font-weight: 600; font-size: 16px;
        }
        .notfound-box {
            margin-top: 8px; background: #fef2f2; border: 1px solid #fecaca; border-radius: 12px;
            padding: 18px; text-align: center; color: #b91c1c; font-weight: 600;
        }
        .notfound-box .hint { font-weight: 400; color: #7f1d1d; font-size: 13px; margin-top: 6px; }
        .notfound-box .hint a { color: #b91c1c; font-weight: 600; }
        .tip { text-align: center; color: #94a3b8; font-size: 12px; margin-top: 16px; }

        .support { text-align: center; margin-top: 20px; color: #475569; font-size: 15px; }
        .support a { color: #2563eb; text-decoration: none; font-weight: 700; }
        .support a:hover { text-decoration: underline; }

        /* Spacer pushes the brand footer to the bottom of the screen */
        .spacer { flex: 1 1 auto; min-height: 40px; }

        /* Bottom: NMP brand + sourcing note + carrier logos */
        .brand-foot { text-align: center; padding-top: 8px; }
        .brand-foot .name { font-size: 26px; font-weight: 800; color: #0f172a; letter-spacing: .5px; }
        .brand-foot .about {
            margin: 12px auto 0; max-width: 420px; color: #475569; font-size: 13.5px; line-height: 1.6;
        }
        .carriers {
            margin-top: 22px; display: flex; align-items: center; justify-content: center;
            flex-wrap: wrap; gap: 12px 16px;
        }
        .carriers img { display: block; width: auto; opacity: .9; }
        .carriers img.au { height: 21px; }
        .carriers img.docomo { height: 18px; }
        .carriers img.softbank { height: 15px; }
        .carriers img.att { height: 20px; }
    </style>
</head>
<body>
    <div class="wrap">
        <div class="powered-head">
            <img src="{{ asset('images/unlocking-experts.png') }}" alt="Unlocking Experts (UK)">
            <div class="txt">
                <div class="a">{{ 'Powered by'|trans }}</div>
                <div class="b">{{ 'Unlocking Experts (UK)'|trans }}</div>
            </div>
        </div>

        <div class="card">
            <form method="get" action="{{ path('_unlock_public') }}">
                <label for="imei">{{ 'Enter your IMEI'|trans }}</label>
                <div class="row">
                    <input type="text" id="imei" name="imei" class="search" inputmode="numeric" autocomplete="off"
                           placeholder="{{ 'e.g. 352271081715071'|trans }}" value="{{ imei }}" autofocus>
                    <button type="submit" class="btn">{{ 'Get code'|trans }}</button>
                </div>
            </form>

            {% if searched %}
                <div class="result">
                    <div class="result-imei">{{ 'IMEI'|trans }}: {{ imei }}</div>
                    {% if result is null %}
                        <div class="notfound-box">
                            {{ 'No code found for this IMEI.'|trans }}
                            <div class="hint">
                                {{ 'Please check the number and try again, or'|trans }}
                                <a href="{{ whatsappUrl }}" target="_blank" rel="noopener">{{ 'chat with us'|trans }}</a>.
                            </div>
                        </div>
                    {% elseif result.code|trim == '' %}
                        <div class="status-box">{{ 'This IMEI is on file, but no unlock code is available for it yet.'|trans }}</div>
                    {% elseif result.code matches '/^\\d+$/' %}
                        <div class="code-box">
                            <div class="code" id="unlock-code" data-imei="{{ imei }}">{{ result.code }}</div>
                            <button type="button" class="copy" id="copy-code">{{ 'Copy'|trans }}</button>
                        </div>
                    {% else %}
                        <div class="status-box">{{ result.code }}</div>
                    {% endif %}
                </div>
            {% else %}
                <div class="tip">{{ 'Type the 15-digit IMEI and tap "Get code".'|trans }}</div>
            {% endif %}
        </div>

        <div class="support">
            {{ 'Need support?'|trans }}
            <a href="{{ whatsappUrl }}" target="_blank" rel="noopener">{{ 'Click here to chat'|trans }}</a>
        </div>

        <div class="spacer"></div>

        <div class="brand-foot">
            <div class="name">{{ 'NMP MOBILES'|trans }}</div>
            <div class="about">
                {{ 'Global supply sourcing of top-tier, Japan-spec and international mobile phones, direct from the world\'s leading tech hubs: Japan, HK, Korea, USA & UK.'|trans }}
            </div>
            <div class="carriers">
                <img class="au" src="{{ asset('images/carrier-au.svg') }}" alt="au">
                <img class="docomo" src="{{ asset('images/carrier-docomo.png') }}" alt="NTT docomo">
                <img class="softbank" src="{{ asset('images/carrier-softbank.png') }}" alt="SoftBank">
                <img class="att" src="{{ asset('images/carrier-att.svg') }}" alt="AT&amp;T">
            </div>
        </div>
    </div>

    <script>
        (function () {
            var btn = document.getElementById('copy-code');
            var code = document.getElementById('unlock-code');
            if (!btn || !code) { return; }
            btn.addEventListener('click', function () {
                var imei = code.getAttribute('data-imei') || '';
                var text = 'IMEI: ' + imei + '\nUnlock Code: ' + code.textContent.trim();
                var done = function () {
                    var original = btn.textContent;
                    btn.textContent = {{ 'Copied!'|trans|json_encode|raw }};
                    setTimeout(function () { btn.textContent = original; }, 1500);
                };
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(text).then(done, done);
                } else {
                    done();
                }
            });
        })();
    </script>
</body>
</html>
