 #
 # Public, no-login IMEI unlock-code lookup. Customer types an IMEI and gets the
 # code back - nothing else. Doubles as a minimal, mobile-first promo page for
 # NMP Mobiles. Self-contained (inline CSS/JS) so it renders anywhere the link is
 # shared.
 #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex, nofollow">
    <title>{{ 'IMEI Unlock Code'|trans }} - {{ company.name }}</title>
    <style>
        :root { color-scheme: light; }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: #f1f5f9;
            color: #1e293b;
            -webkit-font-smoothing: antialiased;
        }
        .wrap { max-width: 480px; margin: 0 auto; padding: 34px 18px 48px; }

        .head { text-align: center; padding: 4px 0 22px; }
        .head .logo { height: 56px; width: auto; }
        .head .sub {
            margin-top: 12px; color: #64748b; font-size: 13px; font-weight: 600;
            text-transform: uppercase; letter-spacing: 1.4px;
        }

        .card { background: #fff; border: 1px solid #e2e8f0; border-radius: 16px; padding: 22px; box-shadow: 0 1px 3px rgba(15,23,42,.06); }
        label { display: block; font-size: 13px; color: #475569; margin-bottom: 8px; font-weight: 600; }
        .row { display: flex; gap: 8px; }
        .search {
            flex: 1 1 auto; min-width: 0; padding: 13px 14px; font-size: 16px; border: 1px solid #cbd5e1;
            border-radius: 10px; background: #fff; color: #0f172a;
        }
        .search::placeholder { color: #cbd5e1; font-weight: 400; }
        .search:focus { outline: none; border-color: #4f46e5; box-shadow: 0 0 0 3px rgba(79,70,229,.15); }
        .btn {
            flex: none; padding: 13px 22px; font-size: 15px; font-weight: 600; border: none; border-radius: 10px;
            background: #4f46e5; color: #fff; cursor: pointer; white-space: nowrap;
        }
        .btn:hover { background: #4338ca; }

        .result { margin-top: 20px; }
        .result-imei { font-size: 12px; color: #64748b; text-transform: uppercase; letter-spacing: .5px; }
        .code-box {
            margin-top: 8px; background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 12px;
            padding: 20px; text-align: center;
        }
        .code-box .code {
            font-size: 26px; font-weight: 800; letter-spacing: 1px; color: #166534; word-break: break-all;
            font-variant-numeric: tabular-nums;
        }
        .code-box .copy {
            margin-top: 12px; padding: 8px 18px; font-size: 13px; font-weight: 600; border: 1px solid #16a34a;
            background: #fff; color: #16a34a; border-radius: 8px; cursor: pointer;
        }
        .status-box {
            margin-top: 8px; background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 12px;
            padding: 18px; text-align: center; color: #1e40af; font-weight: 600; font-size: 16px;
        }
        .notfound-box {
            margin-top: 8px; background: #fef2f2; border: 1px solid #fecaca; border-radius: 12px;
            padding: 18px; text-align: center; color: #b91c1c; font-weight: 600;
        }
        .notfound-box .hint { font-weight: 400; color: #7f1d1d; font-size: 13px; margin-top: 6px; }
        .notfound-box .hint a { color: #b91c1c; font-weight: 600; }
        .tip { text-align: center; color: #94a3b8; font-size: 12px; margin-top: 16px; }

        .contact { text-align: center; margin-top: 22px; color: #475569; font-size: 14px; }
        .wa-link {
            display: inline-flex; align-items: center; gap: 6px; margin-left: 4px; padding: 7px 15px;
            border-radius: 999px; background: #25d366; color: #fff; text-decoration: none; font-weight: 600;
        }
        .wa-link:hover { background: #1ebe5b; }

        /* Minimal business / promo block */
        .promo {
            margin-top: 28px; background: #fff; border: 1px solid #e2e8f0; border-radius: 16px;
            padding: 22px; text-align: center;
        }
        .promo .tagline { font-size: 14px; line-height: 1.55; color: #334155; }
        .promo .hubs {
            margin-top: 12px; font-size: 12px; color: #64748b; font-weight: 600;
            letter-spacing: .3px;
        }
        .promo .hubs b { color: #4f46e5; font-weight: 700; }
        .promo .divider { height: 1px; background: #eef2f7; margin: 18px 0; }
        .promo .biz-name { font-weight: 700; color: #0f172a; font-size: 15px; letter-spacing: .3px; }
        .promo .biz-line { color: #64748b; font-size: 13px; margin-top: 4px; }
        .promo a.web { color: #4f46e5; text-decoration: none; font-weight: 600; }
        .promo a.web:hover { text-decoration: underline; }
        .promo .phones { margin-top: 10px; font-size: 13px; color: #475569; line-height: 1.9; }
        .promo .phones a { color: #475569; text-decoration: none; }
        .promo .phones .lbl { color: #94a3b8; }
        .promo .phones .ph { white-space: nowrap; display: inline-block; }
        .promo .phones .sep { color: #cbd5e1; margin: 0 6px; }

        .powered { text-align: center; margin-top: 26px; }
        .powered-logo { width: 84px; height: auto; opacity: .9; }
        .powered-text { color: #94a3b8; font-size: 12px; margin-top: 6px; letter-spacing: .3px; }

        @media (max-width: 400px) {
            .row { flex-direction: column; }
            .btn { width: 100%; }
        }
    </style>
</head>
<body>
    <div class="wrap">
        <div class="head">
            <img src="{{ asset('images/nmp-logo.png') }}" alt="{{ company.name }}" class="logo">
            <div class="sub">{{ 'SIM Unlock Code Lookup'|trans }}</div>
        </div>

        <div class="card">
            <form method="get" action="{{ path('_unlock_public') }}">
                <label for="imei">{{ 'Enter your IMEI'|trans }}</label>
                <div class="row">
                    <input type="text" id="imei" name="imei" class="search" inputmode="numeric" autocomplete="off"
                           placeholder="{{ 'e.g. 352271081715071'|trans }}" value="{{ imei }}" autofocus>
                    <button type="submit" class="btn">{{ 'Get code'|trans }}</button>
                </div>
            </form>

            {% if searched %}
                <div class="result">
                    <div class="result-imei">{{ 'IMEI'|trans }}: {{ imei }}</div>
                    {% if result is null %}
                        <div class="notfound-box">
                            {{ 'No code found for this IMEI.'|trans }}
                            <div class="hint">
                                {{ 'Please check the number and try again, or'|trans }}
                                <a href="{{ whatsappUrl }}" target="_blank" rel="noopener">{{ 'contact us on WhatsApp'|trans }}</a>.
                            </div>
                        </div>
                    {% elseif result.code|trim == '' %}
                        <div class="status-box">{{ 'This IMEI is on file, but no unlock code is available for it yet.'|trans }}</div>
                    {% elseif result.code matches '/^\\d+$/' %}
                        <div class="code-box">
                            <div class="code" id="unlock-code" data-imei="{{ imei }}">{{ result.code }}</div>
                            <button type="button" class="copy" id="copy-code">{{ 'Copy'|trans }}</button>
                        </div>
                    {% else %}
                        <div class="status-box">{{ result.code }}</div>
                    {% endif %}
                </div>
            {% else %}
                <div class="tip">{{ 'Type the 15-digit IMEI and tap "Get code".'|trans }}</div>
            {% endif %}
        </div>

        <div class="contact">
            {{ 'Need help?'|trans }}
            <a href="{{ whatsappUrl }}" target="_blank" rel="noopener" class="wa-link">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M12.04 2c-5.46 0-9.9 4.44-9.9 9.9 0 1.75.46 3.45 1.32 4.95L2 22l5.3-1.38a9.9 9.9 0 0 0 4.73 1.2h.01c5.46 0 9.9-4.44 9.9-9.9 0-2.64-1.03-5.13-2.9-7A9.82 9.82 0 0 0 12.04 2Zm5.8 14.16c-.24.68-1.42 1.32-1.95 1.36-.5.04-.96.22-3.23-.67-2.73-1.08-4.45-3.86-4.58-4.04-.13-.18-1.1-1.46-1.1-2.78 0-1.32.7-1.97.94-2.24.24-.27.53-.34.7-.34.18 0 .35 0 .5.01.16.01.38-.06.6.46.23.53.77 1.85.84 1.98.07.13.11.29.02.47-.09.18-.13.29-.27.44-.13.16-.28.35-.4.47-.13.13-.27.28-.12.54.16.27.7 1.15 1.5 1.86 1.04.92 1.9 1.2 2.17 1.34.27.13.42.11.58-.07.16-.18.67-.78.85-1.05.18-.27.35-.22.6-.13.24.09 1.54.72 1.8.86.27.13.44.2.5.31.07.11.07.63-.17 1.31Z"/></svg>
                {{ 'Chat with us on WhatsApp'|trans }}
            </a>
        </div>

        <div class="promo">
            <div class="tagline">
                {{ 'Sourcing top-tier Japan-spec & international phones, direct from the world\'s leading tech hubs.'|trans }}
            </div>
            <div class="hubs"><b>Japan</b> · <b>Hong Kong</b> · <b>USA</b> · <b>UK</b></div>
            <div class="divider"></div>
            <div class="biz-name">{{ 'NMP MOBILES'|trans }}</div>
            <div class="biz-line">{{ 'Deira, Dubai · United Arab Emirates'|trans }}</div>
            <div class="biz-line"><a class="web" href="https://mobilesonline.ae" target="_blank" rel="noopener">mobilesonline.ae</a></div>
            <div class="phones">
                <span class="ph"><span class="lbl">{{ 'UAE'|trans }}</span> <a href="tel:+971585678669">+971 5856 78669</a></span><span class="sep">·</span><span class="ph"><span class="lbl">{{ 'Hong Kong'|trans }}</span> <a href="tel:+85292934004">+852 9293 4004</a></span>
            </div>
        </div>

        <div class="powered">
            <img src="{{ asset('images/unlocking-experts.png') }}" alt="Unlocking Experts (UK)" class="powered-logo">
            <div class="powered-text">{{ 'Powered by Unlocking Experts (UK)'|trans }}</div>
        </div>
    </div>

    <script>
        (function () {
            var btn = document.getElementById('copy-code');
            var code = document.getElementById('unlock-code');
            if (!btn || !code) { return; }
            btn.addEventListener('click', function () {
                var imei = code.getAttribute('data-imei') || '';
                var text = 'IMEI: ' + imei + '\nUnlock Code: ' + code.textContent.trim();
                var done = function () {
                    var original = btn.textContent;
                    btn.textContent = {{ 'Copied!'|trans|json_encode|raw }};
                    setTimeout(function () { btn.textContent = original; }, 1500);
                };
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(text).then(done, done);
                } else {
                    done();
                }
            });
        })();
    </script>
</body>
</html>
