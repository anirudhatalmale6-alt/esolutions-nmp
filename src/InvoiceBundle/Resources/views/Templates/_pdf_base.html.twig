 # Base layout for all PDF templates. Provides watermark, page footer, and
 # the standard pdf.css import. Templates extend this and override
 # `body` and (optionally) `extra_styles` and `body_attrs`.
 #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8" />
    <style type="text/css">
        {{ file(asset('static/pdf.css')) }}

        @page {
            margin-top: 20mm;
            margin-bottom: 25mm;
            margin-left: 15mm;
            margin-right: 15mm;
            footer: footer;
        }

        {% block extra_styles %}{% endblock %}
    </style>
</head>
<body{% block body_attrs %}{% endblock %}>

{% if false %}{# status watermark removed per client request #}
    <watermarktext content="{{ invoice.status.value|upper }}" alpha="0.08"/>
{% endif %}

{# Suppression of "Powered by" only takes effect when the `custom_branding` feature is on
   for the current plan; without it, we render the line regardless of the stored value. #}
{% set hide_powered_by = true %}
<pagefooter
    name="footer"
    content-left=""
    content-right="{{ 'pdf.page'|trans }} {PAGENO} {{ 'pdf.of'|trans }} {nb}"
    line="on"
    footer-style="border-top: 1px solid #e2e8f0; font-size: 8pt; color: #64748b; padding-top: 8px;"
/>

{% block body %}{% endblock %}
</body>
</html>
