{% set footerSpan = invoice.tax.positive ? 4 : 3 %}

<div class="{{ containerClass is defined ? containerClass : 'widget' }}" id="invoice-create">
    <div class="invoice">
        <div class="card-body">
            {% block header %}

                <div class="col-12">
                    {% block title %}
                        <h2 class="page-header">
                            {{ "invoice.title"|trans({"%id%" : invoice.invoiceId}) }} {{ invoice_label(invoice.status) }}
                        </h2>
                    {% endblock %}
                    <div class="row invoice-info">
                        <div class="col-sm-4 invoice-col">
                            From:
                            <h4>{{ company_name() }}</h4>

                            {% for identifier in tax_identifiers() %}
                                <p>
                                    <strong>{{ identifier.label }}</strong> {{ identifier.value }}
                                </p>
                            {% endfor %}

                            {% set email = setting('system/company/contact_details/email') %}
                            {% if email is not empty %}
                                <p>
                                    {{ icon('envelope-o') }} {{ email }}
                                </p>
                            {% endif %}

                            {% set phoneNumber = setting('system/company/contact_details/phone_number') %}
                            {% if phoneNumber is not empty %}
                                <p>
                                    {{ icon('phone') }} {{ phoneNumber }}
                                </p>
                            {% endif %}

                            {% set address = setting('system/company/contact_details/address', null, true) %}
                            {% if address is not null and address|filter(v => v) is not empty %}
                                <address>
                                    {{ icon('map-marker') }} {{ address(address)|replace({"\n": ", "}) }}
                                </address>
                            {% endif %}
                        </div>
                        <div class="col-sm-4 invoice-col">
                            To:
                            <h4>{{ invoice.client }}</h4>
                            {% if invoice.client.website is not empty %}
                                <p>
                                    <a href="{{ invoice.client.website }}" rel="external" target="_blank">
                                        {{ invoice.client.website }}
                                    </a>
                                </p>
                            {% endif %}

                            {% for identifier in tax_identifiers(invoice.client) %}
                                <p>
                                    <strong>{{ identifier.label }}</strong> {{ identifier.value }}
                                </p>
                            {% endfor %}

                            {% for address in invoice.client.addresses %}
                                <address>
                                    {{ icon('map-marker') }} {{ address|replace({"\n": ", "}) }}<br/>
                                </address>
                            {% endfor %}
                            <p>
                                {% for user in invoice.users %}
                                    <address class="col-6">
                                        <strong>{{ user }}</strong><br/>
                                        {{ icon('envelope-o') }} {{ 'email'|trans }}: {{ user.email }}<br/>
                                    </address>
                                {% endfor %}
                            </p>
                        </div>
                        <div class="col-sm-2 invoice-col">
                            <dl class="dl-horizontal">
                                <dt>{{ "invoice.title"|trans({"%id%" : ''}) }}</dt>
                                <dd>{{ invoice.invoiceId ?? invoice.id }}</dd>
                                <dt>{{ "invoice.total"|trans }}</dt>
                                <dd>{{ invoice.total|formatCurrency(invoice.client.currency) }}</dd>
                            </dl>
                        </div>
                        {% if isRecurring is not defined or isRecurring is same as(false) %}
                            <div class="col-sm-2 invoice-col">
                                <dl class="dl-horizontal">
                                    <dt>{{ "Invoice Date"|trans }}</dt>
                                    <dd>{{ invoice.invoiceDate | date('d F Y') }}</dd>
                                    {% if invoice.due is not empty %}
                                        <dt>{{ "Due Date"|trans }}</dt>
                                        <dd>{{ invoice.due | date('d F Y') }}</dd>
                                    {% endif %}
                                </dl>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endblock %}

            {% block content %}
                <div class="col-12">
                    <div class="table-responsive">
                        <table id="invoice-rows" class="table table-condensed">
                            <thead>
                            <tr>
                                <th>{{ 'invoice.item.heading.description'|trans }}</th>
                                <th>{{ 'invoice.item.heading.price'|trans }}</th>
                                <th>{{ 'invoice.item.heading.qty'|trans }}</th>
                                {% if invoice.tax.positive %}
                                    <th>{{ 'invoice.item.heading.tax'|trans }}</th>
                                {% endif %}
                                <th class="text-right">{{ 'invoice.item.heading.total'|trans }}</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for item in invoice.lines %}
                                <tr>
                                    <td class="column-description">
                                        {{ item.description|nl2br }}
                                    </td>
                                    <td class="column-price">
                                        {{ item.price|formatCurrency(invoice.client.currency) }}
                                    </td>
                                    <td class="column-qty">
                                        {{ item.qty }}
                                    </td>
                                    {% if invoice.tax.positive %}
                                        <td class="column-tax">
                                            {% for lineTax in item.taxes %}{{ lineTax.nameSnapshot }} ({{ lineTax.rateSnapshot }}%){% if not loop.last %}, {% endif %}{% endfor %}
                                        </td>
                                    {% endif %}
                                    <td class="column-total text-right">
                                        {{ item.total|formatCurrency(invoice.client.currency) }}
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                            <tfoot>
                            <tr>
                                <td colspan="{{ footerSpan }}" class="thick-line text-right">
                                    <strong>{{ 'invoice.subtotal'|trans }}</strong>
                                </td>
                                <td class="thick-line text-right">
                                    <div class="invoice-sub-total">
                                        {{ invoice.baseTotal|formatCurrency(invoice.client.currency) }}
                                    </div>
                                </td>
                            </tr>
                            {% set _tb = tax_breakdown(invoice) %}
                            {% if invoice.tax.positive %}
                                <tr>
                                    <td colspan="{{ footerSpan }}" class="no-line text-right">
                                        <strong>{{ 'invoice.line_tax'|trans }}</strong>
                                    </td>
                                    <td class="no-line text-right">
                                        <span class="text-error invoice-tax">
                                            {{ invoice.tax|formatCurrency(invoice.client.currency) }}
                                        </span>
                                    </td>
                                </tr>
                                {% for row in _tb.lineTaxRows %}
                                    <tr>
                                        <td colspan="{{ footerSpan }}" class="no-line text-right text-muted">
                                            {{ row.name }} ({{ row.rate }}%)
                                        </td>
                                        <td class="no-line text-right text-muted">
                                            {{ row.amount|formatCurrency(invoice.client.currency) }}
                                        </td>
                                    </tr>
                                {% endfor %}
                            {% endif %}
                            {% for row in _tb.additiveRows %}
                                <tr>
                                    <td colspan="{{ footerSpan }}" class="no-line text-right">
                                        <strong>{{ row.name }} ({{ row.rate }}%)</strong>
                                    </td>
                                    <td class="no-line text-right">
                                        {{ row.amount|formatCurrency(invoice.client.currency) }}
                                    </td>
                                </tr>
                            {% endfor %}
                            {% for row in _tb.informationalRows %}
                                <tr>
                                    <td colspan="{{ footerSpan }}" class="no-line text-right text-muted">
                                        {{ row.name }} ({{ row.rate }}%){% if row.note %} — {{ row.note }}{% endif %}
                                    </td>
                                    <td class="no-line text-right text-muted">
                                        {{ 'invoice.invoice_taxes.informational'|trans }}
                                    </td>
                                </tr>
                            {% endfor %}

                            {% if invoice.hasDiscount %}
                                <tr>
                                    <td colspan="{{ footerSpan }}" class="no-line text-right">
                                        <strong>{{ 'invoice.discount'|trans }}</strong>
                                    </td>
                                    <td class="no-line text-right">
                                        <span class="text-danger invoice-discount">
                                            -{{ discount(invoice)|formatCurrency(invoice.client.currency) }}
                                        </span>
                                    </td>
                                </tr>
                            {% endif %}
                            {% set paid = 0 %}
                            {% if (isRecurring is not defined or isRecurring is same as(false)) and invoice.payments|length > 0 and not invoice.balance.isZero %}
                                {% for payment in invoice.payments|filter((v) => v.status == enum('SolidInvoice\\PaymentBundle\\Enum\\PaymentStatus').Captured) %}
                                    <tr>
                                        <td colspan="{{ footerSpan }}" class="no-line text-right">
                                            <strong>
                                                Payment:
                                            </strong>
                                            {{ payment.method.name }}
                                        </td>
                                        <td class="no-line text-right">
                                            <div class="text-danger invoice-total">
                                                -{{ payment.amount.amount|formatCurrency(invoice.client.currency) }}
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            {% endif %}
                            <tr>
                                <td colspan="{{ footerSpan }}" class="no-line text-right">
                                    <strong>
                                        {% if invoice.payments is defined and invoice.payments|length > 0 and not invoice.balance.isZero %}
                                            {{ 'invoice.balance'|trans }}
                                        {% else %}
                                            {{ 'invoice.total'|trans }}
                                        {% endif %}
                                    </strong>
                                </td>
                                <td class="no-line text-right">
                                    <div class="invoice-total">
                                        {% if invoice.payments is defined and invoice.payments|length > 0 and not invoice.balance.isZero %}
                                            {{ invoice.balance|formatCurrency(invoice.client.currency) }}
                                        {% else %}
                                            {{ invoice.total|formatCurrency(invoice.client.currency) }}
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                            {% if invoice.withholdingAmount.positive %}
                                <tr>
                                    <td colspan="{{ footerSpan }}" class="no-line text-right">
                                        <strong>{{ 'invoice.withholding'|trans }}</strong>
                                    </td>
                                    <td class="no-line text-right">
                                        -{{ invoice.withholdingAmount|formatCurrency(invoice.client.currency) }}
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="{{ footerSpan }}" class="no-line text-right">
                                        <strong>{{ 'invoice.amount_payable'|trans }}</strong>
                                    </td>
                                    <td class="no-line text-right">
                                        <div class="invoice-total">
                                            {{ payable_amount(invoice)|formatCurrency(invoice.client.currency) }}
                                        </div>
                                    </td>
                                </tr>
                            {% endif %}
                            </tfoot>
                        </table>
                    </div>
                </div>
            {% endblock %}

            {% block footer %}
                {% if invoice.terms is not empty %}
                    <div class="col-6">
                        <strong>{{ 'invoice.terms'|trans }}</strong>
                        <p class="text-muted well well-sm no-shadow">
                            {{ invoice.terms|nl2br }}
                        </p>
                    </div>
                {% endif %}
            {% endblock %}
        </div>
    </div>
</div>
