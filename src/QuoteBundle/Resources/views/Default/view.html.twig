{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% block page_title %}
    {{ "quote.title"|trans({"%id%" : quote.quoteId}) }}
{% endblock page_title %}

{% block content %}
{% set currency = quote.client.currency %}
<div class="doc-view-page">
    {# ═══════════════════════════════════════════════════════════════════════
       PAGE HEADER - Quote Title, Status, and Actions
    ═══════════════════════════════════════════════════════════════════════ #}
    <div class="doc-view-header no-print">
        <div class="doc-view-header-left">
            <div class="doc-view-icon">
                {{ ux_icon('tabler:file-text', {width: 32, height: 32}) }}
            </div>
            <div class="doc-view-title-group">
                <h1 class="doc-view-title">{{ "quote.title"|trans({"%id%" : quote.quoteId}) }}</h1>
                <div class="doc-view-meta">
                    {{ quote_label(quote.status) }}
                    <span class="doc-view-meta-item">
                        {{ ux_icon('tabler:calendar', {width: 14, height: 14}) }}
                        {{ 'quote.created'|trans }}: {{ quote.created|date('M d, Y') }}
                    </span>
                </div>
            </div>
        </div>

        <div class="doc-view-header-actions">
            {# Always available actions #}
            <div class="doc-view-utility-actions">
                <button type="button" onclick="window.print()" class="btn btn-ghost btn-icon" title="{{ 'quote.action.print'|trans }}">
                    {{ ux_icon('tabler:printer', {width: 20, height: 20}) }}
                </button>
                {% if can_print_pdf() %}
                    <a href="{{ path('_quotes_view', {'id': quote.id, '_format': 'pdf'}) }}" target="_blank" class="btn btn-ghost btn-icon" title="{{ 'quote.action.pdf'|trans }}">
                        {{ ux_icon('tabler:file-type-pdf', {width: 20, height: 20}) }}
                    </a>
                {% endif %}

                {# WhatsApp Share Button - opens WhatsApp with the quote details pre-filled;
                   the sender picks the recipient contact in WhatsApp #}
                {% set wa_text = 'Quote ' ~ quote.quoteId ~ ' - Total: ' ~ quote.total|formatCurrency(currency) ~ ' - View: ' ~ url('_quotes_view', {'id': quote.id}) %}
                <a href="https://wa.me/?text={{ wa_text|url_encode }}" target="_blank" class="btn btn-ghost btn-icon" title="Share on WhatsApp" style="color: #25D366;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                </a>

                {# More Actions Dropdown #}
                <div class="dropdown">
                    <button class="btn btn-ghost btn-icon" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="{{ 'quote.view.toolbar.more_actions'|trans }}">
                        {{ ux_icon('tabler:dots-vertical', {width: 20, height: 20}) }}
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        {% if quote.invoice is not null %}
                            <li>
                                <a class="dropdown-item" href="{{ path('_invoices_view', {'id' : quote.invoice.id}) }}">
                                    {{ ux_icon('tabler:file-invoice', {width: 16, height: 16}) }}
                                    {{ "quote.view.toolbar.view_invoice"|trans }}
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                        {% endif %}

                        <li>
                            <a class="dropdown-item" href="{{ path('_quotes_clone', {'id' : quote.id}) }}">
                                {{ ux_icon('tabler:copy', {width: 16, height: 16}) }}
                                {{ "quote.view.toolbar.clone"|trans }}
                            </a>
                        </li>

                        {% if quote.status != enum('SolidInvoice\\QuoteBundle\\Enum\\QuoteStatus').Accepted %}
                            <li>
                                <a class="dropdown-item" href="{{ path('_quotes_edit', {'id' : quote.id}) }}">
                                    {{ ux_icon('tabler:pencil', {width: 16, height: 16}) }}
                                    {{ "quote.view.toolbar.edit"|trans }}
                                </a>
                            </li>
                        {% endif %}

                        {% if workflow_can(quote, 'reopen') %}
                            <li>
                                <a class="dropdown-item" href="{{ path('_transition_quote', {'action': 'reopen', 'id' : quote.id}) }}">
                                    {{ ux_icon('tabler:refresh', {width: 16, height: 16}) }}
                                    {{ "quote.view.toolbar.reopen"|trans }}
                                </a>
                            </li>
                        {% endif %}

                        {% if workflow_can(quote, 'archive') %}
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item" href="{{ path('_transition_quote', {'action' : 'archive', 'id' : quote.id}) }}">
                                    {{ ux_icon('tabler:archive', {width: 16, height: 16}) }}
                                    {{ "quote.view.toolbar.archive"|trans }}
                                </a>
                            </li>
                        {% endif %}

                        {% if workflow_can(quote, 'cancel') %}
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item text-danger" href="{{ path('_transition_quote', {'action': 'cancel', 'id' : quote.id}) }}">
                                    {{ ux_icon('tabler:x', {width: 16, height: 16}) }}
                                    {{ "quote.view.toolbar.cancel"|trans }}
                                </a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>

            {# Hero Actions - Changes based on quote state #}
            {% if workflow_can(quote, 'accept') %}
                {# Pending state: Accept + Decline buttons #}
                <a href="{{ path('_transition_quote', {'action': 'decline', 'id' : quote.id}) }}" class="btn btn-outline-danger">
                    {{ ux_icon('tabler:x', {width: 18, height: 18}) }}
                    {{ "quote.view.toolbar.decline"|trans }}
                </a>
                <a href="{{ path('_transition_quote', {'action' : 'accept', 'id' : quote.id}) }}" class="btn btn-success btn-hero">
                    {{ ux_icon('tabler:check', {width: 18, height: 18}) }}
                    {{ "quote.view.toolbar.accept"|trans }}
                </a>
                {% if is_email_verification_gated() %}
                    <span class="d-inline-block" tabindex="0"
                          data-bs-toggle="tooltip"
                          title="{{ email_verification_message('sending this quote') }}">
                        <button type="button" class="btn btn-primary btn-hero disabled" disabled style="pointer-events: none;">
                            {{ ux_icon('tabler:send', {width: 18, height: 18}) }}
                            {{ "quote.view.toolbar.send"|trans }}
                        </button>
                    </span>
                {% else %}
                    <a href="{{ path('_send_quote', {'id' : quote.id}) }}" class="btn btn-primary btn-hero">
                        {{ ux_icon('tabler:send', {width: 18, height: 18}) }}
                        {{ "quote.view.toolbar.send"|trans }}
                    </a>
                {% endif %}
            {% elseif workflow_can(quote, 'publish') %}
                {# Draft state: Publish button #}
                <div class="btn-group">
                    <a href="{{ path('_transition_quote', {'action' : 'publish', 'id' : quote.id}) }}" class="btn btn-primary btn-hero">
                        {{ ux_icon('tabler:check', {width: 18, height: 18}) }}
                        {{ 'quote.save.publish'|trans }}
                    </a>
                    <button type="button" class="btn btn-primary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
                        <span class="visually-hidden">{{ 'quote.view.toolbar.toggle_dropdown'|trans }}</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            {% if is_email_verification_gated() %}
                                <span class="d-block" tabindex="0"
                                      data-bs-toggle="tooltip"
                                      title="{{ email_verification_message('sending this quote') }}">
                                    <button type="button" class="dropdown-item disabled" disabled style="pointer-events: none;">
                                        {{ ux_icon('tabler:send', {width: 16, height: 16}) }}
                                        {{ 'quote.view.toolbar.publish_and_send'|trans }}
                                    </button>
                                </span>
                            {% else %}
                                <a class="dropdown-item" href="{{ path('_send_quote', {'id' : quote.id}) }}">
                                    {{ ux_icon('tabler:send', {width: 16, height: 16}) }}
                                    {{ 'quote.view.toolbar.publish_and_send'|trans }}
                                </a>
                            {% endif %}
                        </li>
                    </ul>
                </div>
            {% elseif quote.status == enum('SolidInvoice\\QuoteBundle\\Enum\\QuoteStatus').Accepted and quote.invoice is not null %}
                {# Accepted: View Invoice button #}
                <a href="{{ path('_invoices_view', {'id' : quote.invoice.id}) }}" class="btn btn-primary btn-hero">
                    {{ ux_icon('tabler:file-invoice', {width: 18, height: 18}) }}
                    {{ "quote.view.toolbar.view_invoice"|trans }}
                </a>
            {% endif %}
        </div>
    </div>

    {# ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT - Quote Document + Sidebar
    ═══════════════════════════════════════════════════════════════════════ #}
    <div class="doc-view-content">
        {# Quote Document (Main Area) #}
        <div class="doc-view-document">
            <div class="doc-card">
                {# Document Header - From/To #}
                <div class="doc-header-from-to">
                    <div class="doc-party doc-party-from">
                        <div class="doc-party-label">{{ 'quote.from'|trans }}</div>
                        <h3 class="doc-party-name">{{ company_name() }}</h3>

                        {% for identifier in tax_identifiers() %}
                            <div class="doc-party-detail">
                                <span class="detail-label">{{ identifier.label }}</span>
                                <span class="detail-value">{{ identifier.value }}</span>
                            </div>
                        {% endfor %}

                        {% set email = setting('system/company/contact_details/email') %}
                        {% if email is not empty %}
                            <div class="doc-party-detail">
                                {{ ux_icon('tabler:mail', {width: 14, height: 14}) }}
                                <span class="detail-value">{{ email }}</span>
                            </div>
                        {% endif %}

                        {% set phoneNumber = setting('system/company/contact_details/phone_number') %}
                        {% if phoneNumber is not empty %}
                            <div class="doc-party-detail">
                                {{ ux_icon('tabler:phone', {width: 14, height: 14}) }}
                                <span class="detail-value">{{ phoneNumber }}</span>
                            </div>
                        {% endif %}

                        {% set address = setting('system/company/contact_details/address', null, true) %}
                        {% if address is not null and address|filter(v => v) is not empty %}
                            <div class="doc-party-detail">
                                {{ ux_icon('tabler:map-pin', {width: 14, height: 14}) }}
                                <span class="detail-value">{{ address(address)|replace({"\n": ", "}) }}</span>
                            </div>
                        {% endif %}
                    </div>

                    <div class="doc-party doc-party-to">
                        <div class="doc-party-label">{{ 'quote.to'|trans }}</div>
                        <h3 class="doc-party-name">{{ quote.client }}</h3>

                        {% if quote.client.website is not empty %}
                            <div class="doc-party-detail">
                                {% set website_url = quote.client.website starts with 'http://' or quote.client.website starts with 'https://' ? quote.client.website : 'https://' ~ quote.client.website %}
                                {{ ux_icon('tabler:world', {width: 16, height: 16}) }}
                                <a href="{{ website_url }}" class="detail-value" rel="external noreferrer noopener" target="_blank">
                                    <span>{{ quote.client.website }}</span>
                                    {{ ux_icon('tabler:external-link', {width: 14, height: 14}) }}
                                </a>
                            </div>
                        {% endif %}

                        {% for identifier in tax_identifiers(quote.client) %}
                            <div class="doc-party-detail">
                                <span class="detail-label">{{ identifier.label }}</span>
                                <span class="detail-value">{{ identifier.value }}</span>
                            </div>
                        {% endfor %}

                        {% for address in quote.client.addresses %}
                            <div class="doc-party-detail">
                                {{ ux_icon('tabler:map-pin', {width: 14, height: 14}) }}
                                <span class="detail-value">{{ address|replace({"\n": ", "}) }}</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                {# Line Items Table #}
                <div class="doc-items">
                    <table class="doc-items-table">
                        <thead>
                            <tr>
                                <th class="column-description">{{ 'quote.item.heading.description'|trans }}</th>
                                <th class="column-price">{{ 'quote.item.heading.price'|trans }}</th>
                                <th class="column-qty">{{ 'quote.item.heading.qty'|trans }}</th>
                                {% if quote.tax.positive %}
                                    <th class="column-tax">{{ 'quote.item.heading.tax'|trans }}</th>
                                {% endif %}
                                <th class="column-total">{{ 'quote.item.heading.total'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in quote.lines %}
                                <tr>
                                    <td class="column-description" data-label="{{ 'quote.item.heading.description'|trans }}">{{ item.description|nl2br }}</td>
                                    <td class="column-price" data-label="{{ 'quote.item.heading.price'|trans }}">{{ item.price|formatCurrency(currency) }}</td>
                                    <td class="column-qty" data-label="{{ 'quote.item.heading.qty'|trans }}">{{ item.qty }}</td>
                                    {% if quote.tax.positive %}
                                        <td class="column-tax" data-label="{{ 'quote.item.heading.tax'|trans }}">
                                            {% for lineTax in item.taxes %}{{ lineTax.nameSnapshot }} ({{ lineTax.rateSnapshot }}%){% if not loop.last %}, {% endif %}{% endfor %}
                                        </td>
                                    {% endif %}
                                    <td class="column-total" data-label="{{ 'quote.item.heading.total'|trans }}">{{ item.total|formatCurrency(currency) }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                {# Totals Section #}
                <div class="doc-totals">
                    <div class="doc-totals-grid">
                        <div class="totals-row">
                            <span class="totals-label">{{ 'quote.subtotal'|trans }}</span>
                            <span class="totals-value">{{ quote.baseTotal|formatCurrency(currency) }}</span>
                        </div>

                        {% set _tb = tax_breakdown(quote) %}
                        {% if quote.tax.positive %}
                            <div class="totals-row">
                                <span class="totals-label">{{ 'quote.line_tax'|trans }}</span>
                                <span class="totals-value">{{ quote.tax|formatCurrency(currency) }}</span>
                            </div>
                            {% for row in _tb.lineTaxRows %}
                                <div class="totals-row totals-row-tax-breakdown">
                                    <span class="totals-label totals-label-sub">{{ row.name }} ({{ row.rate }}%)</span>
                                    <span class="totals-value">{{ row.amount|formatCurrency(currency) }}</span>
                                </div>
                            {% endfor %}
                        {% endif %}
                        {% for row in _tb.additiveRows %}
                            <div class="totals-row">
                                <span class="totals-label">{{ row.name }} ({{ row.rate }}%)</span>
                                <span class="totals-value">{{ row.amount|formatCurrency(currency) }}</span>
                            </div>
                        {% endfor %}
                        {% for row in _tb.informationalRows %}
                            <div class="totals-row totals-row-tax-breakdown">
                                <span class="totals-label totals-label-sub">{{ row.name }} ({{ row.rate }}%){% if row.note %} — {{ row.note }}{% endif %}</span>
                                <span class="totals-value text-muted">{{ 'quote.invoice_taxes.informational'|trans }}</span>
                            </div>
                        {% endfor %}

                        {% if discount(quote).isPositive() %}
                            <div class="totals-row totals-row-discount">
                                <span class="totals-label">{{ 'quote.discount'|trans }}</span>
                                <span class="totals-value">-{{ discount(quote)|formatCurrency(currency) }}</span>
                            </div>
                        {% endif %}

                        <div class="totals-row totals-row-final">
                            <span class="totals-label">{{ 'quote.total'|trans }}</span>
                            <span class="totals-value">{{ quote.total|formatCurrency(currency) }}</span>
                        </div>
                        {% if quote.withholdingAmount.positive %}
                            <div class="totals-row">
                                <span class="totals-label">{{ 'quote.withholding'|trans }}</span>
                                <span class="totals-value">-{{ quote.withholdingAmount|formatCurrency(currency) }}</span>
                            </div>
                            <div class="totals-row totals-row-final">
                                <span class="totals-label">{{ 'quote.amount_payable'|trans }}</span>
                                <span class="totals-value">{{ payable_amount(quote)|formatCurrency(currency) }}</span>
                            </div>
                        {% endif %}
                    </div>
                </div>

                {# Custom Fields (admin view shows ALL fields) #}
                <twig:CustomFieldsList :target="enum('SolidInvoice\\CoreBundle\\Enum\\CustomFieldTarget').QUOTE" :recordId="quote.id" />

                {# Terms & Notes #}
                {% if quote.terms is not empty or quote.notes is not empty %}
                    <div class="doc-footer">
                        {% if quote.terms is not empty %}
                            <div class="doc-footer-section">
                                <h4 class="doc-footer-title">{{ 'quote.terms'|trans }}</h4>
                                <p class="doc-footer-text">{{ quote.terms|nl2br }}</p>
                            </div>
                        {% endif %}

                        {% if quote.notes is not empty %}
                            <div class="doc-footer-section no-print">
                                <h4 class="doc-footer-title">{{ 'quote.notes'|trans }}</h4>
                                <p class="doc-footer-text">{{ quote.notes|nl2br }}</p>
                            </div>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>

        {# Sidebar #}
        <div class="doc-view-sidebar no-print">
            {# Client Card #}
            <div class="doc-sidebar-card">
                <div class="doc-sidebar-card-header">
                    <div class="doc-sidebar-card-icon">
                        {{ ux_icon('tabler:building', {width: 18, height: 18}) }}
                    </div>
                    <h3 class="doc-sidebar-card-title">{{ 'quote.client.title'|trans }}</h3>
                </div>
                <div class="doc-sidebar-card-body">
                    <div class="client-info">
                        <a href="{{ path('_clients_view', {'id': quote.client.id}) }}" class="client-name">
                            {{ quote.client }}
                        </a>

                        {% if quote.users|length > 0 %}
                            <div class="client-contacts">
                                {% for user in quote.users %}
                                    <div class="client-contact">
                                        <div class="contact-name">{{ user }}</div>
                                        <div class="contact-email">
                                            {{ ux_icon('tabler:mail', {width: 12, height: 12}) }}
                                            {{ user.email }}
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            {# Quote Summary Card #}
            <div class="doc-sidebar-card">
                <div class="doc-sidebar-card-header">
                    <div class="doc-sidebar-card-icon">
                        {{ ux_icon('tabler:receipt', {width: 18, height: 18}) }}
                    </div>
                    <h3 class="doc-sidebar-card-title">{{ 'quote.summary'|trans }}</h3>
                </div>
                <div class="doc-sidebar-card-body">
                    <div class="doc-summary-grid">
                        <div class="summary-item">
                            <span class="summary-label">{{ 'status'|trans }}</span>
                            <span class="summary-value">{{ quote_label(quote.status) }}</span>
                        </div>
                        <div class="summary-item">
                            <span class="summary-label">{{ 'quote.total'|trans }}</span>
                            <span class="summary-value summary-value-amount">{{ quote.total|formatCurrency(currency) }}</span>
                        </div>
                        <div class="summary-item">
                            <span class="summary-label">{{ 'quote.created'|trans }}</span>
                            <span class="summary-value">{{ quote.created|date('M d, Y') }}</span>
                        </div>
                    </div>
                </div>
            </div>

            {# Related Invoice Card (if accepted) #}
            {% if quote.invoice is not null %}
                <div class="doc-sidebar-card doc-sidebar-card-success">
                    <div class="doc-sidebar-card-header">
                        <div class="doc-sidebar-card-icon">
                            {{ ux_icon('tabler:file-invoice', {width: 18, height: 18}) }}
                        </div>
                        <h3 class="doc-sidebar-card-title">{{ 'quote.view.related_invoice'|trans }}</h3>
                    </div>
                    <div class="doc-sidebar-card-body">
                        <a href="{{ path('_invoices_view', {'id' : quote.invoice.id}) }}" class="related-invoice-link">
                            {{ ux_icon('tabler:external-link', {width: 14, height: 14}) }}
                            {{ 'invoice.title'|trans({'%id%': quote.invoice.invoiceId}) }}
                        </a>
                        <div class="related-invoice-status">
                            {{ invoice_label(quote.invoice.status) }}
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock content %}
