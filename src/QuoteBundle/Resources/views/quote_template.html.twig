{% set currency = quote.client.currency %}

<div class="ext-doc-page">
    <div class="container-xl py-4">
        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-9">
                {% if false %}
                    {# App Branding Header #}
                    <div class="app-branding-header mb-4 no-print">
                        <div class="d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center gap-3">
                                {% if app_logo() is not empty %}
                                    <div class="app-logo">
                                        {{ app_logo(40, showDefault: true, showOnlyAppIcon: true) }}
                                    </div>
                                {% endif %}
                                <div>
                                    <h1 class="app-brand-name mb-0">{{ constant('SolidInvoice\\CoreBundle\\SolidInvoiceCoreBundle::APP_NAME') }}</h1>
                                    {#<p class="app-brand-tagline mb-0">{{ 'quote.external.tagline'|trans }}</p>#}
                                </div>
                            </div>
                        </div>
                    </div>
                {% endif %}

                {# Action Bar - Top #}
                <div class="ext-doc-action-bar card mb-3 no-print">
                    <div class="card-body py-3">
                        <div class="d-flex gap-2 justify-content-between align-items-center">
                            <div class="d-flex gap-2">
                                <button type="button" onclick="window.print()" class="btn btn-outline-secondary">
                                    {{ ux_icon('tabler:printer', {width: 18, height: 18}) }}
                                    {{ 'quote.action.print'|trans }}
                                </button>
                                {% if can_print_pdf() %}
                                    <a href="{{ path('_view_quote_external', {'uuid': quote.uuid, '_format': 'pdf'}) }}" target="_blank" class="btn btn-outline-secondary">
                                        {{ ux_icon('tabler:file-type-pdf', {width: 18, height: 18}) }}
                                        {{ 'quote.action.pdf'|trans }}
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>

                {# Main Quote Card #}
                <div class="card card-lg">
                    <div class="card-body">
                        {# Header with Logo and Quote Info #}
                        <div class="row">
                            <div class="col-6">
                                {% if app_logo() is not empty %}
                                    <div class="ext-doc-logo mb-3">
                                        {{ app_logo(80) }}
                                    </div>
                                {% endif %}
                                <h2 class="ext-doc-company-name mb-1">{{ company_name() }}</h2>
                                {% for identifier in tax_identifiers() %}
                                    <div class="ext-doc-vat-number">{{ identifier.label }}: {{ identifier.value }}</div>
                                {% endfor %}
                            </div>
                            <div class="col-6 text-end">
                                <div class="ext-doc-number-label text-uppercase small mb-1">{{ 'quote.title'|trans({'%id%': ''}) }}</div>
                                <h1 class="ext-doc-number mb-3">#{{ quote.quoteId }}</h1>
                                {{ quote_label(quote.status) }}
                            </div>
                        </div>

                        {# Quote Metadata Card #}
                        <div class="ext-doc-metadata-card card bg-light mb-4">
                            <div class="card-body py-4">
                                <div class="row">
                                    <div class="col-sm-6 mb-3 mb-sm-0">
                                        <div class="ext-doc-metadata-label text-uppercase small mb-1">{{ 'Quote Date'|trans }}</div>
                                        <div class="ext-doc-metadata-value fw-medium">{{ quote.created|date('M d, Y') }}</div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="ext-doc-metadata-label text-uppercase small mb-1">{{ 'quote.total'|trans }}</div>
                                        <div class="ext-doc-metadata-total text-primary fw-bold">{{ quote.total|formatCurrency(currency) }}</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {# From / To Section #}
                        <div class="row ext-doc-parties-section">
                            <div class="col-sm-6 mb-3 mb-sm-0">
                                <div class="ext-doc-party-label text-uppercase small mb-2">{{ 'quote.from'|trans }}</div>
                                <div class="ext-doc-party-name fw-bold mb-2">{{ company_name() }}</div>

                                {% set email = setting('system/company/contact_details/email') %}
                                {% if email is not empty %}
                                    <div class="ext-doc-party-detail">{{ email }}</div>
                                {% endif %}

                                {% set phoneNumber = setting('system/company/contact_details/phone_number') %}
                                {% if phoneNumber is not empty %}
                                    <div class="ext-doc-party-detail">{{ phoneNumber }}</div>
                                {% endif %}

                                {% set address = setting('system/company/contact_details/address', null, true) %}
                                {% if address is not null and address|filter(v => v) is not empty %}
                                    <div class="ext-doc-party-detail">{{ address(address) }}</div>
                                {% endif %}
                            </div>

                            <div class="col-sm-6">
                                <div class="ext-doc-party-label text-uppercase small mb-2">{{ 'quote.to'|trans }}</div>
                                <div class="ext-doc-party-name fw-bold mb-2">{{ quote.client }}</div>

                                {% for identifier in tax_identifiers(quote.client) %}
                                    <div class="ext-doc-party-detail">{{ identifier.label }}: {{ identifier.value }}</div>
                                {% endfor %}

                                {% for address in quote.client.addresses %}
                                    <div class="ext-doc-party-detail">{{ address }}</div>
                                {% endfor %}

                                {% if quote.users|length > 0 %}
                                    <div class="mt-2">
                                        {% for user in quote.users %}
                                            <div class="ext-doc-party-detail">{{ user }}</div>
                                            <div class="ext-doc-party-detail small">{{ user.email }}</div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                        </div>

                        <hr class="my-4">

                        {# Line Items Table #}
                        <div class="table-responsive">
                            <table class="table ext-doc-items-table">
                                <thead>
                                    <tr>
                                        <th class="text-uppercase small">{{ 'quote.item.heading.description'|trans }}</th>
                                        <th class="text-uppercase small text-end" style="width: 100px">{{ 'quote.item.heading.price'|trans }}</th>
                                        <th class="text-uppercase small text-center" style="width: 80px">{{ 'quote.item.heading.qty'|trans }}</th>
                                        {% if quote.tax.positive %}
                                            <th class="text-uppercase small text-end" style="width: 80px">{{ 'quote.item.heading.tax'|trans }}</th>
                                        {% endif %}
                                        <th class="text-uppercase small text-end" style="width: 120px">{{ 'quote.item.heading.total'|trans }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for item in quote.lines %}
                                        <tr>
                                            <td class="item-description">{{ item.description|nl2br }}</td>
                                            <td class="text-end item-amount">{{ item.price|formatCurrency(currency) }}</td>
                                            <td class="text-center">{{ item.qty }}</td>
                                            {% if quote.tax.positive %}
                                                <td class="text-end item-amount">
                                                    {% for lineTax in item.taxes %}{{ lineTax.nameSnapshot }} ({{ lineTax.rateSnapshot }}%){% if not loop.last %}, {% endif %}{% endfor %}
                                                </td>
                                            {% endif %}
                                            <td class="text-end fw-bold item-amount">{{ item.total|formatCurrency(currency) }}</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>

                        {# Client-visible custom fields #}
                        <twig:CustomFieldsListPdf
                            :target="enum('SolidInvoice\\CoreBundle\\Enum\\CustomFieldTarget').QUOTE"
                            :recordId="quote.id"
                            :visibility="enum('SolidInvoice\\CoreBundle\\Enum\\CustomFieldVisibility').CLIENT_VISIBLE"
                        />

                        <hr class="my-4">

                        {# Totals Section #}
                        <div class="row justify-content-end">
                            <div class="col-lg-5 col-md-6">
                                <div class="ext-doc-totals-card card bg-light">
                                    <div class="card-body">
                                        <div class="ext-doc-totals-row">
                                            <div class="ext-doc-totals-label">{{ 'quote.subtotal'|trans }}</div>
                                            <div class="ext-doc-totals-value">{{ quote.baseTotal|formatCurrency(currency) }}</div>
                                        </div>
                                        {% set _tb = tax_breakdown(quote) %}
                                        {% if quote.tax.positive %}
                                            <div class="ext-doc-totals-row">
                                                <div class="ext-doc-totals-label">{{ 'quote.line_tax'|trans }}</div>
                                                <div class="ext-doc-totals-value">{{ quote.tax|formatCurrency(currency) }}</div>
                                            </div>
                                            {% for row in _tb.lineTaxRows %}
                                                <div class="ext-doc-totals-row ext-doc-totals-row-sub">
                                                    <div class="ext-doc-totals-label small opacity-75">{{ row.name }} ({{ row.rate }}%)</div>
                                                    <div class="ext-doc-totals-value">{{ row.amount|formatCurrency(currency) }}</div>
                                                </div>
                                            {% endfor %}
                                        {% endif %}
                                        {% for row in _tb.additiveRows %}
                                            <div class="ext-doc-totals-row">
                                                <div class="ext-doc-totals-label">{{ row.name }} ({{ row.rate }}%)</div>
                                                <div class="ext-doc-totals-value">{{ row.amount|formatCurrency(currency) }}</div>
                                            </div>
                                        {% endfor %}
                                        {% for row in _tb.informationalRows %}
                                            <div class="ext-doc-totals-row ext-doc-totals-row-sub">
                                                <div class="ext-doc-totals-label small opacity-75">{{ row.name }} ({{ row.rate }}%){% if row.note %} — {{ row.note }}{% endif %}</div>
                                                <div class="ext-doc-totals-value text-muted">{{ 'quote.invoice_taxes.informational'|trans }}</div>
                                            </div>
                                        {% endfor %}
                                        {% if quote.discount.type is not empty %}
                                            <div class="ext-doc-totals-row">
                                                <div class="ext-doc-totals-label">{{ 'quote.discount'|trans }}</div>
                                                <div class="ext-doc-totals-value text-success">-{{ discount(quote)|formatCurrency(currency) }}</div>
                                            </div>
                                        {% endif %}
                                        <div class="ext-doc-totals-final">
                                            <div class="ext-doc-totals-row">
                                                <div class="ext-doc-totals-label">{{ 'quote.total'|trans }}</div>
                                                <div class="ext-doc-totals-value text-primary">{{ quote.total|formatCurrency(currency) }}</div>
                                            </div>
                                        </div>
                                        {% if quote.withholdingAmount.positive %}
                                            <div class="ext-doc-totals-row">
                                                <div class="ext-doc-totals-label">{{ 'quote.withholding'|trans }}</div>
                                                <div class="ext-doc-totals-value text-danger">-{{ quote.withholdingAmount|formatCurrency(currency) }}</div>
                                            </div>
                                            <div class="ext-doc-totals-final">
                                                <div class="ext-doc-totals-row">
                                                    <div class="ext-doc-totals-label">{{ 'quote.amount_payable'|trans }}</div>
                                                    <div class="ext-doc-totals-value text-primary">{{ payable_amount(quote)|formatCurrency(currency) }}</div>
                                                </div>
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>

                        {# Terms #}
                        {% if quote.terms is not empty %}
                            <hr class="my-4">
                            <div class="mb-3">
                                <strong class="d-block mb-2">{{ 'quote.terms'|trans }}</strong>
                                <div class="opacity-75">{{ quote.terms|nl2br }}</div>
                            </div>
                        {% endif %}
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
