{% extends '@SolidInvoiceCore/Layout/default.html.twig' %}

{% block title %}{{ ux_icon('tabler:forms', {width: 24, height: 24, class: 'me-2'}) }}{{ "Custom fields"|trans }}{% endblock %}

{% block heading %}
    <a href="{{ path('_settings_custom_fields_create') }}" class="btn btn-primary">
        {{ ux_icon('tabler:plus', {width: 18, height: 18}) }}
        {{ 'Add field'|trans }}
    </a>
{% endblock %}

{% block content %}
    <ul class="nav nav-underline" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" data-bs-toggle="tab" href="#tab-client" role="tab" aria-controls="tab-client">
                <span class="nav-link-icon d-none d-sm-inline-block">
                    {{ ux_icon('tabler:building', {width: 16, height: 16}) }}
                </span>
                <span>{{ 'Client fields'|trans }}</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#tab-contact" role="tab" aria-controls="tab-contact">
                <span class="nav-link-icon d-none d-sm-inline-block">
                    {{ ux_icon('tabler:user', {width: 16, height: 16}) }}
                </span>
                <span>{{ 'Contact fields'|trans }}</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#tab-invoice" role="tab" aria-controls="tab-invoice">
                <span class="nav-link-icon d-none d-sm-inline-block">
                    {{ ux_icon('tabler:file-invoice', {width: 16, height: 16}) }}
                </span>
                <span>{{ 'Invoice fields'|trans }}</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#tab-quote" role="tab" aria-controls="tab-quote">
                <span class="nav-link-icon d-none d-sm-inline-block">
                    {{ ux_icon('tabler:file-text', {width: 16, height: 16}) }}
                </span>
                <span>{{ 'Quote fields'|trans }}</span>
            </a>
        </li>
    </ul>

    <div class="card mt-3">
        <div class="tab-content">
            {% for tabId, rows in {'client': client, 'contact': contact, 'invoice': invoice, 'quote': quote} %}
                <div class="tab-pane{% if loop.first %} active show{% endif %}" id="tab-{{ tabId }}">
                    {% if rows is empty %}
                        <div class="card-body text-center text-muted">
                            {{ 'No custom fields yet — click Add field to create one.'|trans }}
                        </div>
                    {% else %}
                        <div class="list-group list-group-flush custom-field-list"
                             {{ stimulus_controller('custom-field-reorder', {
                                 url: path('_settings_custom_fields_reorder'),
                                 csrfToken: csrf_token('custom_field_reorder'),
                             }) }}>
                            {% for row in rows %}
                                <div class="list-group-item d-flex align-items-center custom-field-row" data-id="{{ row.field.id }}">
                                    <span class="custom-field-handle me-3" data-handle title="{{ 'Drag to reorder'|trans }}" aria-label="{{ 'Drag to reorder'|trans }}">
                                        {{ ux_icon('tabler:grip-vertical', {width: 18, height: 18}) }}
                                    </span>
                                    <div class="flex-fill">
                                        <strong>{{ row.field.label }}</strong>
                                        <span class="badge bg-secondary-lt ms-2">{{ row.field.type.label }}</span>
                                        {% if row.field.required %}<span class="badge bg-yellow-lt ms-1">{{ 'Required'|trans }}</span>{% endif %}
                                        {% if row.field.visibility is not null %}
                                            {% if row.field.visibility.value == 'CLIENT_VISIBLE' %}
                                                <span class="badge bg-blue-lt ms-1">{{ 'Client-visible'|trans }}</span>
                                            {% else %}
                                                <span class="badge bg-secondary-lt ms-1">{{ 'Internal'|trans }}</span>
                                            {% endif %}
                                        {% endif %}
                                        <div class="text-muted small">{{ row.count }} {{ 'values'|trans }}</div>
                                    </div>
                                    <div class="d-flex gap-1">
                                        <a href="{{ path('_settings_custom_fields_edit', {id: row.field.id}) }}"
                                           class="btn btn-ghost-secondary btn-icon btn-icon-sm"
                                           title="{{ 'Edit'|trans }}"
                                           aria-label="{{ 'Edit'|trans }}">
                                            {{ ux_icon('tabler:pencil', {width: 16, height: 16}) }}
                                        </a>
                                        <form method="post" action="{{ path('_settings_custom_fields_delete', {id: row.field.id}) }}" class="d-inline" onsubmit="return confirm('{{ 'Delete %label%? %count% records have a value for this field. These values will be permanently deleted.'|trans({'%label%': row.field.label, '%count%': row.count}) }}')">
                                            <input type="hidden" name="_token" value="{{ csrf_token('cf_delete_' ~ row.field.id) }}">
                                            <button class="btn btn-ghost-danger btn-icon btn-icon-sm" type="submit"
                                                    title="{{ 'Delete'|trans }}"
                                                    aria-label="{{ 'Delete'|trans }}">
                                                {{ ux_icon('tabler:trash', {width: 16, height: 16}) }}
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                        {% if rows|length > 1 %}
                            <div class="px-3 py-2 text-muted small d-flex align-items-center gap-2">
                                {{ ux_icon('tabler:arrows-sort', {width: 16, height: 16}) }}
                                {{ 'Drag the handle on the left of each row to reorder fields.'|trans }}
                            </div>
                        {% endif %}
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
