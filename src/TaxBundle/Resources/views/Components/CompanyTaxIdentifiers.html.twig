<div {{ attributes.defaults({class: 'company-tax-identifiers'}) }}>
    <h3 class="d-flex align-items-center gap-2 mb-2">
        {{ ux_icon('tabler:receipt-tax', {width: 22, height: 22, class: 'text-primary', 'aria-hidden': 'true'}) }}
        {{ 'tax.company_identifiers.title'|trans }}
    </h3>
    <p class="text-muted small mb-3">
        {{ 'tax.company_identifiers.description'|trans }}
    </p>

    {{ form_start(form, {
        attr: {
            'data-action': 'live#action:prevent',
            'data-live-action-param': 'save'
        }
    }) }}

    <div class="tax-identifiers-list mb-3">
        {% for identifier in form.identifiers %}
            <div class="row g-3 align-items-end mb-2 company-tax-identifier-row">
                <div class="col-md-4">
                    {{ form_row(identifier.label, {label: 'tax.company_identifiers.label'|trans}) }}
                </div>
                <div class="col">
                    {{ form_row(identifier.value, {label: 'tax.company_identifiers.value'|trans}) }}
                </div>
                <div class="col-auto">
                    {{ form_row(identifier.primary, {label: 'tax.company_identifiers.primary'|trans}) }}
                </div>
                <div class="col-auto">
                    <button type="button"
                            class="btn btn-sm btn-outline-danger"
                            data-action="live#action"
                            data-live-action-param="removeCollectionItem"
                            data-live-name-param="{{ form.identifiers.vars.full_name }}"
                            data-live-index-param="{{ loop.index0 }}"
                            title="{{ 'tax.company_identifiers.remove'|trans }}"
                            aria-label="{{ 'tax.company_identifiers.remove'|trans }}">
                        {{ ux_icon('tabler:trash', {width: 16, height: 16, 'aria-hidden': 'true'}) }}
                    </button>
                </div>
            </div>
        {% else %}
            <p class="text-muted small mb-2">
                {{ 'tax.company_identifiers.empty'|trans }}
            </p>
        {% endfor %}
    </div>

    {{ form_errors(form.identifiers) }}

    <div class="d-flex justify-content-between align-items-center">
        {{ form_widget(form.identifiers.vars.button_add, {
            label: 'tax.company_identifiers.add'|trans,
            attr: {
                class: 'btn btn-ghost btn-sm'
            }
        }) }}

        <button type="submit" class="btn btn-primary btn-sm">
            {{ ux_icon('tabler:device-floppy', {width: 16, height: 16, 'aria-hidden': 'true'}) }}
            {{ 'tax.company_identifiers.save'|trans }}
        </button>
    </div>

    {{ form_end(form) }}
</div>
