{% extends "@SolidInvoiceCore/Layout/default.html.twig" %}

{% block title %}{{ ux_icon('tabler:user-cog', {width: 24, height: 24, class: 'me-2'}) }}{{ 'Set User Role'|trans }}{% endblock title %}

{% block heading %}
    <a href="{{ path('_users_list') }}" class="btn btn-outline-secondary">
        {{ ux_icon('tabler:arrow-left', {width: 18, height: 18}) }}
        {{ 'Back to Users'|trans }}
    </a>
{% endblock %}

{% block content %}
    <twig:Ui:Card>
        <div class="mb-4">
            <div class="text-secondary">{{ 'Access level for'|trans }}</div>
            <div class="h3 mb-0">{{ user.userIdentifier }}</div>
        </div>

        <form method="post" action="{{ path('_user_edit', {id: user.id}) }}">
            <div class="row g-3">
                {% for role in roles %}
                    <div class="col-12">
                        <label class="form-selectgroup-item d-block">
                            <div class="card {{ currentRole == role ? 'border-primary' : '' }}">
                                <div class="card-body d-flex align-items-start">
                                    <input type="radio" name="role" value="{{ role.value }}" class="form-check-input mt-1 me-3"
                                           {{ currentRole == role ? 'checked' : '' }} required>
                                    <div>
                                        <span class="badge bg-{{ role.color }} text-{{ role.color }}-fg mb-1">{{ role.label }}</span>
                                        <div class="text-secondary">{{ role.description }}</div>
                                    </div>
                                </div>
                            </div>
                        </label>
                    </div>
                {% endfor %}
            </div>

            {% if currentRole is null %}
                <div class="alert alert-warning mt-3 mb-0">
                    {{ ux_icon('tabler:alert-triangle', {width: 18, height: 18}) }}
                    {{ 'This user has no role yet and can only see the dashboard. Choose a role to grant access.'|trans }}
                </div>
            {% endif %}

            <input type="hidden" name="_token" value="{{ csrf_token('user.role') }}">

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    {{ ux_icon('tabler:device-floppy', {width: 18, height: 18}) }}
                    {{ 'Save Role'|trans }}
                </button>
                <a href="{{ path('_users_list') }}" class="btn btn-link">{{ 'Cancel'|trans }}</a>
            </div>
        </form>
    </twig:Ui:Card>
{% endblock %}
